#lang beagle/clj
(ns selfhost.parse)
(define-mode strict)

;; Self-hosted parser for beagle — port of driftlab self-host/parse.bjs,
;; upgraded to today's surface (beagle-lib/private/parse.rkt).
;; Input: vector of top-level datums (selfhost.reader encoding).
;; Output: program AST matching beagle-lib/private/ast-json.rkt exactly.
;;
;; REMAINING GAP — MODULE RESOLUTION (the k/* permissive-Any gap; recorded
;; on thread). parse.rkt's require scan (resolve-module-path +
;; import-module-types!, ~300 lines) READS each required module's source
;; and imports: typed externs for def/defn/defonce (alias-qualified +
;; :refer-bare), defrecord field/ctor/accessor types, defunion members
;; (incl. parametric), defenum values, defscalar backing types + preds,
;; deferror members, imported ^:dynamic vars, and required modules' MACROS
;; (qualified) — incl. the one fresh-lowered-sym site not mirrored here
;; (parse.rkt (fresh-lowered-sym 'p) for non-symbol imported-proc-macro
;; params). This chain does NONE of that: qualified refs (k/x) and :refer
;; imports type as Any, so cross-module type errors pass the selfhost
;; check (the Racket oracle still catches them). Emitted BYTES are
;; unaffected for programs that compile under the oracle — externs shape
;; typing, not emission — which is why verify-selfhost's AST-parity rung
;; compares forms/requires/namespace/mode/target and excludes externs.
;; Porting it needs a module loader (path resolution + file IO + recursive
;; reader/parse) in what is today a pure datum->AST stage (IO lives in
;; rt.clj/main.bclj): a tranche of its own, not a tail item.
;;
;; Also unported: source locations (this chain carries none; seed emission
;; is srcloc-free by construction) and non-clj target surfaces (nix reader
;; macros / nix-* forms — the selfhost chain emits the clj target only).

(require clojure.string :as str)
(require selfhost.rt)
(require selfhost.macros :as mac)

(declare-extern selfhost.rt/eprint [String -> Nil])

;; --- constants ---------------------------------------------------------------

(def BRACKET-TAG :- String "#%brackets")
(def MAP-TAG :- String "#%map")
(def SET-TAG :- String "#%set")
(def CHAR-TAG :- String "#%char")

(def META-FORMS :- (Vec String)
  ["ns" "define-mode" "define-target" "define-macro" "defmacro" "defalias"
   "declare-extern" "require" "import"])

;; --- error collection ---------------------------------------------------------
;; Racket raises; we collect + eprint and keep parsing (tranche-1 discipline:
;; pointed message parity over abort parity). check/main fail on non-empty.

(def ERRORS :- Any (atom []))

(defn parse-errors [] :- Any
  ;; macro-expansion errors (arity, depth) are parse-time diagnostics too;
  ;; fold them in so the driver's exit gate treats them like any parse error.
  (into (deref ERRORS) (mac/macro-errors)))

(defn reset-errors! [] :- Nil
  (reset! ERRORS [])
  (mac/reset-macro-errors!)
  nil)

(defn- err! [msg :- String] :- Any
  (swap! ERRORS conj msg)
  (selfhost.rt/eprint (str "beagle: " msg "\n"))
  {"node" "literal" "kind" "nil"})

;; --- small vector/string helpers ----------------------------------------------

(defn- char-at [s :- String i :- Int] :- String
  (if (and (>= i 0) (< i (count s))) (subs s i (+ i 1)) ""))

(defn- index-of-item [xs :- Any x :- Any] :- Int
  (let [n (count xs)]
    (loop [i 0]
      (cond
        (>= i n) -1
        (= (nth xs i) x) i
        :else (recur (+ i 1))))))

(defn- has-item? [xs :- Any x :- Any] :- Bool
  (not (= -1 (index-of-item xs x))))

(defn- str-index-of [s :- String sub :- String] :- Int
  (let [r (str/index-of s sub)]
    (if (nil? r) -1 r)))

;; --- forward-reference cells ----------------------------------------------------
;; bb/SCI resolves defn bodies eagerly, and emit-clj has no `declare`, so the
;; parser's mutual recursion (parse-type <-> parse-fn-type-items, parse-expr! <->
;; parse-list-form! and every form helper) routes through atom cells wired by
;; top-level reset! at the end of the module. Computed calls ((f) x) don't emit
;; on the clj target — `apply` carries the deref'd fn as a value instead.

(def PARSE-TYPE-CELL :- Any (atom nil))
(def PARSE-EXPR-CELL :- Any (atom nil))

(defn- parse-type* [t :- Any] :- Any
  (apply (deref PARSE-TYPE-CELL) [t]))

(defn- parse-expr* [d :- Any] :- Any
  (apply (deref PARSE-EXPR-CELL) [d]))

;; --- tag utilities -----------------------------------------------------------

(defn bracketed? [d :- Any] :- Bool
  (and (vector? d) (> (count d) 0) (= (nth d 0) BRACKET-TAG)))

(defn bracket-body [d :- Any] :- Any
  (subvec d 1))

(defn map-tagged? [d :- Any] :- Bool
  (and (vector? d) (> (count d) 0) (= (nth d 0) MAP-TAG)))

(defn map-body [d :- Any] :- Any
  (subvec d 1))

(defn set-tagged? [d :- Any] :- Bool
  (and (vector? d) (> (count d) 0) (= (nth d 0) SET-TAG)))

(defn set-body [d :- Any] :- Any
  (subvec d 1))

(defn unwrap-items [d :- Any] :- Any
  (cond
    (bracketed? d) (bracket-body d)
    (vector? d) d
    :else []))

(defn string-datum? [d :- Any] :- Bool
  (or (string? d)
      (and (vector? d) (= (count d) 2) (= (nth d 0) "#%string"))))

;; A STRING LITERAL datum only (`["#%string" s]`) — NOT a bare symbol. In the
;; selfhost datum encoding symbols are plain strings, so `string-datum?` (which
;; includes bare strings) can't distinguish a nix `(s ...)` text part from a
;; symbol/ref part; the nix interp/multiline arms need this strict check to
;; mirror Racket's `(string? d)` (where a symbol is NOT a string).
(defn string-literal-datum? [d :- Any] :- Bool
  (and (vector? d) (= (count d) 2) (= (nth d 0) "#%string")))

(defn extract-string [d :- Any] :- String
  (if (string? d) d (nth d 1)))

;; --- symbol predicates -------------------------------------------------------

(def UPPER :- String "ABCDEFGHIJKLMNOPQRSTUVWXYZ")

(defn- upper-case-start? [sym :- String] :- Bool
  (and (> (count sym) 0) (str/includes? UPPER (char-at sym 0))))

(defn dot-method-sym? [sym :- String] :- Bool
  (and (> (count sym) 1) (= (char-at sym 0) ".")))

(defn static-method-sym? [sym :- String] :- Bool
  (let [slash-pos (str-index-of sym "/")]
    (and (> slash-pos 0) (< (+ slash-pos 1) (count sym))
         (or (upper-case-start? sym)
             (str/starts-with? sym "js/")))))

(defn constructor-sym? [sym :- String] :- Bool
  (and (> (count sym) 1)
       (upper-case-start? sym)
       (= (char-at sym (- (count sym) 1)) ".")))

(defn keyword-sym? [sym :- String] :- Bool
  (and (> (count sym) 1) (= (char-at sym 0) ":")))

(defn dynamic-var-sym? [sym :- String] :- Bool
  (and (>= (count sym) 3)
       (= (char-at sym 0) "*")
       (= (char-at sym (- (count sym) 1)) "*")))

;; `:-` is canonical; wrapped positions also accept legacy `:` (parse.rkt
;; annotation-marker?). Flat/inline positions require `:-` and reject `:`
;; with a pointed error — handled at each site.
(defn annotation-marker? [sym :- Any] :- Bool
  (or (= sym ":-") (= sym ":")))

(defn canonical-marker? [sym :- Any] :- Bool
  (= sym ":-"))

;; --- type constructors ---------------------------------------------------------

(def PARAMETRIC-CTORS :- (Vec String)
  ["Vec" "List" "Set" "Map" "Promise" "NixType" "Arr" "Ptr" "Atom" "HVec"])

(def CLJ-ALIASES :- (Map String String)
  {"Long" "Int" "Double" "Float" "Boolean" "Bool" "Integer" "Int"})

;; user parametric-union names (defunion prescan) + defalias table
(def USER-PARAMETRIC :- Any (atom {}))
(def TYPE-ALIASES :- Any (atom {}))

(defn make-prim [name :- String] :- Any
  {"kind" "prim" "name" name})

(defn make-fn-type [params :- Any rest-type :- Any ret :- Any] :- Any
  {"kind" "fn" "params" params "rest" rest-type "ret" ret})

(defn make-app [ctor :- String args :- Any] :- Any
  {"kind" "app" "name" ctor "args" args})

(defn make-union [members :- Any] :- Any
  {"kind" "union" "members" members})

(defn make-type-var [name :- String] :- Any
  {"kind" "var" "name" name})

(defn parse-fn-type-items [items :- Any] :- Any
  (let [arrow-pos (index-of-item items "->")]
    (if (= arrow-pos -1)
      (make-prim "Any")
      (let [before (subvec items 0 arrow-pos)
            after (subvec items (+ arrow-pos 1))]
        (if (not (= (count after) 1))
          (make-prim "Any")
          (let [amp-pos (index-of-item before "&")]
            (if (> amp-pos -1)
              (make-fn-type
                (mapv parse-type* (subvec before 0 amp-pos))
                (parse-type* (nth (subvec before (+ amp-pos 1)) 0))
                (parse-type* (nth after 0)))
              (make-fn-type
                (mapv parse-type* before)
                nil
                (parse-type* (nth after 0))))))))))

(defn parse-type [t :- Any] :- Any
  (cond
    (and (vector? t) (> (count t) 0) (= (nth t 0) BRACKET-TAG))
      (parse-fn-type-items (subvec t 1))

    (and (vector? t) (= (count t) 3) (= (nth t 0) "forall"))
      (let [vars-form (nth t 1)
            raw-vars (if (and (vector? vars-form) (> (count vars-form) 0)
                              (= (nth vars-form 0) BRACKET-TAG))
                       (subvec vars-form 1)
                       vars-form)
            vars (filterv string? raw-vars)]
        {"kind" "poly" "vars" vars "body" (parse-type (nth t 2)) "bounds" nil})

    (and (vector? t) (> (count t) 1) (= (nth t 0) "U"))
      (make-union (mapv parse-type (subvec t 1)))

    (and (vector? t) (> (count t) 0) (string? (nth t 0))
         (or (has-item? PARAMETRIC-CTORS (nth t 0))
             (= true (get (deref USER-PARAMETRIC) (nth t 0)))))
      (make-app (nth t 0) (mapv parse-type (subvec t 1)))

    (and (string? t) (some? (get (deref TYPE-ALIASES) t)))
      (get (deref TYPE-ALIASES) t)

    (and (string? t) (> (count t) 1)
         (= (char-at t (- (count t) 1)) "?"))
      (let [base (subs t 0 (- (count t) 1))]
        (make-union [(parse-type base) (make-prim "Nil")]))

    (and (string? t) (= t "Number"))
      (make-union [(make-prim "Int") (make-prim "Float")])

    (and (string? t) (some? (get CLJ-ALIASES t)))
      (make-prim (get CLJ-ALIASES t))

    (string? t) (make-prim t)

    :else (make-prim "Any")))

(reset! PARSE-TYPE-CELL parse-type)

;; --- AST constructors ----------------------------------------------------------
;; JSON-absent = false where ast-json.rkt uses (and x ...), null where it
;; serializes a #f type via type->json.

(defn make-literal [kind :- String value :- Any] :- Any
  (if (= kind "nil")
    {"node" "literal" "kind" "nil"}
    {"node" "literal" "kind" kind "value" value}))

(defn make-ref [name :- String] :- Any
  {"node" "ref" "name" name})

(def NIL-LITERAL :- Any {"node" "literal" "kind" "nil"})
(def FALSE-LITERAL :- Any {"node" "literal" "kind" "bool" "value" false})

(defn make-def [name :- String ann :- Any value :- Any doc :- Any dyn :- Bool] :- Any
  {"node" "def" "name" name "ann" ann "value" value
   "doc" (if (nil? doc) false doc) "dynamic" dyn})

(defn make-defonce [name :- String ann :- Any value :- Any doc :- Any] :- Any
  {"node" "defonce" "name" name "ann" ann "value" value
   "doc" (if (nil? doc) false doc)})

(defn make-defn [name :- String params :- Any rest-param :- Any
                 ret :- Any body :- Any priv :- Bool] :- Any
  {"node" "defn" "name" name "params" params
   "rest" (if (nil? rest-param) false rest-param)
   "ret" ret "body" body "private" priv})

(defn make-defn-multi [name :- String arities :- Any priv :- Bool] :- Any
  {"node" "defn-multi" "name" name "arities" arities "private" priv})

(defn make-fn [params :- Any rest-param :- Any ret :- Any body :- Any] :- Any
  {"node" "fn" "params" params "rest" (if (nil? rest-param) false rest-param)
   "ret" ret "body" body})

(defn make-let [bindings :- Any body :- Any] :- Any
  {"node" "let" "bindings" bindings "body" body})

;; (if c t) stores else = #f in Racket; ast-json serializes that as a bool
;; literal (expr->json is unguarded there). Replicated faithfully.
(defn make-if [test :- Any then-expr :- Any else-expr :- Any] :- Any
  {"node" "if" "cond" test "then" then-expr
   "else" (if (nil? else-expr) FALSE-LITERAL else-expr)})

(defn make-cond [clauses :- Any] :- Any
  {"node" "cond" "clauses" clauses})

(defn make-do [body :- Any] :- Any
  {"node" "do" "body" body})

(defn make-call [fn-expr :- Any args :- Any] :- Any
  {"node" "call" "fn" fn-expr "args" args})

(defn make-vec [items :- Any] :- Any
  {"node" "vec" "items" items})

(defn make-map [pairs :- Any] :- Any
  {"node" "map" "pairs" pairs})

(defn make-set-form [items :- Any] :- Any
  {"node" "set" "items" items})

(defn make-quoted [datum :- Any] :- Any
  {"node" "quoted" "datum" datum})

(defn make-loop [bindings :- Any body :- Any] :- Any
  {"node" "loop" "bindings" bindings "body" body})

(defn make-recur [args :- Any] :- Any
  {"node" "recur" "args" args})

(defn make-for [clauses :- Any body :- Any] :- Any
  {"node" "for" "clauses" clauses "body" body})

(defn make-method-call [method :- String target :- Any args :- Any] :- Any
  {"node" "method-call" "method" method "target" target "args" args})

(defn make-static-call [class-method :- String args :- Any] :- Any
  {"node" "static-call" "name" class-method "args" args})

;; threading-marker (ast.rkt): kind + parsed surface args (clj/cljs surface
;; reconstruction) + parsed desugared form (what check walks).
(defn make-threading [kind :- String args :- Any desugared :- Any] :- Any
  {"node" "threading" "kind" kind "args" args "desugared" desugared})

(defn make-kw-access [kw :- String target :- Any fallback :- Any] :- Any
  {"node" "kw-access" "kw" kw "target" target
   "default" (if (nil? fallback) false fallback)})

(defn make-try [body :- Any catches :- Any finally-body :- Any] :- Any
  {"node" "try" "body" body "catches" catches
   "finally" (if (nil? finally-body) false finally-body)})

(defn make-match [target :- Any clauses :- Any] :- Any
  {"node" "match" "target" target "clauses" clauses})

(defn make-with [target :- Any updates :- Any] :- Any
  {"node" "with" "target" target "updates" updates})

;; --- nix node constructors (shapes mirror ast-json.rkt L466-543) --------------

(defn make-nix-inherit [names :- Any] :- Any
  {"node" "nix-inherit" "names" names})

(defn make-nix-inherit-from [ns-expr :- Any names :- Any] :- Any
  {"node" "nix-inherit-from" "ns-expr" ns-expr "names" names})

(defn make-nix-with [ns-expr :- Any body :- Any] :- Any
  {"node" "nix-with" "ns-expr" ns-expr "body" body})

(defn make-nix-rec-attrs [pairs :- Any] :- Any
  {"node" "nix-rec-attrs" "pairs" pairs})

(defn make-nix-assert [cond-expr :- Any body :- Any] :- Any
  {"node" "nix-assert" "cond" cond-expr "body" body})

(defn make-nix-get-or [base :- Any path :- String default :- Any] :- Any
  {"node" "nix-get-or" "base" base "path" path "default" default})

(defn make-nix-has-attr [base :- Any path :- String] :- Any
  {"node" "nix-has-attr" "base" base "path" path})

(defn make-nix-search-path [name :- String] :- Any
  {"node" "nix-search-path" "name" name})

(defn make-nix-interpolated-string [parts :- Any] :- Any
  {"node" "nix-interpolated-string" "parts" parts})

(defn make-nix-multiline-string [lines :- Any] :- Any
  {"node" "nix-multiline-string" "lines" lines})

(defn make-nix-path [path :- String] :- Any
  {"node" "nix-path" "path" path})

;; at-name is `false` when absent (Racket `(and #f ...)` -> #f -> JSON false);
;; each formal default is `false` when absent, matching the oracle serializer.
(defn make-nix-fn-set [formals :- Any rest :- Bool at-name :- Any body :- Any] :- Any
  {"node" "nix-fn-set" "formals" formals "rest" rest "at-name" at-name "body" body})

;; nix/derivation, nix/flake, nix/with-cfg, flake-input have NO serializer case
;; in ast-json.rkt -> the oracle bin/beagle-ast falls to the [else] arm and emits
;; {"node":"unknown","raw":"#(struct:...)"} (a Racket struct dump). We produce
;; proper node shapes here so emit-nix can consume them; AST parity against the
;; oracle DIFFs on these four until ast-json.rkt grows the cases (Racket lane).
(defn make-nix-derivation [attrs :- Any] :- Any
  {"node" "nix-derivation" "attrs" attrs})

(defn make-nix-flake [attrs :- Any] :- Any
  {"node" "nix-flake" "attrs" attrs})

(defn make-nix-with-cfg [path :- Any body :- Any] :- Any
  {"node" "nix-with-cfg" "path" path "body" body})

(defn make-flake-input [input-name :- Any namespace :- Any path :- Any] :- Any
  {"node" "flake-input" "input-name" input-name "namespace" namespace "path" path})

(defn make-defrecord [name :- String fields :- Any] :- Any
  {"node" "record" "name" name "fields" fields})

(defn make-defenum [name :- String values :- Any] :- Any
  {"node" "defenum" "name" name "values" values})

(defn make-defunion [name :- String members :- Any
                     type-params :- Any member-fields :- Any] :- Any
  (if (nil? member-fields)
    {"node" "defunion" "name" name "members" members "type-params" type-params}
    {"node" "defunion" "name" name "members" members
     "type-params" type-params "member-fields" member-fields}))

(defn make-deferror [name :- String members :- Any member-fields :- Any] :- Any
  (if (nil? member-fields)
    {"node" "deferror" "name" name "members" members}
    {"node" "deferror" "name" name "members" members "member-fields" member-fields}))

(defn make-defscalar [name :- String backing :- Any] :- Any
  {"node" "defscalar" "name" name "backing" backing})

(defn make-condp [pred-fn :- Any test-expr :- Any clauses :- Any fallback :- Any] :- Any
  {"node" "condp" "pred" pred-fn "test" test-expr "clauses" clauses
   "default" (if (nil? fallback) false fallback)})

(defn make-doseq [clauses :- Any body :- Any] :- Any
  {"node" "doseq" "clauses" clauses "body" body})

(defn make-letfn [fns :- Any body :- Any] :- Any
  {"node" "letfn" "fns" fns "body" body})

(defn make-set! [target :- Any value :- Any] :- Any
  {"node" "set!" "target" target "value" value})

(defn make-await [expr :- Any] :- Any
  {"node" "await" "expr" expr})

(defn make-new [class-name :- String args :- Any] :- Any
  {"node" "new" "class" class-name "args" args})

(defn make-regex [pattern :- String] :- Any
  {"node" "regex" "pattern" pattern})

(defn make-dynamic-var [name :- String] :- Any
  {"node" "dynamic-var" "name" name})

;; --- param / binding / pattern constructors ------------------------------------

(defn make-param [name :- String ann :- Any] :- Any
  {"type" "param" "name" name "ann" ann})

(defn make-map-destructure [keys :- Any as-name :- Any] :- Any
  {"type" "map-destructure" "keys" keys
   "as" (if (nil? as-name) false as-name)})

(defn make-seq-destructure [names :- Any rest-name :- Any] :- Any
  {"type" "seq-destructure" "names" names
   "rest" (if (nil? rest-name) false rest-name)})

(defn make-let-binding [name :- Any ann :- Any value :- Any] :- Any
  {"name" name "ann" ann "value" value})

(defn make-pat-wildcard [] :- Any
  {"type" "wildcard"})

(defn make-pat-literal [value :- Any] :- Any
  {"type" "literal" "value" value})

(defn make-pat-record [type-name :- String bindings :- Any] :- Any
  {"type" "record" "name" type-name "bindings" bindings})

(defn make-pat-map [entries :- Any] :- Any
  {"type" "map" "entries" entries})

(defn make-pat-var [name :- String] :- Any
  {"type" "var" "name" name})

;; --- lowering temps (macros.rkt fresh-lowered-sym!) -----------------------------
;; Deterministic lowering temps, ported from fix/emit-determinism: names are
;; <base>__<n> from ONE counter reset per parse-program!, so minted names depend
;; only on module content. Bases mirror parse.rkt: cond-thread / some-thread /
;; bind. The counter LIVES in selfhost.macros (as in Racket, where parse.rkt
;; imports macros.rkt's lowering-counter) — shared with macro-hygiene renames.

(defn- fresh-lowered-sym! [base :- String] :- String
  (mac/fresh-lowered-sym! base))

;; --- user-macro registry (macros.rkt registry via current-registry) ------------
;; Fresh per parse-program!; nested macro applications inside expressions
;; consult it through this cell (parse.rkt parameterizes current-registry).
;; nil = no program context (bare parse-expr* in tests) — macro-inert.

(def CURRENT-REGISTRY-CELL :- Any (atom nil))

;; --- datum->json (quoted datums / case values; ast-json.rkt encoding) ----------
;; Symbols tag as {"type" "symbol"}, keywords as {"type" "keyword"} (colon
;; stripped); reader strings ["#%string" s] collapse to plain JSON strings.

(defn datum->json [d :- Any] :- Any
  (cond
    (and (vector? d) (= (count d) 2) (= (nth d 0) "#%string"))
      (nth d 1)
    (and (string? d) (keyword-sym? d))
      {"type" "keyword" "value" (subs d 1)}
    (string? d) {"type" "symbol" "value" d}
    (number? d) d
    (boolean? d) d
    (nil? d) nil
    (vector? d) (mapv datum->json d)
    :else (str d)))

;; --- parse-params! ------------------------------------------------------------

(defn map-destructure-form? [item :- Any] :- Bool
  (and (map-tagged? item)
       (let [body (map-body item)]
         (and (>= (count body) 2)
              (= (nth body 0) ":keys")
              (bracketed? (nth body 1))))))

(defn parse-map-destructure [item :- Any] :- Any
  (let [body (map-body item)
        keys-bracket (nth body 1)
        key-names (bracket-body keys-bracket)
        n (count body)]
    (loop [i 2 as-name :- Any nil]
      (cond
        (>= i n) (make-map-destructure key-names as-name)
        (and (= (nth body i) ":as") (< (+ i 1) n) (string? (nth body (+ i 1))))
          (recur (+ i 2) (nth body (+ i 1)))
        ;; :or defaults parse but aren't serialized by ast-json — consume.
        (and (= (nth body i) ":or") (< (+ i 1) n))
          (recur (+ i 2) as-name)
        :else (recur (+ i 1) as-name)))))

(defn parse-seq-destructure [item :- Any] :- Any
  (let [body (bracket-body item)
        n (count body)]
    (loop [i 0 names :- Any [] rest-name :- Any nil]
      (cond
        (>= i n) (make-seq-destructure names rest-name)
        (= (nth body i) "&")
          (if (and (< (+ i 1) n) (string? (nth body (+ i 1))))
            (make-seq-destructure names (nth body (+ i 1)))
            (make-seq-destructure names nil))
        (string? (nth body i))
          (recur (+ i 1) (conj names (nth body i)) rest-name)
        :else (make-seq-destructure names rest-name)))))

;; wrapped single-item param: (name :- T) / (name : T)
(defn- wrapped-annotated? [item :- Any] :- Bool
  (and (vector? item) (not (bracketed? item)) (= (count item) 3)
       (string? (nth item 0))
       (annotation-marker? (nth item 1))))

(defn- parse-rest-param! [after :- Any] :- Any
  (cond
    ;; & name
    (and (= (count after) 1) (string? (nth after 0)))
      (make-param (nth after 0) nil)
    ;; & (name :- T)
    (and (= (count after) 1) (wrapped-annotated? (nth after 0)))
      (make-param (nth (nth after 0) 0) (parse-type (nth (nth after 0) 2)))
    ;; & name :- T   (flat)
    (and (= (count after) 3) (string? (nth after 0))
         (annotation-marker? (nth after 1)))
      (make-param (nth after 0) (parse-type (nth after 2)))
    :else
      (do (err! (str "bad rest parameter after &: " (str after)))
          nil)))

;; Today's grammar: flat inline `name :- TYPE` triples (canonical), wrapped
;; `(name :- T)`, destructures, bare names. Flat bare `:` is rejected.
(defn parse-params! [params-form :- Any] :- Any
  (let [items (unwrap-items params-form)
        n (count items)]
    (loop [i 0 fixed :- Any [] rest-param :- Any nil]
      (cond
        (>= i n) {"params" fixed "rest-param" rest-param}
        (= (nth items i) "&")
          (if (< (+ i 1) n)
            {"params" fixed "rest-param" (parse-rest-param! (subvec items (+ i 1)))}
            (do (err! "& must be followed by a rest parameter")
                {"params" fixed "rest-param" nil}))
        ;; flat inline `name :- TYPE`
        (and (string? (nth items i)) (< (+ i 2) (+ n 1))
             (< (+ i 2) n)
             (canonical-marker? (nth items (+ i 1))))
          (recur (+ i 3)
                 (conj fixed (make-param (nth items i) (parse-type (nth items (+ i 2)))))
                 rest-param)
        ;; flat bare `:` — pointed rejection at `:-`
        (and (string? (nth items i)) (< (+ i 2) n)
             (= (nth items (+ i 1)) ":"))
          (do (err! (str "[" (nth items i) " : ...] — bare `:` is not the inline type marker. Use `:-` for inline type annotation:\n  [" (nth items i) " :- TYPE ...]"))
              (recur (+ i 3) fixed rest-param))
        :else
          (let [item (nth items i)]
            (cond
              (bracketed? item)
                (recur (+ i 1) (conj fixed (parse-seq-destructure item)) rest-param)
              (map-destructure-form? item)
                (recur (+ i 1) (conj fixed (parse-map-destructure item)) rest-param)
              (wrapped-annotated? item)
                (recur (+ i 1)
                       (conj fixed (make-param (nth item 0) (parse-type (nth item 2))))
                       rest-param)
              (string? item)
                (recur (+ i 1) (conj fixed (make-param item nil)) rest-param)
              :else
                (do (err! (str "bad parameter: " (str item) " — expected name, name :- Type, (name :- Type), [seq...], or {:keys [...]}"))
                    (recur (+ i 1) fixed rest-param))))))))

;; --- parse-let-bindings! ------------------------------------------------------
;; Arm order mirrors parse.rkt: wrapped-annotated pair, map/seq destructure
;; pairs, flat 4-item `name :- TYPE value`, flat bare-`:` rejection, bare pair.

(defn parse-let-bindings! [b :- Any] :- Any
  (let [items (unwrap-items b)
        n (count items)]
    (loop [i 0 acc :- Any []]
      (cond
        (>= i n) acc
        ;; wrapped typed binding: (name :- Type) value
        (and (< (+ i 1) n) (wrapped-annotated? (nth items i)))
          (recur (+ i 2)
                 (conj acc (make-let-binding
                             (nth (nth items i) 0)
                             (parse-type (nth (nth items i) 2))
                             (parse-expr* (nth items (+ i 1))))))
        ;; map destructure binding
        (and (< (+ i 1) n) (map-destructure-form? (nth items i)))
          (recur (+ i 2)
                 (conj acc (make-let-binding
                             (parse-map-destructure (nth items i))
                             nil
                             (parse-expr* (nth items (+ i 1))))))
        ;; seq destructure binding
        (and (< (+ i 1) n) (bracketed? (nth items i)))
          (recur (+ i 2)
                 (conj acc (make-let-binding
                             (parse-seq-destructure (nth items i))
                             nil
                             (parse-expr* (nth items (+ i 1))))))
        ;; flat typed binding: name :- TYPE value (consume 4)
        (and (< (+ i 3) (+ n 0)) (string? (nth items i))
             (canonical-marker? (nth items (+ i 1))))
          (recur (+ i 4)
                 (conj acc (make-let-binding
                             (nth items i)
                             (parse-type (nth items (+ i 2)))
                             (parse-expr* (nth items (+ i 3))))))
        ;; flat bare `:` — pointed rejection
        (and (< (+ i 3) n) (string? (nth items i))
             (= (nth items (+ i 1)) ":"))
          (do (err! (str "(let [" (nth items i) " : ...] ...) — bare `:` is not the inline type marker. Use `:-` for inline type annotation:\n  (let [" (nth items i) " :- TYPE VALUE ...] ...)"))
              (recur (+ i 4) acc))
        ;; bare name binding
        (and (< (+ i 1) n) (string? (nth items i)))
          (recur (+ i 2)
                 (conj acc (make-let-binding
                             (nth items i)
                             nil
                             (parse-expr* (nth items (+ i 1))))))
        :else
          (do (err! (str "bad let bindings at: " (str (nth items i))))
              acc)))))

;; --- parse-record-fields! -----------------------------------------------------
;; Flat `name :- Type` triples (canonical) or wrapped (name :- Type).
;; Untyped fields are rejected (records are typed boundaries).

(defn parse-record-fields! [f :- Any] :- Any
  (let [items (unwrap-items f)
        n (count items)]
    (loop [i 0 acc :- Any []]
      (cond
        (>= i n) acc
        ;; flat triple
        (and (string? (nth items i)) (< (+ i 2) n)
             (annotation-marker? (nth items (+ i 1))))
          (recur (+ i 3)
                 (conj acc {"name" (nth items i)
                            "ann" (parse-type (nth items (+ i 2)))}))
        ;; wrapped
        (wrapped-annotated? (nth items i))
          (recur (+ i 1)
                 (conj acc {"name" (nth (nth items i) 0)
                            "ann" (parse-type (nth (nth items i) 2))}))
        :else
          (do (err! (str "defrecord field needs a type annotation — use [name :- Type ...], got: " (str (nth items i))))
              (recur (+ i 1) acc))))))

;; --- parse-cond-clauses ------------------------------------------------------

;; A cond test of `:else` (Clojure idiom) or bare `else` canonicalizes to the
;; ref `else` — parse.rkt parse-cond-test does the same with the symbol 'else.
(defn- parse-cond-test [test-datum :- Any] :- Any
  (if (or (= test-datum ":else") (= test-datum "else"))
    (make-ref "else")
    (parse-expr* test-datum)))

(defn parse-cond-clauses [clauses :- Any] :- Any
  (cond
    (= (count clauses) 0) []
    ;; bracketed style: [test body...]
    (bracketed? (nth clauses 0))
      (mapv (fn [c :- Any] :- Any
              (let [items (if (bracketed? c) (bracket-body c) c)]
                (if (and (vector? items) (> (count items) 1))
                  {"test" (parse-cond-test (nth items 0))
                   "body" (mapv parse-expr* (subvec items 1))}
                  {"test" (parse-cond-test c) "body" []})))
            clauses)
    ;; flat style: test body test body...
    :else
      (let [n (count clauses)]
        (loop [i 0 acc :- Any []]
          (cond
            (>= i n) acc
            (< (+ i 1) n)
              (recur (+ i 2)
                     (conj acc {"test" (parse-cond-test (nth clauses i))
                                "body" [(parse-expr* (nth clauses (+ i 1)))]}))
            :else acc)))))

;; --- parse-for-clauses -------------------------------------------------------

(defn parse-for-clauses [b :- Any] :- Any
  (let [items (unwrap-items b)
        n (count items)]
    (loop [i 0 acc :- Any []]
      (cond
        (>= i n) acc
        (and (< (+ i 1) n) (= (nth items i) ":when"))
          (recur (+ i 2)
                 (conj acc {"type" "when" "test" (parse-expr* (nth items (+ i 1)))}))
        (and (< (+ i 1) n) (= (nth items i) ":let"))
          (recur (+ i 2)
                 (conj acc {"type" "let" "bindings" (parse-let-bindings! (nth items (+ i 1)))}))
        (and (< (+ i 1) n) (string? (nth items i)))
          (recur (+ i 2)
                 (conj acc {"type" "binding"
                            "name" (nth items i)
                            "expr" (parse-expr* (nth items (+ i 1)))}))
        :else (recur (+ i 1) acc)))))

;; --- parse-try-form ----------------------------------------------------------

(defn- catch-clause? [item :- Any] :- Bool
  (and (vector? item) (not (bracketed? item)) (> (count item) 0)
       (= (nth item 0) "catch")))

(defn- finally-clause? [item :- Any] :- Bool
  (and (vector? item) (not (bracketed? item)) (> (count item) 0)
       (= (nth item 0) "finally")))

(defn parse-try-form [rest-items :- Any] :- Any
  (let [n (count rest-items)]
    (loop [i 0 body :- Any [] catches :- Any [] finally-body :- Any nil]
      (if (>= i n)
        (make-try body catches finally-body)
        (let [item (nth rest-items i)]
          (cond
            (catch-clause? item)
              (if (>= (count item) 4)
                (recur (+ i 1) body
                       (conj catches {"type" (nth item 1)
                                      "name" (nth item 2)
                                      "body" (mapv parse-expr* (subvec item 3))})
                       finally-body)
                (recur (+ i 1) body catches finally-body))
            (finally-clause? item)
              (recur (+ i 1) body catches (mapv parse-expr* (subvec item 1)))
            (and (= (count catches) 0) (nil? finally-body))
              (recur (+ i 1) (conj body (parse-expr* item)) catches finally-body)
            :else (recur (+ i 1) body catches finally-body)))))))

;; --- parse-match-form --------------------------------------------------------

(defn parse-map-pattern [entries :- Any] :- Any
  (let [n (count entries)]
    (loop [i 0 acc :- Any []]
      (cond
        (>= i n) (make-pat-map acc)
        (and (< (+ i 1) n)
             (string? (nth entries i))
             (keyword-sym? (nth entries i)))
          (recur (+ i 2)
                 (conj acc {"key" (datum->json (nth entries i))
                            "name" (nth entries (+ i 1))}))
        :else (recur (+ i 1) acc)))))

(defn parse-pattern [p :- Any] :- Any
  (cond
    (= p "_") (make-pat-wildcard)
    (= p "nil") (make-pat-literal nil)
    (and (string? p) (keyword-sym? p)) (make-pat-literal (datum->json p))
    (number? p) (make-pat-literal p)
    (boolean? p) (make-pat-literal p)
    (string-datum? p) (make-pat-literal (extract-string p))
    (and (vector? p) (> (count p) 0) (= (nth p 0) MAP-TAG))
      (parse-map-pattern (subvec p 1))
    ;; record pattern: (TypeName bindings...)
    (and (vector? p) (not (bracketed? p)) (> (count p) 0)
         (string? (nth p 0))
         (upper-case-start? (nth p 0)))
      (make-pat-record (nth p 0)
        (mapv (fn [b :- Any] :- Any {"name" b}) (subvec p 1)))
    (string? p) (make-pat-var p)
    :else (make-pat-literal (datum->json p))))

(defn parse-match-form [target-datum :- Any clauses :- Any] :- Any
  (make-match (parse-expr* target-datum)
    (mapv (fn [c :- Any] :- Any
            (let [items (if (bracketed? c) (bracket-body c) c)]
              (if (and (vector? items) (>= (count items) 2))
                {"pattern" (parse-pattern (nth items 0))
                 "body" (mapv parse-expr* (subvec items 1))}
                {"pattern" (parse-pattern c) "body" []})))
          clauses)))

;; --- parse-with-form ---------------------------------------------------------

(defn parse-with-form [target-datum :- Any updates :- Any] :- Any
  (make-with (parse-expr* target-datum)
    (mapv (fn [u :- Any] :- Any
            (if (and (bracketed? u) (>= (count (bracket-body u)) 2))
              (let [items (bracket-body u)]
                {"field" (nth items 0) "value" (parse-expr* (nth items 1))})
              {"field" "" "value" nil}))
          updates)))

;; --- nix formal / rec-attrs parsers (parse.rkt L3562-3615) --------------------

;; Returns {"formals" [...] "at-name" (false|str)}. Each formal is
;; {"name" str "default" (false|expr)}. The rest-marker `...` is filtered out;
;; `:as name` at the tail captures the whole attrset as at-name.
(defn parse-nix-fn-set-formals! [formals-form :- Any] :- Any
  (let [items (cond (bracketed? formals-form) (bracket-body formals-form)
                    (vector? formals-form) formals-form
                    :else (do (err! "fn-set: expected list of formals") []))]
    (loop [i 0 before :- Any [] at-name :- Any false]
      (cond
        (>= i (count items))
          {"formals"
           (mapv (fn [item :- Any] :- Any
                   (cond
                     (string? item) {"name" item "default" false}
                     (and (bracketed? item) (= (count (bracket-body item)) 2))
                       {"name" (nth (bracket-body item) 0)
                        "default" (parse-expr* (nth (bracket-body item) 1))}
                     (and (vector? item) (= (count item) 2))
                       {"name" (nth item 0) "default" (parse-expr* (nth item 1))}
                     :else (do (err! (str "fn-set formal: expected name or (name default), got " (str item)))
                               {"name" (str item) "default" false})))
                 (filterv (fn [x :- Any] :- Bool (not= x "...")) before))
           "at-name" at-name}
        (= (nth items i) ":as")
          (if (>= (+ i 1) (count items))
            (do (err! "fn-set/module: :as requires a name")
                {"formals" [] "at-name" false})
            (recur (count items) before (nth items (+ i 1))))
        :else (recur (+ i 1) (conj before (nth items i)) at-name)))))

;; Alternating key/value -> [{"key" str "val" expr} ...]; keys are symbols.
(defn parse-nix-rec-pairs! [items :- Any] :- Any
  (loop [i 0 acc :- Any []]
    (cond
      (>= i (count items)) acc
      (>= (+ i 1) (count items))
        (do (err! "rec-attrs: expected key value pairs, got odd number of forms") acc)
      :else
        (recur (+ i 2)
               (conj acc {"key" (let [k (nth items i)]
                                  (if (string? k) k
                                    (do (err! (str "rec-attrs: key must be symbol, got " (str k)))
                                        (str k))))
                          "val" (parse-expr* (nth items (+ i 1)))})))))

;; --- parse-letfn-fns! ---------------------------------------------------------

(defn parse-letfn-fns! [form :- Any] :- Any
  (let [items (unwrap-items form)]
    (mapv (fn [item :- Any] :- Any
            (if (and (vector? item) (>= (count item) 3) (string? (nth item 0)))
              (let [name (nth item 0)
                    params-form (nth item 1)
                    rest-forms (subvec item 2)
                    parsed-params (parse-params! params-form)
                    rp (get parsed-params "rest-param")]
                (if (and (>= (count rest-forms) 2)
                         (annotation-marker? (nth rest-forms 0)))
                  {"name" name
                   "params" (get parsed-params "params")
                   "rest" (if (nil? rp) false rp)
                   "ret" (parse-type (nth rest-forms 1))
                   "body" (mapv parse-expr* (subvec rest-forms 2))}
                  {"name" name
                   "params" (get parsed-params "params")
                   "rest" (if (nil? rp) false rp)
                   "ret" nil
                   "body" (mapv parse-expr* rest-forms)}))
              nil))
          items)))

;; --- parse-condp-form --------------------------------------------------------

(defn parse-condp-form [pred-datum :- Any test-datum :- Any clause-datums :- Any] :- Any
  (let [pred-expr (parse-expr* pred-datum)
        test-expr (parse-expr* test-datum)
        n (count clause-datums)]
    (loop [i 0 pairs :- Any [] fallback :- Any nil]
      (cond
        (>= i n) (make-condp pred-expr test-expr pairs fallback)
        (= i (- n 1))
          (make-condp pred-expr test-expr pairs (parse-expr* (nth clause-datums i)))
        (< (+ i 1) n)
          (recur (+ i 2)
                 (conj pairs {"test" (parse-expr* (nth clause-datums i))
                              "body" (parse-expr* (nth clause-datums (+ i 1)))})
                 fallback)
        :else (make-condp pred-expr test-expr pairs fallback)))))

;; --- multi-arity detection ---------------------------------------------------

(defn multi-arity-form? [d :- Any] :- Bool
  (and (vector? d)
       (not (bracketed? d))
       (> (count d) 0)
       (vector? (nth d 0))
       (bracketed? (nth d 0))))

(defn parse-arity-clause! [clause :- Any] :- Any
  (let [params-form (nth clause 0)
        rest-forms (subvec clause 1)
        parsed-params (parse-params! params-form)
        rp (get parsed-params "rest-param")]
    (if (and (>= (count rest-forms) 2)
             (annotation-marker? (nth rest-forms 0)))
      {"params" (get parsed-params "params")
       "rest" (if (nil? rp) false rp)
       "ret" (parse-type (nth rest-forms 1))
       "body" (mapv parse-expr* (subvec rest-forms 2))}
      {"params" (get parsed-params "params")
       "rest" (if (nil? rp) false rp)
       "ret" nil
       "body" (mapv parse-expr* rest-forms)})))

;; --- threading macro expansion (datum-level rewrite, then parse) ----------------

(defn thread-step-insert [val :- Any step :- Any position :- String] :- Any
  (if (vector? step)
    (if (= position "first")
      (vec (concat [(nth step 0)] [val] (subvec step 1)))
      (conj step val))
    [step val]))

(defn expand-thread-first [init :- Any steps :- Any] :- Any
  (reduce (fn [acc :- Any step :- Any] :- Any
            (thread-step-insert acc step "first"))
          init steps))

(defn expand-thread-last [init :- Any steps :- Any] :- Any
  (reduce (fn [acc :- Any step :- Any] :- Any
            (thread-step-insert acc step "last"))
          init steps))

(defn expand-cond-thread [kind :- String init :- Any clauses :- Any] :- Any
  (when (not= (mod (count clauses) 2) 0)
    (err! (str kind ": expected pairs of (test step) after init; got "
               (str (mod (count clauses) 2)) " trailing form(s)")))
  (let [n (count clauses)
        pairs (loop [i 0 acc :- Any []]
                (if (>= (+ i 1) n)
                  acc
                  (recur (+ i 2) (conj acc [(nth clauses i) (nth clauses (+ i 1))]))))
        pos (if (= kind "cond->") "first" "last")
        ;; parse.rkt expand-cond-thread: a FRESH temp per step, never one temp
        ;; rebound (emit-js flattens nested lets into one block, where rebinding
        ;; emitted a duplicate const). temps[0] binds init; temps[i+1] binds
        ;; step i's if-form. Pre-minting preserves Racket's counter order —
        ;; nothing else mints between these.
        k (count pairs)
        temps (loop [i 0 acc :- Any [(fresh-lowered-sym! "cond-thread")]]
                (if (>= i k)
                  acc
                  (recur (+ i 1) (conj acc (fresh-lowered-sym! "cond-thread")))))
        inner (loop [i (- k 1) acc :- Any (nth temps k)]
                (if (< i 0)
                  acc
                  (recur (- i 1)
                         ["let" [BRACKET-TAG (nth temps (+ i 1))
                                 ["if" (nth (nth pairs i) 0)
                                  (thread-step-insert (nth temps i) (nth (nth pairs i) 1) pos)
                                  (nth temps i)]]
                          acc])))]
    ["let" [BRACKET-TAG (nth temps 0) init] inner]))

(defn expand-some-thread [kind :- String init :- Any steps :- Any] :- Any
  (let [pos (if (= kind "some->") "first" "last")
        m (count steps)]
    (if (= m 0)
      init
      ;; parse.rkt expand-some-thread: a temp per step; temps[i] binds the value
      ;; flowing INTO step i (init, then step i-1's threaded result); nil?-test
      ;; short-circuits to nil; the LAST step's threaded form is returned bare.
      (let [temps (loop [i 0 acc :- Any []]
                    (if (>= i m)
                      acc
                      (recur (+ i 1) (conj acc (fresh-lowered-sym! "some-thread")))))
            threadeds (loop [i 0 acc :- Any []]
                        (if (>= i m)
                          acc
                          (recur (+ i 1)
                                 (conj acc (thread-step-insert (nth temps i) (nth steps i) pos)))))]
        (loop [i (- m 1) acc :- Any (nth threadeds (- m 1))]
          (let [node ["let" [BRACKET-TAG (nth temps i)
                             (if (= i 0) init (nth threadeds (- i 1)))]
                      ["if" ["nil?" (nth temps i)] "nil" acc]]]
            (if (= i 0)
              node
              (recur (- i 1) node))))))))

;; (as-> init name s1 s2 …) -> (let [name init] (let [name s1] (let [name s2]
;; … name))) — each let SHADOWS the previous binding and the innermost body is
;; the placeholder (parse.rkt expand-as-thread; NOT a value-position fold).
(defn expand-as-thread [init :- Any name :- Any steps :- Any] :- Any
  (let [values (into [init] steps)]
    (loop [i (- (count values) 1) acc :- Any name]
      (if (< i 0)
        acc
        (recur (- i 1) ["let" [BRACKET-TAG name (nth values i)] acc])))))

;; --- binding-conditional lowering (parse.rkt lower-binding-cond!) ----------------
;; (if-let [x v] t e)   -> (let [x v] (if x t e))          — simple [name expr]
;; (when-some [x v] b…) -> (let [x v] (if (not (nil? x)) (do b…)))
;; Typed/destructure binders bind a minted temp (bind__<n>, fresh-lowered-sym!)
;; and rebind inside the success branch. Temp names match the Racket compiler
;; post fix/emit-determinism; the counter is shared with macro-hygiene renames
;; (selfhost.macros), so defmacro-using modules number identically too.

(defn- binding-cond-test [head :- String v :- Any] :- Any
  (if (or (= head "if-let") (= head "when-let"))
    v
    ["not" ["nil?" v]]))

(defn- lower-binding-cond! [head :- String bindings-form :- Any rest-items :- Any] :- Any
  (let [items (unwrap-items bindings-form)]
    (if (< (count items) 2)
      (do (err! (str head ": bindings must be [binder expr], got: " (str bindings-form)))
          "nil")
      (let [value (nth items (- (count items) 1))
            binder-part (subvec items 0 (- (count items) 1))
            if-form? (or (= head "if-let") (= head "if-some"))]
        (if (and (= (count binder-part) 1) (string? (nth binder-part 0)))
          (let [name (nth binder-part 0)
                binding [BRACKET-TAG name value]
                test (binding-cond-test head name)]
            (if if-form?
              ["let" binding ["if" test (nth rest-items 0) (nth rest-items 1)]]
              ["let" binding ["if" test (vec (concat ["do"] rest-items))]]))
          (let [g (fresh-lowered-sym! "bind")
                inner (vec (concat [BRACKET-TAG] binder-part [g]))
                test (binding-cond-test head g)]
            (if if-form?
              ["let" [BRACKET-TAG g value]
               ["if" test ["let" inner (nth rest-items 0)] (nth rest-items 1)]]
              ["let" [BRACKET-TAG g value]
               ["if" test ["let" inner (vec (concat ["do"] rest-items))]]])))))))

;; --- defunion / deferror helpers ----------------------------------------------

(defn parse-simple-defunion [name :- String raw-members :- Any] :- Any
  (let [n (count raw-members)]
    (loop [i 0 mnames :- Any [] mf :- Any {} has-fields false]
      (if (>= i n)
        (make-defunion name mnames nil (if has-fields mf nil))
        (let [m (nth raw-members i)]
          (if (and (vector? m) (not (bracketed? m)) (> (count m) 0))
            (if (and (>= (count m) 2) (vector? (nth m 1)))
              (recur (+ i 1) (conj mnames (nth m 0))
                     (assoc mf (nth m 0) (parse-record-fields! (nth m 1)))
                     true)
              (recur (+ i 1) (conj mnames (nth m 0)) mf has-fields))
            (recur (+ i 1) (conj mnames m) mf has-fields)))))))

(defn parse-parametric-defunion! [name :- String type-vars :- Any member-defs :- Any] :- Any
  (swap! USER-PARAMETRIC assoc name true)
  (let [n (count member-defs)]
    (loop [i 0 mnames :- Any [] mf :- Any {}]
      (if (>= i n)
        (make-defunion name mnames type-vars mf)
        (let [md (nth member-defs i)]
          (if (and (vector? md) (>= (count md) 2) (string? (nth md 0)))
            (recur (+ i 1) (conj mnames (nth md 0))
                   (assoc mf (nth md 0) (parse-record-fields! (nth md 1))))
            (recur (+ i 1) mnames mf)))))))

(defn parse-deferror-form [name :- String member-defs :- Any] :- Any
  (let [n (count member-defs)]
    (loop [i 0 mnames :- Any [] mf :- Any {}]
      (if (>= i n)
        (make-deferror name mnames mf)
        (let [md (nth member-defs i)]
          (cond
            (string? md)
              (recur (+ i 1) (conj mnames md) (assoc mf md []))
            (and (vector? md) (>= (count md) 2) (string? (nth md 0)))
              (recur (+ i 1) (conj mnames (nth md 0))
                     (assoc mf (nth md 0) (parse-record-fields! (nth md 1))))
            :else (recur (+ i 1) mnames mf)))))))

;; --- parse-map-literal -------------------------------------------------------

(defn parse-map-literal [items :- Any] :- Any
  (let [n (count items)]
    (loop [i 0 pairs :- Any []]
      (cond
        (>= i n) (make-map pairs)
        (< (+ i 1) n)
          (recur (+ i 2)
                 (conj pairs {"key" (parse-expr* (nth items i))
                              "val" (parse-expr* (nth items (+ i 1)))}))
        :else (make-map pairs)))))

;; --- defn family --------------------------------------------------------------

;; Bare-vector multi-arity (parse.rkt bare-multi-arity-clauses):
;;   (defn name [a] body [a b] body)
;; canonicalizes to list-wrapped clauses ((params body…) …). Returns nil
;; unless the strict shape holds: first arg is a params vec, >= 2 top-level
;; vecs, every vec followed by >= 1 non-vec body form, and no top-level `:-`
;; (that is a single-arity RETURN annotation, never an arity boundary).
(defn- bare-multi-arity-clauses [args :- Any] :- Any
  (cond
    (or (= (count args) 0) (not (bracketed? (nth args 0)))) nil
    (has-item? args ":-") nil
    :else
      (let [n (count args)
            state (loop [i 0 segments :- Any [] cur :- Any [] ok true]
                    (if (or (>= i n) (not ok))
                      {"segments" segments "cur" cur "ok" ok}
                      (let [arg (nth args i)]
                        (if (bracketed? arg)
                          (cond
                            (= (count cur) 0)
                              (recur (+ i 1) segments [arg] ok)
                            (= (count cur) 1)
                              (recur (+ i 1) segments cur false)
                            :else
                              (recur (+ i 1) (conj segments cur) [arg] ok))
                          (if (= (count cur) 0)
                            (recur (+ i 1) segments cur false)
                            (recur (+ i 1) segments (conj cur arg) ok))))))]
        (cond
          (not (get state "ok")) nil
          (<= (count (get state "cur")) 1) nil
          :else
            (let [all (conj (get state "segments") (get state "cur"))]
              (if (>= (count all) 2) all nil))))))

(defn- parse-defn-tail! [name :- String after-name :- Any priv :- Bool] :- Any
  (cond
    ;; multi-arity (list-wrapped clauses)
    (and (>= (count after-name) 1) (multi-arity-form? (nth after-name 0)))
      (make-defn-multi name (mapv parse-arity-clause! after-name) priv)
    ;; bare-vector multi-arity canonicalizes to the same clauses
    (some? (bare-multi-arity-clauses after-name))
      (make-defn-multi name
                       (mapv parse-arity-clause! (bare-multi-arity-clauses after-name))
                       priv)
    ;; with return type: params :- RET [:raises ERR] body...
    (and (>= (count after-name) 3)
         (canonical-marker? (nth after-name 1)))
      (let [parsed-params (parse-params! (nth after-name 0))
            ret (parse-type (nth after-name 2))
            tail (subvec after-name 3)
            ;; :raises ERR is parsed and dropped — not serialized by ast-json.
            body-forms (if (and (>= (count tail) 2) (= (nth tail 0) ":raises"))
                         (subvec tail 2)
                         tail)]
        (make-defn name
                   (get parsed-params "params")
                   (get parsed-params "rest-param")
                   ret
                   (mapv parse-expr* body-forms)
                   priv))
    ;; bare `:` return marker — pointed rejection
    (and (>= (count after-name) 3) (= (nth after-name 1) ":"))
      (err! (str "(defn " name " [params] : RET ...) — bare `:` is not the inline type marker. Use `:-` for inline type annotation:\n  (defn " name " [params] :- RET body...)"))
    ;; without return type
    (>= (count after-name) 2)
      (let [parsed-params (parse-params! (nth after-name 0))]
        (make-defn name
                   (get parsed-params "params")
                   (get parsed-params "rest-param")
                   nil
                   (mapv parse-expr* (subvec after-name 1))
                   priv))
    :else (err! (str "malformed defn " name))))

;; Strip ["#%meta" mv name] name wrappers; ^:private marks private.
(defn- meta-name? [d :- Any] :- Bool
  (and (vector? d) (= (count d) 3) (= (nth d 0) "#%meta") (string? (nth d 2))))

;; --- def/defonce arms (docstring + ^:dynamic recorded on the node) -------------

;; `^:dynamic` on a def name: the metadata value is either the keyword
;; `:dynamic` (shorthand) or a #%map carrying `:dynamic true` (longhand);
;; any other metadata is accepted and stripped (parse.rkt meta-dynamic?).
(defn- meta-dynamic? [mv :- Any] :- Bool
  (cond
    (= mv ":dynamic") true
    (map-tagged? mv)
      (let [kvs (map-body mv)
            n (count kvs)]
        (loop [i 0]
          (cond
            (>= (+ i 1) n) false
            (and (= (nth kvs i) ":dynamic") (= (nth kvs (+ i 1)) true)) true
            :else (recur (+ i 2)))))
    :else false))

(defn- mk-def-node [kw :- String name :- String ann :- Any value :- Any
                    doc :- Any dyn :- Bool] :- Any
  (if (= kw "defonce")
    (make-defonce name ann value doc)
    (make-def name ann value doc dyn)))

(defn- parse-def-form! [kw :- String rest-items :- Any] :- Any
  (let [name-form (nth rest-items 0)
        name (if (meta-name? name-form) (nth name-form 2) name-form)
        dyn (and (= kw "def") (meta-name? name-form)
                 (meta-dynamic? (nth name-form 1)))
        items (subvec rest-items 1)]
    (cond
      (not (string? name))
        (err! (str "malformed " kw ": " (str rest-items)))
      ;; defonce takes a plain name only (parse.rkt defonce arms have no
      ;; #%meta variant — a meta-wrapped name is malformed there)
      (and (= kw "defonce") (meta-name? name-form))
        (err! "malformed defonce — expected (defonce NAME VALUE), (defonce NAME \"doc\" VALUE), or (defonce NAME :- TYPE VALUE)")
      ;; name :- TYPE "doc" value
      (and (>= (count items) 4)
           (canonical-marker? (nth items 0))
           (string-datum? (nth items 2))
           (vector? (nth items 2)))
        (mk-def-node kw name (parse-type (nth items 1)) (parse-expr* (nth items 3))
                     (extract-string (nth items 2)) dyn)
      ;; name :- TYPE value
      (and (>= (count items) 3) (canonical-marker? (nth items 0)))
        (mk-def-node kw name (parse-type (nth items 1)) (parse-expr* (nth items 2))
                     nil dyn)
      ;; bare `:` — pointed rejection
      (and (>= (count items) 3) (= (nth items 0) ":"))
        (err! (str "(" kw " " name " : ...) — bare `:` is not the inline type marker. Use `:-` for inline type annotation:\n  (" kw " " name " :- TYPE VALUE)"))
      ;; name "doc" value
      (and (= (count items) 2)
           (vector? (nth items 0))
           (= (count (nth items 0)) 2)
           (= (nth (nth items 0) 0) "#%string"))
        (mk-def-node kw name nil (parse-expr* (nth items 1))
                     (extract-string (nth items 0)) dyn)
      ;; name value
      (= (count items) 1)
        (mk-def-node kw name nil (parse-expr* (nth items 0)) nil dyn)
      :else
        (err! (str "malformed " kw " — expected (" kw " NAME VALUE), (" kw " NAME \"doc\" VALUE), (" kw " NAME :- TYPE VALUE), or (" kw " NAME :- TYPE \"doc\" VALUE)")))))

;; --- target-case (parse.rkt parse-target-case) ---------------------------------
;; (target-case :clj E :js E …) — branches parse in SOURCE order (counter
;; parity); duplicate targets: last wins (Racket hash-set!). The cases list
;; serializes SORTED by target name, matching ast-json.rkt's deterministic
;; ordering of the underlying hasheq.

(defn- parse-target-case! [items :- Any] :- Any
  (let [n (count items)
        cases (loop [i 0 acc :- Any {}]
                (cond
                  (>= i n) acc
                  (< (+ i 1) n)
                    (let [kw (nth items i)]
                      (if (and (string? kw) (keyword-sym? kw))
                        (recur (+ i 2)
                               (assoc acc (subs kw 1) (parse-expr* (nth items (+ i 1)))))
                        (do (err! (str "target-case: expected target keyword, got: " (str kw)))
                            (recur (+ i 2) acc))))
                  :else
                    (do (err! (str "target-case: expected keyword-expression pairs, got trailing: " (str (subvec items i))))
                        acc)))]
    (if (= (count cases) 0)
      (err! "target-case: no branches provided")
      {"node" "target-case"
       "cases" (mapv (fn [k :- String] :- Any
                       {"target" k "body" (get cases k)})
                     (vec (sort (vec (keys cases)))))})))

;; --- parse-list-form!: the big dispatch ---------------------------------------

;; ===== js/quote parsing (port of beagle-lib/private/parse-js-quote.rkt) =======
;; Parses a (js/quote ...) body of RAW reader datums into js-ast JSON nodes
;; (key "jsk"), consumed by selfhost.emit-js/emit-js-ast-node. Splices (~x /
;; ~@x / ~%x) parse the trailing datum as a beagle expr via parse-expr*.

(def JSQ-BINARY-OPS :- Any
  {"+" "+" "-" "-" "*" "*" "/" "/" "%" "%" "**" "**"
   "===" "===" "!==" "!==" "==" "==" "!=" "!="
   "<" "<" ">" ">" "<=" "<=" ">=" ">="
   "and" "&&" "or" "||" "nullish" "??"
   "bit-and" "&" "bit-or" "|" "bit-xor" "^"
   "<<" "<<" ">>" ">>" ">>>" ">>>" "in" "in" "instanceof" "instanceof"})

(def JSQ-ASSIGN-OPS :- Any
  {"+=" "+=" "-=" "-=" "*=" "*=" "/=" "/=" "%=" "%=" "**=" "**="
   "and=" "&&=" "or=" "||=" "nullish=" "??="
   "bit-and=" "&=" "bit-or=" "|=" "bit-xor=" "^="
   "<<=" "<<=" ">>=" ">>=" ">>>=" ">>>="})

(defn- jsq-binary-op? [s :- Any] :- Bool (and (string? s) (contains? JSQ-BINARY-OPS s)))
(defn- jsq-assign-op? [s :- Any] :- Bool (and (string? s) (contains? JSQ-ASSIGN-OPS s)))

;; The binary op string underlying a compound assignment (drop trailing "=").
(defn- jsq-strip-assign-op [s :- String] :- String
  (let [js (get JSQ-ASSIGN-OPS s)] (subs js 0 (- (count js) 1))))

(defn- jsq-strlit? [d :- Any] :- Bool
  (and (vector? d) (= (count d) 2) (= (nth d 0) "#%string")))
(defn- jsq-sym? [d :- Any] :- Bool (string? d))
(defn- jsq-list? [d :- Any] :- Bool
  (and (vector? d) (> (count d) 0)
       (not (bracketed? d)) (not (map-tagged? d)) (not (set-tagged? d)) (not (jsq-strlit? d))))
(defn- jsq-splice-sym? [d :- Any] :- Bool
  (and (string? d) (> (count d) 1) (= (char-at d 0) "~")))

;; -> [kind name] where kind = "stmts" | "json" | "expr", name is the remaining datum
(defn- jsq-splice-kind [d :- String] :- Any
  (cond
    (and (> (count d) 2) (= (char-at d 1) "@")) ["stmts" (subs d 2)]
    (and (> (count d) 2) (= (char-at d 1) "%")) ["json" (subs d 2)]
    :else ["expr" (subs d 1)]))

;; recursion hubs (set by install-jsq!)
(def JSQ-EXPR-CELL :- Any (atom nil))
(def JSQ-STMT-CELL :- Any (atom nil))
(defn- pj-expr [d :- Any] :- Any (apply (deref JSQ-EXPR-CELL) [d]))
(defn- pj-stmt [d :- Any] :- Any (apply (deref JSQ-STMT-CELL) [d]))

(defn- pj-param-list [d :- Any] :- Any
  (let [items (cond (bracketed? d) (bracket-body d) (vector? d) d :else [])]
    (mapv (fn [item :- Any] :- Any
            (cond
              (jsq-sym? item) item
              (and (jsq-list? item) (= (count item) 2) (= (nth item 0) "spread"))
                {"spread" (nth item 1)}
              :else (do (err! (str "js/quote: parameter must be a symbol, got " (str item))) "_")))
          items)))

(defn- pj-block-body [stmts :- Any] :- Any
  (let [parsed (mapv (fn [s :- Any] :- Any (pj-stmt s)) stmts)]
    (if (= 1 (count parsed)) (nth parsed 0) {"jsk" "block" "stmts" parsed})))

(defn- pj-object-literal [items :- Any] :- Any
  (let [pairs (loop [rest items acc :- (Vec Any) []]
                (if (< (count rest) 2) acc
                  (recur (subvec rest 2)
                         (conj acc {"key" (pj-expr (nth rest 0)) "val" (pj-expr (nth rest 1))}))))]
    {"jsk" "object" "pairs" pairs}))

(defn- pj-call-or-member [d :- Any] :- Any
  (let [head (nth d 0)]
    (cond
      (and (jsq-sym? head) (dot-method-sym? head))
        (let [method-name (subs head 1)
              obj (pj-expr (nth d 1))
              args (mapv (fn [a :- Any] :- Any (pj-expr a)) (subvec d 2))]
          {"jsk" "call" "callee" {"jsk" "member" "object" obj "property" method-name "computed" false} "args" args})
      (jsq-splice-sym? head)
        (let [sk (jsq-splice-kind head)]
          {"jsk" "call" "callee" {"jsk" "splice-expr" "bexpr" (parse-expr* (nth sk 1))}
           "args" (mapv (fn [a :- Any] :- Any (pj-expr a)) (subvec d 1))})
      :else
        {"jsk" "call" "callee" (pj-expr head)
         "args" (mapv (fn [a :- Any] :- Any (pj-expr a)) (subvec d 1))})))

(defn- pj-list-expr [d :- Any] :- Any
  (let [h (nth d 0) n (count d)]
    (cond
      (and (= h "=>") (= n 3)) {"jsk" "arrow" "params" (pj-param-list (nth d 1)) "body" (pj-expr (nth d 2))}
      (and (= h "=>") (> n 3)) {"jsk" "arrow" "params" (pj-param-list (nth d 1)) "body" (pj-block-body (subvec d 2))}
      (and (= h "?") (= n 4)) {"jsk" "ternary" "test" (pj-expr (nth d 1)) "then" (pj-expr (nth d 2)) "else" (pj-expr (nth d 3))}
      (and (jsq-binary-op? h) (= n 3))
        {"jsk" "binary" "op" (get JSQ-BINARY-OPS h) "left" (pj-expr (nth d 1)) "right" (pj-expr (nth d 2))}
      (and (= h "!") (= n 2)) {"jsk" "unary" "op" "!" "expr" (pj-expr (nth d 1)) "prefix" true}
      (and (= h "typeof") (= n 2)) {"jsk" "typeof" "expr" (pj-expr (nth d 1))}
      (and (= h "void") (= n 2)) {"jsk" "unary" "op" "void" "expr" (pj-expr (nth d 1)) "prefix" true}
      (and (= h "delete") (= n 2)) {"jsk" "unary" "op" "delete" "expr" (pj-expr (nth d 1)) "prefix" true}
      (= h "new") {"jsk" "new" "callee" (pj-expr (nth d 1)) "args" (mapv (fn [a :- Any] :- Any (pj-expr a)) (subvec d 2))}
      (and (= h "await") (= n 2)) {"jsk" "await" "expr" (pj-expr (nth d 1))}
      (= h "tpl")
        {"jsk" "template" "parts"
         (mapv (fn [p :- Any] :- Any
                 (if (jsq-strlit? p) {"str" (extract-string p)} {"expr" (pj-expr p)})) (subvec d 1))}
      (and (= h "spread") (= n 2)) {"jsk" "spread" "expr" (pj-expr (nth d 1))}
      (= h "array") {"jsk" "array" "items" (mapv (fn [a :- Any] :- Any (pj-expr a)) (subvec d 1))}
      (= h "object") (pj-object-literal (subvec d 1))
      (and (= h "dot") (= n 3)) {"jsk" "member" "object" (pj-expr (nth d 1)) "property" (nth d 2) "computed" false}
      (and (= h "bracket") (= n 3)) {"jsk" "index" "object" (pj-expr (nth d 1)) "idx" (pj-expr (nth d 2))}
      :else (pj-call-or-member d))))

(defn- pj-expr-impl [d :- Any] :- Any
  (cond
    (jsq-strlit? d) {"jsk" "literal" "kind" "string" "value" (extract-string d)}
    (boolean? d) {"jsk" "literal" "kind" "bool" "value" d}
    (number? d) {"jsk" "literal" "kind" "number" "value" d}
    (= d "true") {"jsk" "literal" "kind" "bool" "value" true}
    (= d "false") {"jsk" "literal" "kind" "bool" "value" false}
    (= d "null") {"jsk" "literal" "kind" "null" "value" "null"}
    (= d "undefined") {"jsk" "literal" "kind" "undefined" "value" "undefined"}
    (= d "this") {"jsk" "ident" "name" "this"}
    (jsq-splice-sym? d)
      (let [sk (jsq-splice-kind d) kind (nth sk 0)]
        (cond
          (= kind "expr") {"jsk" "splice-expr" "bexpr" (parse-expr* (nth sk 1))}
          (= kind "json") {"jsk" "splice-json" "bexpr" (parse-expr* (nth sk 1))}
          :else (do (err! "js/quote: ~@splice not allowed in expression context") {"jsk" "ident" "name" "_"})))
    (jsq-sym? d) {"jsk" "ident" "name" d}
    (bracketed? d) {"jsk" "array" "items" (mapv (fn [x :- Any] :- Any (pj-expr x)) (bracket-body d))}
    (map-tagged? d) (pj-object-literal (map-body d))
    (jsq-list? d) (pj-list-expr d)
    :else (do (err! (str "js/quote: unsupported expression: " (str d))) {"jsk" "ident" "name" "_"})))

(defn- pj-function [rest :- Any async? :- Bool] :- Any
  (let [name-d (nth rest 0)
        params (pj-param-list (nth rest 1))
        body-forms (subvec rest 2)]
    {"jsk" "function" "name" name-d "params" params "body" (pj-block-body body-forms) "async" async? "export" false}))

(defn- pj-method-modifiers [d :- Any] :- Any
  ;; -> [static? async? kind rest]
  (let [head (nth d 0)]
    (cond
      (= head "constructor") [false false "constructor" (subvec d 1)]
      (= head "static") (let [r (pj-method-modifiers (subvec d 1))] [true (nth r 1) (nth r 2) (nth r 3)])
      (= head "async") (let [r (pj-method-modifiers (subvec d 1))] [(nth r 0) true (nth r 2) (nth r 3)])
      (= head "get") [false false "get" (subvec d 1)]
      (= head "set") [false false "set" (subvec d 1)]
      (= head "method") [false false "method" (subvec d 1)]
      (jsq-sym? head) [false false "method" d]
      :else (do (err! (str "js/quote method: unexpected modifier " (str head))) [false false "method" d]))))

(defn- pj-method [d :- Any] :- Any
  (let [mods (pj-method-modifiers d)
        static? (nth mods 0) async? (nth mods 1) kind (nth mods 2) rest (nth mods 3)]
    (if (= kind "constructor")
      {"jsk" "method" "name" "constructor" "params" (pj-param-list (nth rest 0))
       "body" (pj-block-body (subvec rest 1)) "static" static? "async" async? "kind" "constructor"}
      {"jsk" "method" "name" (nth rest 0) "params" (pj-param-list (nth rest 1))
       "body" (pj-block-body (subvec rest 2)) "static" static? "async" async? "kind" kind})))

(defn- pj-class [rest :- Any export? :- Bool] :- Any
  (let [name-d (nth rest 0)
        remaining (subvec rest 1)
        has-extends (and (> (count remaining) 0) (= (nth remaining 0) "extends") (> (count remaining) 1))
        extends-expr (if has-extends (pj-expr (nth remaining 1)) false)
        methods-raw (if has-extends (subvec remaining 2) remaining)]
    {"jsk" "class" "name" name-d "extends" extends-expr
     "methods" (mapv (fn [m :- Any] :- Any (pj-method m)) methods-raw) "export" export?}))

(defn- pj-try [rest :- Any] :- Any
  (let [split (loop [forms rest body-acc :- (Vec Any) []]
                (if (= 0 (count forms)) [body-acc []]
                  (let [f (nth forms 0)]
                    (if (and (jsq-list? f) (or (= (nth f 0) "catch") (= (nth f 0) "finally")))
                      [body-acc forms]
                      (recur (subvec forms 1) (conj body-acc f))))))
        body-forms (nth split 0)
        cf (nth split 1)]
    (loop [items cf catch-name false catch-body false finally-body false]
      (if (= 0 (count items))
        {"jsk" "try" "body" (pj-block-body body-forms) "catch-name" catch-name
         "catch-body" catch-body "finally-body" finally-body}
        (let [c (nth items 0)]
          (cond
            (= (nth c 0) "catch")
              (recur (subvec items 1) (nth c 1) (pj-block-body (subvec c 2)) finally-body)
            (= (nth c 0) "finally")
              (recur (subvec items 1) catch-name catch-body (pj-block-body (subvec c 1)))
            :else (do (err! "js/quote try: expected catch/finally") (recur (subvec items 1) catch-name catch-body finally-body))))))))

(defn- pj-split-if-else [body :- Any] :- Any
  (loop [rest body then-acc :- (Vec Any) []]
    (cond
      (= 0 (count rest)) [then-acc []]
      (= (nth rest 0) "else") [then-acc (subvec rest 1)]
      :else (recur (subvec rest 1) (conj then-acc (nth rest 0))))))

(defn- pj-export [inner :- Any] :- Any
  (cond
    (and (jsq-list? inner) (= (nth inner 0) "function"))
      (assoc (pj-function (subvec inner 1) false) "export" true)
    (and (jsq-list? inner) (= (nth inner 0) "async"))
      (let [rest-items (subvec inner 1)]
        (cond
          (and (> (count rest-items) 0) (jsq-list? (nth rest-items 0)) (= (nth (nth rest-items 0) 0) "function"))
            (assoc (pj-function (subvec (nth rest-items 0) 1) true) "export" true)
          (and (> (count rest-items) 0) (= (nth rest-items 0) "function"))
            (assoc (pj-function (subvec rest-items 1) true) "export" true)
          :else (do (err! "js/quote: export async must be followed by function") {"jsk" "block" "stmts" []})))
    (and (jsq-list? inner) (= (nth inner 0) "class"))
      (pj-class (subvec inner 1) true)
    :else (do (err! (str "js/quote: export requires function/async function/class, got " (str inner)))
              {"jsk" "block" "stmts" []})))

(defn- pj-list-stmt [d :- Any] :- Any
  (let [h (nth d 0) n (count d)]
    (cond
      (and (= h "const") (= n 3) (jsq-sym? (nth d 1))) {"jsk" "const" "name" (nth d 1) "value" (pj-expr (nth d 2))}
      (and (= h "let") (= n 3) (jsq-sym? (nth d 1))) {"jsk" "let" "name" (nth d 1) "value" (pj-expr (nth d 2))}
      (and (= h "=") (= n 3)) {"jsk" "assign" "target" (pj-expr (nth d 1)) "value" (pj-expr (nth d 2))}
      (and (jsq-assign-op? h) (= n 3))
        {"jsk" "assign" "target" (pj-expr (nth d 1))
         "value" {"jsk" "binary" "op" (jsq-strip-assign-op h) "left" (pj-expr (nth d 1)) "right" (pj-expr (nth d 2))}}
      (and (= h "return") (= n 1)) {"jsk" "return" "expr" false}
      (and (= h "return") (= n 2)) {"jsk" "return" "expr" (pj-expr (nth d 1))}
      (and (= h "if") (= n 3)) {"jsk" "if" "test" (pj-expr (nth d 1)) "then" (pj-block-body [(nth d 2)]) "else" false}
      (and (= h "if") (= n 4)) {"jsk" "if" "test" (pj-expr (nth d 1)) "then" (pj-block-body [(nth d 2)]) "else" (pj-block-body [(nth d 3)])}
      (and (= h "if") (> n 4))
        (let [sp (pj-split-if-else (subvec d 2))]
          {"jsk" "if" "test" (pj-expr (nth d 1)) "then" (pj-block-body (nth sp 0))
           "else" (if (= 0 (count (nth sp 1))) false (pj-block-body (nth sp 1)))})
      (and (= h "for-of") (jsq-sym? (nth d 1)))
        {"jsk" "for-of" "binding" (nth d 1) "iterable" (pj-expr (nth d 2)) "body" (pj-block-body (subvec d 3))}
      (= h "while") {"jsk" "while" "test" (pj-expr (nth d 1)) "body" (pj-block-body (subvec d 2))}
      (and (= h "throw") (= n 2)) {"jsk" "throw" "expr" (pj-expr (nth d 1))}
      (= h "try") (pj-try (subvec d 1))
      (and (= h "export") (= n 2)) (pj-export (nth d 1))
      (and (= h "async") (> n 1) (= (nth d 1) "function")) (pj-function (subvec d 2) true)
      (and (= h "async") (= n 2)) (pj-function (subvec (nth d 1) 1) true)
      (= h "function") (pj-function (subvec d 1) false)
      (= h "class") (pj-class (subvec d 1) false)
      (and (jsq-binary-op? h) (= n 3))
        {"jsk" "expr-stmt" "expr" {"jsk" "binary" "op" (get JSQ-BINARY-OPS h) "left" (pj-expr (nth d 1)) "right" (pj-expr (nth d 2))}}
      (and (jsq-sym? h) (not (jsq-splice-sym? h))) {"jsk" "expr-stmt" "expr" (pj-call-or-member d)}
      :else {"jsk" "expr-stmt" "expr" (pj-expr d)})))

(defn- pj-stmt-impl [d :- Any] :- Any
  (cond
    (jsq-list? d) (pj-list-stmt d)
    (jsq-splice-sym? d)
      (let [sk (jsq-splice-kind d) kind (nth sk 0)]
        (cond
          (= kind "stmts") {"jsk" "splice-stmts" "bexpr" (parse-expr* (nth sk 1))}
          (= kind "expr") {"jsk" "expr-stmt" "expr" {"jsk" "splice-expr" "bexpr" (parse-expr* (nth sk 1))}}
          :else {"jsk" "expr-stmt" "expr" {"jsk" "splice-json" "bexpr" (parse-expr* (nth sk 1))}}))
    :else {"jsk" "expr-stmt" "expr" (pj-expr d)}))

(defn- install-jsq! [] :- Nil
  (reset! JSQ-EXPR-CELL pj-expr-impl)
  (reset! JSQ-STMT-CELL pj-stmt-impl)
  nil)

(defn- pj-body [forms :- Any] :- Any
  (install-jsq!)
  (cond
    (= 0 (count forms)) {"jsk" "block" "stmts" []}
    (= 1 (count forms)) (pj-stmt (nth forms 0))
    :else {"jsk" "block" "stmts" (mapv (fn [f :- Any] :- Any (pj-stmt f)) forms)}))

(defn parse-list-form! [d :- Any] :- Any
  (let [head (nth d 0)
        rest-items (subvec d 1)]
    (cond
      ;; user macro in head position — macros outrank built-in forms outrank
      ;; legacy (parse.rkt head-meaning); expand fully, parse the expansion
      (and (string? head)
           (some? (deref CURRENT-REGISTRY-CELL))
           (mac/macro-application? (deref CURRENT-REGISTRY-CELL) d))
        (parse-expr* (mac/expand-fully! (deref CURRENT-REGISTRY-CELL) d 0 nil))

      ;; zero escape hatches: unsafe-* rejected at parse (today's surface)
      (and (string? head) (= head "unsafe"))
        (err! "(unsafe \"...\") is not supported — beagle has no verbatim escape hatch; add a typed stdlib entry or a sibling target-language file instead")
      (and (string? head) (str/starts-with? head "unsafe-"))
        (err! (str "(" head " \"...\") is not supported — beagle has no verbatim escape hatch; add a typed stdlib entry or a sibling target-language file instead"))

      ;; (fmt ...) removed — pointed error
      (= head "fmt")
        (err! "(fmt ...) is not supported — use str / format")

      ;; js/quote: structural JS quasiquotation -> js-ast JSON (emit-js renders it)
      (= head "js/quote")
        {"node" "js-quote" "body" (pj-body rest-items)}

      ;; def: (def name :- TYPE ["doc"] value) | (def name ["doc"] value)
      (= head "def")
        (parse-def-form! "def" rest-items)
      (= head "defonce")
        (parse-def-form! "defonce" rest-items)

      ;; defn / defn- with optional docstring (stripped; not serialized)
      (and (= head "defn") (>= (count rest-items) 2))
        (let [name-form (nth rest-items 0)
              priv0 false]
          (cond
            (and (string? name-form) (not (keyword-sym? name-form))
                 (string-datum? (nth rest-items 1)) (>= (count rest-items) 3)
                 (vector? (nth rest-items 1)))
              (parse-defn-tail! name-form (subvec rest-items 2) priv0)
            (meta-name? name-form)
              (parse-defn-tail! (nth name-form 2) (subvec rest-items 1) true)
            (string? name-form)
              ;; docstring after name? ["#%string" s]
              (if (and (>= (count rest-items) 3)
                       (vector? (nth rest-items 1))
                       (= (count (nth rest-items 1)) 2)
                       (= (nth (nth rest-items 1) 0) "#%string"))
                (parse-defn-tail! name-form (subvec rest-items 2) priv0)
                (parse-defn-tail! name-form (subvec rest-items 1) priv0))
            :else (err! (str "malformed defn: " (str d)))))

      (and (= head "defn-") (>= (count rest-items) 2))
        (cond
          (meta-name? (nth rest-items 0))
            (parse-defn-tail! (nth (nth rest-items 0) 2) (subvec rest-items 1) true)
          (string? (nth rest-items 0))
            (if (and (>= (count rest-items) 3)
                     (vector? (nth rest-items 1))
                     (= (count (nth rest-items 1)) 2)
                     (= (nth (nth rest-items 1) 0) "#%string"))
              (parse-defn-tail! (nth rest-items 0) (subvec rest-items 2) true)
              (parse-defn-tail! (nth rest-items 0) (subvec rest-items 1) true))
          :else (err! (str "malformed defn-: " (str d))))

      ;; defrecord: (defrecord Name [fields])
      (and (= head "defrecord") (= (count rest-items) 2))
        (make-defrecord (nth rest-items 0) (parse-record-fields! (nth rest-items 1)))

      (and (= head "defenum") (>= (count rest-items) 1))
        (make-defenum (nth rest-items 0) (subvec rest-items 1))

      ;; defunion — parametric (defunion (Name T E) ...) or simple
      (and (= head "defunion") (>= (count rest-items) 1)
           (vector? (nth rest-items 0)) (not (bracketed? (nth rest-items 0))))
        (let [name-form (nth rest-items 0)]
          (if (and (>= (count name-form) 2) (string? (nth name-form 0)))
            (parse-parametric-defunion! (nth name-form 0)
              (subvec name-form 1) (subvec rest-items 1))
            (parse-simple-defunion (nth rest-items 0) (subvec rest-items 1))))
      (and (= head "defunion") (>= (count rest-items) 1)
           (string? (nth rest-items 0)))
        (parse-simple-defunion (nth rest-items 0) (subvec rest-items 1))

      (and (= head "deferror") (>= (count rest-items) 1))
        (parse-deferror-form (nth rest-items 0) (subvec rest-items 1))

      (and (= head "defscalar") (>= (count rest-items) 2))
        (make-defscalar (nth rest-items 0) (parse-type (nth rest-items 1)))

      ;; fn with return type
      ;; multi-arity anonymous fn — list-wrapped or bare-vector — is rejected
      ;; with the pointed defn migration (parse.rkt fn arms, detected FIRST)
      (and (= head "fn") (>= (count rest-items) 1)
           (or (multi-arity-form? (nth rest-items 0))
               (some? (bare-multi-arity-clauses rest-items))))
        (err! "multi-arity anonymous `fn` is not yet supported — give it a name with `defn` (which supports multi-arity), or use a single arity.")
      ;; fn retains legacy `:` return marker acceptance (parse.rkt fn arm) —
      ;; nix fixtures use `(fn [params] : Any body)`; clj uses `:-`.
      (and (= head "fn") (>= (count rest-items) 3)
           (annotation-marker? (nth rest-items 1)))
        (let [parsed-params (parse-params! (nth rest-items 0))]
          (make-fn (get parsed-params "params")
                   (get parsed-params "rest-param")
                   (parse-type (nth rest-items 2))
                   (mapv parse-expr* (subvec rest-items 3))))
      (and (= head "fn") (>= (count rest-items) 1))
        (let [parsed-params (parse-params! (nth rest-items 0))]
          (make-fn (get parsed-params "params")
                   (get parsed-params "rest-param")
                   nil
                   (mapv parse-expr* (subvec rest-items 1))))

      (and (= head "let") (>= (count rest-items) 1))
        (make-let (parse-let-bindings! (nth rest-items 0))
                  (mapv parse-expr* (subvec rest-items 1)))

      ;; binding: dynamic-var rebinding; bindings share the let-binding shape.
      (and (= head "binding") (>= (count rest-items) 1))
        {"node" "binding"
         "bindings" (parse-let-bindings! (nth rest-items 0))
         "body" (mapv parse-expr* (subvec rest-items 1))}
      (= head "binding")
        (err! (str "malformed binding — expected (binding [*var* val ...] body...); got: " (str d)))

      (and (= head "letfn") (>= (count rest-items) 1))
        (make-letfn (parse-letfn-fns! (nth rest-items 0))
                    (mapv parse-expr* (subvec rest-items 1)))

      (and (= head "loop") (>= (count rest-items) 1))
        (make-loop (parse-let-bindings! (nth rest-items 0))
                   (mapv parse-expr* (subvec rest-items 1)))

      (= head "recur")
        (make-recur (mapv parse-expr* rest-items))

      (and (= head "await") (= (count rest-items) 1))
        (make-await (parse-expr* (nth rest-items 0)))

      (and (= head "set!") (= (count rest-items) 2))
        (make-set! (parse-expr* (nth rest-items 0)) (parse-expr* (nth rest-items 1)))

      (and (= head "for") (>= (count rest-items) 1))
        (make-for (parse-for-clauses (nth rest-items 0))
                  (mapv parse-expr* (subvec rest-items 1)))

      (and (= head "if") (= (count rest-items) 3))
        (make-if (parse-expr* (nth rest-items 0))
                 (parse-expr* (nth rest-items 1))
                 (parse-expr* (nth rest-items 2)))
      (and (= head "if") (= (count rest-items) 2))
        (make-if (parse-expr* (nth rest-items 0))
                 (parse-expr* (nth rest-items 1))
                 nil)

      ;; Sugar canonicalization (parse.rkt combiners): when/when-not/if-not
      ;; and the binding-conditional family REWRITE to if/let/do datums and
      ;; reparse — when-form/if-let-form etc. never appear in a source AST.
      (and (= head "when") (>= (count rest-items) 2))
        (parse-expr* ["if" (nth rest-items 0)
                      (vec (concat ["do"] (subvec rest-items 1)))])
      (= head "when")
        (err! "when requires at least one body expression: (when c body...)")

      (and (= head "when-not") (>= (count rest-items) 2))
        (parse-expr* ["if" ["not" (nth rest-items 0)]
                      (vec (concat ["do"] (subvec rest-items 1)))])
      (= head "when-not")
        (err! "when-not requires at least one body expression: (when-not c body...)")

      (and (= head "if-not") (= (count rest-items) 3))
        (parse-expr* ["if" (nth rest-items 0) (nth rest-items 2) (nth rest-items 1)])
      (= head "if-not")
        (err! "if-not expects (if-not c then else): three arguments required")

      (and (= head "when-let") (>= (count rest-items) 2))
        (parse-expr* (lower-binding-cond! "when-let" (nth rest-items 0)
                                         (subvec rest-items 1)))
      (and (= head "if-let") (= (count rest-items) 3))
        (parse-expr* (lower-binding-cond! "if-let" (nth rest-items 0)
                                         (subvec rest-items 1)))
      (and (= head "when-some") (>= (count rest-items) 2))
        (parse-expr* (lower-binding-cond! "when-some" (nth rest-items 0)
                                         (subvec rest-items 1)))
      (and (= head "if-some") (= (count rest-items) 3))
        (parse-expr* (lower-binding-cond! "if-some" (nth rest-items 0)
                                         (subvec rest-items 1)))

      (= head "comment") NIL-LITERAL

      (= head "do")
        (make-do (mapv parse-expr* rest-items))

      (= head "cond")
        (make-cond (parse-cond-clauses rest-items))

      (and (= head "condp") (>= (count rest-items) 2))
        (parse-condp-form (nth rest-items 0)
                          (nth rest-items 1)
                          (subvec rest-items 2))

      (= head "try")
        (parse-try-form rest-items)

      (and (= head "match") (>= (count rest-items) 1))
        (parse-match-form (nth rest-items 0) (subvec rest-items 1))

      ;; `case` removed — folded into match + or-pattern. Pointed rejection.
      (= head "case")
        (err! "case removed — use (match x [v1 body] [v2 body] [_ default]) or (match x [(or v1 v2) shared-body] [_ default]); literal-only matches case-fold to target-native dispatch in emit")

      ;; per-target branch selection
      (= head "target-case")
        (parse-target-case! rest-items)

      (and (= head "doseq") (>= (count rest-items) 1))
        (make-doseq (parse-for-clauses (nth rest-items 0))
                    (mapv parse-expr* (subvec rest-items 1)))

      ;; `dotimes` removed — sugar for (doseq [i (range n)] body...). Pointed rejection.
      (= head "dotimes")
        (err! "dotimes removed — use (doseq [i (range n)] body...)")

      ;; bare `with` is nix-prefixed today; the record-update `with` form
      ;; remains under this head in the AST (ast-json with-form).
      (and (= head "with") (>= (count rest-items) 1))
        (parse-with-form (nth rest-items 0) (subvec rest-items 1))

      ;; --- nix-specific forms (parse.rkt L2486-3153; ast-json.rkt L466-543) ---

      ;; (s PART ...) -> nix-interpolated-string; string datums are text parts,
      ;; everything else parses as an expr part.
      (= head "s")
        (make-nix-interpolated-string
          (mapv (fn [part :- Any] :- Any
                  (if (string-literal-datum? part)
                    {"type" "text" "value" (extract-string part)}
                    {"type" "expr" "value" (parse-expr* part)}))
                rest-items))

      ;; (ms LINE ...) -> nix-multiline-string; string lines are text, nested
      ;; (s ...) lines serialize as "interp" (their parts inline), else "expr".
      (= head "ms")
        (make-nix-multiline-string
          (mapv (fn [line :- Any] :- Any
                  (if (string-literal-datum? line)
                    {"type" "text" "value" (extract-string line)}
                    (let [e (parse-expr* line)]
                      (if (= (get e "node") "nix-interpolated-string")
                        {"type" "interp" "parts" (get e "parts")}
                        {"type" "expr" "value" e}))))
                rest-items))

      ;; (p "./path") -> nix-path (string or bare-symbol path)
      (and (= head "p") (= (count rest-items) 1))
        (let [pd (nth rest-items 0)]
          (cond
            (string-datum? pd) (make-nix-path (extract-string pd))
            (string? pd) (make-nix-path pd)
            :else (err! "p: expected string or symbol")))

      ;; (inherit name ...) -> nix-inherit
      (= head "inherit")
        (make-nix-inherit
          (mapv (fn [n :- Any] :- Any
                  (if (string? n) n
                    (do (err! "inherit: expected symbol") (str n))))
                rest-items))

      ;; (inherit-from (ns) name ...) -> nix-inherit-from
      (and (= head "inherit-from") (>= (count rest-items) 1))
        (make-nix-inherit-from
          (parse-expr* (nth rest-items 0))
          (mapv (fn [n :- Any] :- Any
                  (if (string? n) n
                    (do (err! "inherit-from: expected symbol") (str n))))
                (subvec rest-items 1)))

      ;; (rec-attrs k v ...) -> nix-rec-attrs
      (= head "rec-attrs")
        (make-nix-rec-attrs (parse-nix-rec-pairs! rest-items))

      ;; (search-path name) -> nix-search-path
      (and (= head "search-path") (= (count rest-items) 1))
        (let [d (nth rest-items 0)]
          (make-nix-search-path (if (string-datum? d) (extract-string d) (str d))))

      ;; (get-or base path default) -> nix-get-or; path from symbol/quoted-sym
      (and (= head "get-or") (= (count rest-items) 3))
        (make-nix-get-or
          (parse-expr* (nth rest-items 0))
          (let [pd (nth rest-items 1)]
            (cond
              (string? pd) pd
              (and (vector? pd) (> (count pd) 1) (= (nth pd 0) "quote")) (str (nth pd 1))
              :else (str pd)))
          (parse-expr* (nth rest-items 2)))

      ;; (nix/assert COND BODY) -> nix-assert
      (and (= head "nix/assert") (= (count rest-items) 2))
        (make-nix-assert (parse-expr* (nth rest-items 0)) (parse-expr* (nth rest-items 1)))

      ;; (nix/with NS BODY) -> nix-with
      (and (= head "nix/with") (= (count rest-items) 2))
        (make-nix-with (parse-expr* (nth rest-items 0)) (parse-expr* (nth rest-items 1)))

      ;; (nix/module FORMALS BODY) -> nix-fn-set with rest=true (open attrs)
      (and (= head "nix/module") (= (count rest-items) 2))
        (let [fl (parse-nix-fn-set-formals! (nth rest-items 0))]
          (make-nix-fn-set (get fl "formals") true (get fl "at-name")
                           (parse-expr* (nth rest-items 1))))

      ;; (nix/fn-set FORMALS BODY) -> nix-fn-set with rest=false (closed attrs)
      (and (= head "nix/fn-set") (= (count rest-items) 2))
        (let [fl (parse-nix-fn-set-formals! (nth rest-items 0))]
          (make-nix-fn-set (get fl "formals") false (get fl "at-name")
                           (parse-expr* (nth rest-items 1))))

      ;; (nix/overlay [final prev] BODY) -> curried fn-form (final: prev: body)
      (and (= head "nix/overlay") (= (count rest-items) 2))
        (let [fl (parse-nix-fn-set-formals! (nth rest-items 0))
              formals (get fl "formals")]
          (if (not= (count formals) 2)
            (err! "nix/overlay: expected exactly two formals [final prev]")
            (make-fn (mapv (fn [f :- Any] :- Any (make-param (get f "name") nil)) formals)
                     nil nil
                     [(parse-expr* (nth rest-items 1))])))

      ;; (nix/with-cfg PATH BODY) -> nix-with-cfg (oracle serializes as unknown)
      (and (= head "nix/with-cfg") (= (count rest-items) 2))
        (make-nix-with-cfg (parse-expr* (nth rest-items 0)) (parse-expr* (nth rest-items 1)))

      ;; (nix/derivation ATTRS) -> nix-derivation (oracle serializes as unknown)
      (and (= head "nix/derivation") (= (count rest-items) 1))
        (make-nix-derivation (parse-expr* (nth rest-items 0)))

      ;; (nix/flake ATTRS) -> nix-flake (oracle serializes as unknown)
      (and (= head "nix/flake") (= (count rest-items) 1))
        (make-nix-flake (parse-expr* (nth rest-items 0)))

      ;; (flake-input :input :ns seg ...) -> flake-input (oracle serializes as unknown)
      (and (= head "flake-input") (>= (count rest-items) 2))
        (make-flake-input (nth rest-items 0) (nth rest-items 1)
                          (mapv (fn [s :- Any] :- Any (str s)) (subvec rest-items 2)))

      ;; bare nix forms are HARD-REJECTED — point at the nix/-prefixed spelling
      (and (= head "assert") (= (count rest-items) 2))
        (err! "(assert ...) — bare `assert` is not supported. Use `(nix/assert COND BODY)`.")
      (and (= head "with-cfg") (= (count rest-items) 2))
        (err! "(with-cfg ...) — bare `with-cfg` is not supported. Use `(nix/with-cfg PATH BODY)`.")
      (and (= head "overlay") (= (count rest-items) 2))
        (err! "(overlay ...) — bare `overlay` is not supported. Use `(nix/overlay [final prev] BODY)`.")
      (and (= head "derivation") (= (count rest-items) 1))
        (err! "(derivation ...) — bare `derivation` is not supported. Use `(nix/derivation ATTRS)`.")
      (and (= head "flake") (= (count rest-items) 1))
        (err! "(flake ...) — bare `flake` is not supported. Use `(nix/flake ATTRS)`.")
      (and (= head "fn-set") (= (count rest-items) 2))
        (err! "(fn-set ...) — bare `fn-set` is not supported. Use `(nix/fn-set FORMALS BODY)`.")
      (and (= head "module") (= (count rest-items) 2))
        (err! "(module ...) — bare `module` is not supported. Use `(nix/module FORMALS BODY)`.")

      ;; threading — desugars to let/if/call composition, wrapped in a
      ;; threading node so emit-clj reconstructs the surface form (parse.rkt
      ;; threading-marker; ast-json node "threading"). Racket evaluates the
      ;; marker's fields left-to-right: orig args parse FIRST (minting any
      ;; nested temps), THEN the desugar mints its temps, THEN the desugared
      ;; datum re-parses (minting nested temps again) — the let orders below
      ;; preserve that counter sequence exactly.
      (and (= head "->") (>= (count rest-items) 1))
        (let [args (mapv parse-expr* rest-items)]
          (make-threading "->" args
            (parse-expr* (expand-thread-first (nth rest-items 0) (subvec rest-items 1)))))
      (and (= head "->>") (>= (count rest-items) 1))
        (let [args (mapv parse-expr* rest-items)]
          (make-threading "->>" args
            (parse-expr* (expand-thread-last (nth rest-items 0) (subvec rest-items 1)))))
      (and (= head "cond->") (>= (count rest-items) 1))
        (let [args (mapv parse-expr* rest-items)]
          (make-threading "cond->" args
            (parse-expr* (expand-cond-thread "cond->" (nth rest-items 0) (subvec rest-items 1)))))
      (and (= head "cond->>") (>= (count rest-items) 1))
        (let [args (mapv parse-expr* rest-items)]
          (make-threading "cond->>" args
            (parse-expr* (expand-cond-thread "cond->>" (nth rest-items 0) (subvec rest-items 1)))))
      (and (= head "some->") (>= (count rest-items) 1))
        (let [args (mapv parse-expr* rest-items)]
          (make-threading "some->" args
            (parse-expr* (expand-some-thread "some->" (nth rest-items 0) (subvec rest-items 1)))))
      (and (= head "some->>") (>= (count rest-items) 1))
        (let [args (mapv parse-expr* rest-items)]
          (make-threading "some->>" args
            (parse-expr* (expand-some-thread "some->>" (nth rest-items 0) (subvec rest-items 1)))))
      (and (= head "as->") (>= (count rest-items) 2) (string? (nth rest-items 1)))
        (let [args (mapv parse-expr* rest-items)]
          (make-threading "as->" args
            (parse-expr* (expand-as-thread (nth rest-items 0) (nth rest-items 1)
                                           (subvec rest-items 2)))))
      (and (= head "as->") (>= (count rest-items) 2))
        (err! "as-> expects a symbol placeholder: (as-> init name steps...)")

      ;; (get m :k) / (get m :k default) — literal-keyword-key projection
      ;; canonicalizes to kw-access, same AST as (:k m) (parse.rkt get
      ;; combiner); dynamic/non-keyword keys fall through to call-form
      (and (= head "get") (= (count rest-items) 2)
           (string? (nth rest-items 1)) (keyword-sym? (nth rest-items 1)))
        (make-kw-access (nth rest-items 1) (parse-expr* (nth rest-items 0)) nil)
      (and (= head "get") (= (count rest-items) 3)
           (string? (nth rest-items 1)) (keyword-sym? (nth rest-items 1)))
        (make-kw-access (nth rest-items 1)
                        (parse-expr* (nth rest-items 0))
                        (parse-expr* (nth rest-items 2)))

      ;; constructor: (Type. args...)
      (and (string? head) (constructor-sym? head))
        (make-new head (mapv parse-expr* rest-items))

      ;; keyword access: (:key target) / (:key target default)
      (and (string? head) (keyword-sym? head) (>= (count rest-items) 1))
        (make-kw-access head (parse-expr* (nth rest-items 0))
                        (if (>= (count rest-items) 2)
                          (parse-expr* (nth rest-items 1)) nil))

      ;; method call: (.method target args...)
      (and (string? head) (dot-method-sym? head) (>= (count rest-items) 1))
        (make-method-call head (parse-expr* (nth rest-items 0))
                          (mapv parse-expr* (subvec rest-items 1)))

      ;; static call: (Class/method args...) / (js/foo args...)
      (and (string? head) (static-method-sym? head))
        (make-static-call head (mapv parse-expr* rest-items))

      ;; generic call
      (string? head)
        (make-call (make-ref head) (mapv parse-expr* rest-items))

      ;; call with computed function
      (vector? head)
        (make-call (parse-expr* head) (mapv parse-expr* rest-items))

      :else NIL-LITERAL)))


;; --- parse-expr!: the main dispatch -------------------------------------------

(defn parse-expr! [d :- Any] :- Any
  (cond
    (nil? d) NIL-LITERAL
    ;; Bare true/false in source are SYMBOLS to the Racket reader and parse
    ;; to refs (ast-json oracle: {"node":"ref","name":"true"}); boolean-typed
    ;; datums (hand-built ASTs, JSON round-trips) normalize to the same refs.
    (boolean? d) (make-ref (if d "true" "false"))
    (and (number? d) (int? d)) (make-literal "number" d)
    (number? d) (make-literal "float" d)

    ;; char literal: [#%char code] — code is the Unicode code point (Int).
    ;; emit-clj canonicalizes via emit-char-lit (mirrors oracle emit-clj-char).
    (and (vector? d) (= (count d) 2) (= (nth d 0) CHAR-TAG))
      (make-literal "char" (nth d 1))

    ;; string literal: [#%string value]
    (and (vector? d) (= (count d) 2) (= (nth d 0) "#%string"))
      (make-literal "string" (nth d 1))

    (and (string? d) (= d "nil")) NIL-LITERAL

    (and (string? d) (keyword-sym? d))
      (make-literal "keyword" (subs d 1))

    (and (string? d) (dynamic-var-sym? d))
      (make-dynamic-var d)

    (string? d) (make-ref d)

    (and (vector? d) (= (count d) 2) (= (nth d 0) "#%regex"))
      (make-regex (nth d 1))

    (bracketed? d)
      (make-vec (mapv parse-expr* (bracket-body d)))

    (map-tagged? d)
      (parse-map-literal (map-body d))

    (set-tagged? d)
      (make-set-form (mapv parse-expr* (set-body d)))

    (and (vector? d) (= (count d) 2) (= (nth d 0) "quote"))
      (make-quoted (datum->json (nth d 1)))

    (and (vector? d) (> (count d) 0))
      (parse-list-form! d)

    :else NIL-LITERAL))


(reset! PARSE-EXPR-CELL parse-expr!)

;; --- meta-form? --------------------------------------------------------------

(defn meta-form? [d :- Any] :- Bool
  (and (vector? d) (not (bracketed? d)) (> (count d) 0)
       (has-item? META-FORMS (nth d 0))))

;; --- require libspec registration ---------------------------------------------
;; libspec: lib | [lib] | [lib :as a] | [lib :refer [syms]] | [lib :as a :refer [syms]]
;; possibly quoted. Returns {"ns" .. "alias" ..|false "refer" [..]|false} or nil.

(defn- parse-require-libspec! [spec :- Any] :- Any
  (let [unq (if (and (vector? spec) (= (count spec) 2) (= (nth spec 0) "quote"))
              (nth spec 1)
              spec)]
    (cond
      (string? unq)
        {"ns" unq "alias" false "refer" false}
      (bracketed? unq)
        (let [items (bracket-body unq)]
          (if (and (> (count items) 0) (string? (nth items 0)))
            (let [rn (nth items 0)
                  n (count items)]
              (loop [i 1 alias :- Any false refer :- Any false]
                (cond
                  (>= i n) {"ns" rn "alias" alias "refer" refer}
                  (and (= (nth items i) ":as") (< (+ i 1) n) (string? (nth items (+ i 1))))
                    (recur (+ i 2) (nth items (+ i 1)) refer)
                  (and (= (nth items i) ":refer") (< (+ i 1) n)
                       (bracketed? (nth items (+ i 1))))
                    (recur (+ i 2) alias (bracket-body (nth items (+ i 1))))
                  :else
                    (do (err! (str "require: unsupported libspec option " (str (nth items i)) " — supported: [lib], [lib :as alias], [lib :refer [syms]], [lib :as alias :refer [syms]]"))
                        {"ns" rn "alias" alias "refer" refer}))))
            (do (err! (str "require: libspec must start with a namespace symbol, got: " (str unq)))
                nil)))
      :else
        (do (err! (str "require: bad libspec " (str unq) " — expected a namespace symbol or [lib :as alias] / [lib :refer [syms]]"))
            nil))))

;; --- parse-program! -----------------------------------------------------------

(defn parse-program! [datums :- Any] :- Any
  (reset-errors!)
  ;; Fresh lowering-temp counter per program (parse.rkt parameterizes
  ;; lowering-counter here): minted names depend only on THIS module's
  ;; content, never on what the process parsed before it. The counter lives
  ;; in selfhost.macros — shared with macro-hygiene renames, as in Racket.
  (mac/reset-lowering-counter!)
  (reset! CURRENT-REGISTRY-CELL (mac/make-macro-registry))
  (let [mode (atom "strict")
        mode-set (atom false)
        namespace (atom "beagle.user")
        ns-set (atom false)
        target (atom "clj")
        target-set (atom false)
        extern-seen (atom {})
        extern-list (atom [])
        requires (atom [])
        gen-class (atom false)
        forms (atom [])]
    ;; Pre-scan: register parametric defunion names for parse-type.
    (doseq [d datums]
      (when (and (vector? d) (not (bracketed? d)) (>= (count d) 2)
                 (= (nth d 0) "defunion")
                 (vector? (nth d 1)) (not (bracketed? (nth d 1)))
                 (> (count (nth d 1)) 0) (string? (nth (nth d 1) 0)))
        (swap! USER-PARAMETRIC assoc (nth (nth d 1) 0) true)))
    ;; Pre-scan: defalias registration in source order.
    (doseq [d datums]
      (when (and (vector? d) (not (bracketed? d)) (= (count d) 3)
                 (= (nth d 0) "defalias") (string? (nth d 1)))
        (swap! TYPE-ALIASES assoc (nth d 1) (parse-type (nth d 2)))))
    ;; Pass 1: meta forms.
    (doseq [d datums]
      (when (and (vector? d) (not (bracketed? d)) (>= (count d) 2))
        (let [head (nth d 0)]
          (cond
            (= head "define-mode")
              (do (when (deref mode-set)
                    (err! "duplicate define-mode"))
                  (if (or (= (nth d 1) "strict") (= (nth d 1) "dynamic"))
                    (reset! mode (nth d 1))
                    (err! (str "unknown mode: " (str (nth d 1)) " (expected strict or dynamic)")))
                  (reset! mode-set true))
            (= head "define-target")
              (do (when (deref target-set)
                    (err! "duplicate define-target"))
                  (if (has-item? ["clj" "cljs" "js" "nix" "py" "rkt" "zig" "odin"] (nth d 1))
                    (reset! target (nth d 1))
                    (err! (str "unknown target: " (str (nth d 1)))))
                  (reset! target-set true))
            (= head "ns")
              (do (when (deref ns-set)
                    (err! "duplicate ns form"))
                  (reset! namespace (nth d 1))
                  (reset! ns-set true)
                  ;; ns clauses: docstring (dropped), (:require ...), (:import ...)
                  (doseq [clause (subvec d 2)]
                    (cond
                      (string-datum? clause) nil
                      (and (vector? clause) (> (count clause) 0)
                           (= (nth clause 0) ":require"))
                        (doseq [spec (subvec clause 1)]
                          (let [r (parse-require-libspec! spec)]
                            (when (some? r) (swap! requires conj r))))
                      (and (vector? clause) (> (count clause) 0)
                           (= (nth clause 0) ":import"))
                        nil
                      (and (vector? clause) (> (count clause) 0)
                           (= (nth clause 0) ":gen-class"))
                        (do (reset! gen-class true) nil)
                      (and (vector? clause) (> (count clause) 0)
                           (= (nth clause 0) ":use"))
                        (do (err! (str "(ns " (nth d 1) " (:use ...)) — :use is not supported. Use (:require [lib :refer [sym ...]]) instead.")) nil)
                      :else
                        (do (err! (str "(ns " (nth d 1) " ...): unsupported ns clause " (str clause))) nil))))
            (= head "define-macro")
              (do (err! "(define-macro ...) — `define-macro` is not supported. Use `(defmacro NAME [params] body)` instead.") nil)
            ;; defmacro registers with the expander kernel (selfhost.macros);
            ;; pass 2 expands applications in-chain (parse.rkt pass 1).
            (= head "defmacro")
              (if (and (= (count d) 4) (string? (nth d 1))
                       (or (bracketed? (nth d 2))
                           (vector? (nth d 2))))
                (mac/register-macro! (deref CURRENT-REGISTRY-CELL)
                                     (nth d 1) "defmacro"
                                     (unwrap-items (nth d 2))
                                     (nth d 3))
                (do (err! (str "malformed defmacro — expected (defmacro NAME [params] template) with exactly one template form; wrap multiple forms in `(do ...)`, got: " (str d)))
                    nil))
            (= head "defalias") nil
            (= head "declare-extern")
              (if (>= (count d) 3)
                (let [name-form (nth d 1)
                      t (parse-type (nth d 2))
                      add-extern! (fn [nm :- Any] :- Nil
                                    (if (some? (get (deref extern-seen) nm))
                                      (do (err! (str "duplicate declare-extern: " nm)) nil)
                                      (do (swap! extern-seen assoc nm true)
                                          (swap! extern-list conj {"name" nm "type" t})
                                          nil)))]
                  (if (bracketed? name-form)
                    (doseq [nm (bracket-body name-form)]
                      (add-extern! nm))
                    (add-extern! name-form)))
                (err! "malformed declare-extern — expected (declare-extern name TYPE) or (declare-extern [name1 name2 ...] TYPE)"))
            (= head "require")
              (let [specs (subvec d 1)]
                (if (and (> (count specs) 0) (string? (nth specs 0)))
                  ;; bare form: (require lib :as a :refer [syms])
                  (let [r (parse-require-libspec! (vec (concat [BRACKET-TAG] specs)))]
                    (when (some? r) (swap! requires conj r)))
                  ;; quoted/bracketed libspecs, one or more
                  (doseq [spec specs]
                    (let [r (parse-require-libspec! spec)]
                      (when (some? r) (swap! requires conj r))))))
            (= head "import") nil
            :else nil))))
    ;; Mode-2 hygiene context (parse.rkt module-def-name-set): the program's
    ;; top-level def names, gated to targets whose emitters handle the
    ;; injected `(def alias orig)` (clj/cljs/nix/js/odin). ^:dynamic defs
    ;; carry a (#%meta ...) name wrapper — not a plain symbol — and are
    ;; excluded, as in Racket.
    (let [hygiene-capable (has-item? ["clj" "cljs" "nix" "js" "odin"] (deref target))
          def-names (if hygiene-capable
                      (reduce (fn [acc :- Any dd :- Any] :- Any
                                (if (and (vector? dd) (not (bracketed? dd))
                                         (>= (count dd) 2)
                                         (has-item? ["def" "defn" "defonce"] (nth dd 0))
                                         (string? (nth dd 1)))
                                  (assoc acc (nth dd 1) true)
                                  acc))
                              {} datums)
                      nil)]
      (mac/set-hygiene-context! def-names))
    ;; Pass 2: expand user macros (top-level applications here; nested ones
    ;; expand inside parse-expr, mirroring parse.rkt's head-meaning order)
    ;; and parse non-meta forms. Proc-macro (Vec Form) output arrives as a
    ;; #%splice-forms wrapper and splices into the top-level form list.
    (doseq [d datums]
      (when (not (meta-form? d))
        (let [reg (deref CURRENT-REGISTRY-CELL)
              from-macro (mac/macro-application? reg d)
              expanded (if from-macro (mac/expand-fully! reg d 0 nil) d)]
          (if (and (vector? expanded) (> (count expanded) 0)
                   (= (nth expanded 0) "#%splice-forms"))
            (doseq [f (subvec expanded 1)]
              (swap! forms conj (parse-expr* f)))
            (swap! forms conj (parse-expr* expanded))))))
    ;; Mode-2 hygiene: inject a synthetic `(def alias orig)` immediately after
    ;; orig's definition for every free-ref alias the expander recorded
    ;; (parse.rkt inject-hygiene-aliases; no-op when none were).
    (let [aliases (mac/hygiene-aliases)]
      (when (> (count aliases) 0)
        (reset! forms
          (reduce (fn [acc :- Any f :- Any] :- Any
                    (let [node (get f "node")
                          nm (if (has-item? ["def" "defn" "defonce" "defn-multi"] node)
                               (get f "name")
                               nil)
                          alias (if (string? nm) (get aliases nm) nil)]
                      (if (some? alias)
                        (conj acc f (make-def alias nil (make-ref nm) nil false))
                        (conj acc f))))
                  [] (deref forms)))))
    (mac/set-hygiene-context! nil)
    (reset! CURRENT-REGISTRY-CELL nil)
    {"mode" (deref mode)
     "namespace" (deref namespace)
     "target" (deref target)
     "gen-class" (deref gen-class)
     "forms" (deref forms)
     "externs" (deref extern-list)
     "requires" (deref requires)}))

;; === tests ===================================================================

(def PASSES :- Any (atom 0))
(def FAILURES :- Any (atom []))

(defn- expect! [label :- String result :- Bool] :- Nil
  (if result
    (do (swap! PASSES inc) nil)
    (do (swap! FAILURES conj label) nil))
  nil)

(defn run-tests! [] :- Int
  (reset! PASSES 0)
  (reset! FAILURES [])
  (reset-errors!)

  ;; --- literal parsing ---
  (expect! "literal: number"
    (= (parse-expr* 42) {"node" "literal" "kind" "number" "value" 42}))
  (expect! "literal: float"
    (= (parse-expr* 3.14) {"node" "literal" "kind" "float" "value" 3.14}))
  (expect! "bare true normalizes to ref (oracle parity)"
    (= (parse-expr* true) {"node" "ref" "name" "true"}))
  (expect! "bare false normalizes to ref (oracle parity)"
    (= (parse-expr* false) {"node" "ref" "name" "false"}))
  (expect! "cond :else canonicalizes to ref else (oracle parity)"
    (let [node (parse-expr* ["cond" [BRACKET-TAG "x" "a"] [BRACKET-TAG ":else" "b"]])]
      (= (get (nth (get node "clauses") 1) "test") {"node" "ref" "name" "else"})))
  (expect! "literal: nil (null) — no value key (ast-json parity)"
    (= (parse-expr* nil) {"node" "literal" "kind" "nil"}))
  (expect! "literal: nil symbol"
    (= (get (parse-expr* "nil") "kind") "nil"))
  (expect! "literal: keyword"
    (= (parse-expr* ":name") {"node" "literal" "kind" "keyword" "value" "name"}))
  (expect! "literal: string datum"
    (= (parse-expr* ["#%string" "hi"]) {"node" "literal" "kind" "string" "value" "hi"}))

  ;; --- refs ---
  (expect! "ref: symbol" (= (parse-expr* "x") {"node" "ref" "name" "x"}))
  (expect! "ref: hyphenated" (= (parse-expr* "my-var") {"node" "ref" "name" "my-var"}))
  (expect! "ref: qualified lowercase stays ref (k/single?)"
    (= (parse-expr* "k/single?") {"node" "ref" "name" "k/single?"}))

  ;; --- def (today: `:-` marker; bare `:` rejected) ---
  (expect! "def without annotation"
    (let [node (parse-expr* ["def" "x" 42])]
      (and (= (get node "node") "def")
           (= (get node "name") "x")
           (nil? (get node "ann"))
           (= (get (get node "value") "value") 42))))
  (expect! "def with :- annotation"
    (let [node (parse-expr* ["def" "x" ":-" "Int" 42])]
      (and (= (get node "node") "def")
           (= (get node "name") "x")
           (= (get (get node "ann") "name") "Int")
           (= (get (get node "value") "value") 42))))
  (expect! "def with docstring"
    (let [node (parse-expr* ["def" "x" ["#%string" "doc"] 42])]
      (and (= (get node "node") "def")
           (= (get (get node "value") "value") 42))))
  (expect! "def bare `:` rejected"
    (do (reset-errors!)
        (parse-expr* ["def" "x" ":" "Int" 42])
        (> (count (parse-errors)) 0)))

  ;; --- defn (flat params today) ---
  (expect! "defn flat typed params + return type"
    (let [node (parse-expr* ["defn" "foo"
                            [BRACKET-TAG "x" ":-" "Int"]
                            ":-" "String"
                            ["str" "x"]])]
      (and (= (get node "node") "defn")
           (= (get node "name") "foo")
           (= (count (get node "params")) 1)
           (= (get (nth (get node "params") 0) "name") "x")
           (= (get (get (nth (get node "params") 0) "ann") "name") "Int")
           (= (get node "ret") {"kind" "prim" "name" "String"})
           (= (get node "private") false)
           (= (get node "rest") false))))
  (expect! "defn wrapped params still accepted"
    (let [node (parse-expr* ["defn" "foo"
                            [BRACKET-TAG ["x" ":-" "Int"]]
                            ":-" "String"
                            ["str" "x"]])]
      (and (= (get node "node") "defn")
           (= (get (get (nth (get node "params") 0) "ann") "name") "Int"))))
  (expect! "defn without return type"
    (let [node (parse-expr* ["defn" "bar" [BRACKET-TAG "x"] ["+" "x" 1]])]
      (and (= (get node "node") "defn")
           (nil? (get node "ret")))))
  (expect! "defn mixed param vector [a :- Int b c :- String]"
    (let [node (parse-expr* ["defn" "f"
                            [BRACKET-TAG "a" ":-" "Int" "b" "c" ":-" "String"]
                            "a"])]
      (and (= (count (get node "params")) 3)
           (= (get (nth (get node "params") 0) "name") "a")
           (= (get (get (nth (get node "params") 0) "ann") "name") "Int")
           (= (get (nth (get node "params") 1) "name") "b")
           (nil? (get (nth (get node "params") 1) "ann"))
           (= (get (get (nth (get node "params") 2) "ann") "name") "String"))))
  (expect! "defn with docstring (stripped)"
    (let [node (parse-expr* ["defn" "f" ["#%string" "doc"] [BRACKET-TAG "x"] "x"])]
      (and (= (get node "node") "defn")
           (= (get node "name") "f")
           (= (count (get node "body")) 1))))

  ;; --- fn ---
  (expect! "fn with return type"
    (let [node (parse-expr* ["fn" [BRACKET-TAG "x" ":-" "Int"] ":-" "Int"
                            ["+" "x" 1]])]
      (and (= (get node "node") "fn")
           (= (count (get node "params")) 1)
           (= (get (get node "ret") "name") "Int"))))
  (expect! "fn without return type"
    (let [node (parse-expr* ["fn" [BRACKET-TAG "x"] ["+" "x" 1]])]
      (and (= (get node "node") "fn")
           (nil? (get node "ret")))))

  ;; --- let ---
  (expect! "let with bindings"
    (let [node (parse-expr* ["let" [BRACKET-TAG "x" 1 "y" 2] ["+" "x" "y"]])]
      (and (= (get node "node") "let")
           (= (count (get node "bindings")) 2)
           (= (get (nth (get node "bindings") 0) "name") "x")
           (= (get (nth (get node "bindings") 1) "name") "y"))))
  (expect! "binding form (dynamic-var rebinding, let-binding shape)"
    (let [node (parse-expr* ["binding" [BRACKET-TAG "*out*" "*err*"]
                             ["println" ["#%string" "x"]]])]
      (and (= (get node "node") "binding")
           (= (nth (get node "bindings") 0)
              {"name" "*out*" "ann" nil
               "value" {"node" "dynamic-var" "name" "*err*"}})
           (= (count (get node "body")) 1))))
  (expect! "let flat typed binding (name :- TYPE value)"
    (let [node (parse-expr* ["let" [BRACKET-TAG "t" ":-" "Any" [":tx" "a"]]
                            "t"])]
      (and (= (count (get node "bindings")) 1)
           (= (get (nth (get node "bindings") 0) "name") "t")
           (= (get (get (nth (get node "bindings") 0) "ann") "name") "Any")
           (= (get (get (nth (get node "bindings") 0) "value") "node") "kw-access"))))

  ;; --- if / cond / when / do ---
  (expect! "if with else"
    (let [node (parse-expr* ["if" true "yes" "no"])]
      (and (= (get node "node") "if")
           (= (get (get node "then") "name") "yes")
           (= (get (get node "else") "name") "no"))))
  (expect! "if without else — bool-false literal (ast-json parity)"
    (let [node (parse-expr* ["if" true "yes"])]
      (and (= (get node "node") "if")
           (= (get node "else") {"node" "literal" "kind" "bool" "value" false}))))
  (expect! "cond flat style"
    (let [node (parse-expr* ["cond" true "a" false "b"])]
      (and (= (get node "node") "cond")
           (= (count (get node "clauses")) 2))))
  (expect! "cond bracket style"
    (let [node (parse-expr* ["cond" [BRACKET-TAG true "a"] [BRACKET-TAG ":else" "b"]])]
      (and (= (get node "node") "cond")
           (= (count (get node "clauses")) 2))))
  (expect! "when canonicalizes to (if c (do ...)) — oracle parity"
    (let [node (parse-expr* ["when" "c" "a" "b"])]
      (and (= (get node "node") "if")
           (= (get (get node "then") "node") "do")
           (= (count (get (get node "then") "body")) 2)
           (= (get node "else") {"node" "literal" "kind" "bool" "value" false}))))
  (expect! "when-not canonicalizes to (if (not c) (do ...))"
    (let [node (parse-expr* ["when-not" "c" "a"])]
      (and (= (get node "node") "if")
           (= (get (get (get node "cond") "fn") "name") "not"))))
  (expect! "if-not swaps branches (oracle parity)"
    (let [node (parse-expr* ["if-not" "c" "t" "e"])]
      (and (= (get node "node") "if")
           (= (get (get node "cond") "name") "c")
           (= (get (get node "then") "name") "e")
           (= (get (get node "else") "name") "t"))))
  (expect! "do"
    (let [node (parse-expr* ["do" "a" "b"])]
      (and (= (get node "node") "do")
           (= (count (get node "body")) 2))))

  ;; --- loop / recur ---
  (expect! "loop"
    (let [node (parse-expr* ["loop" [BRACKET-TAG "i" 0] ["recur" ["+" "i" 1]]])]
      (and (= (get node "node") "loop")
           (= (count (get node "bindings")) 1)
           (= (get (nth (get node "bindings") 0) "name") "i"))))
  (expect! "recur"
    (let [node (parse-expr* ["recur" 1 2])]
      (and (= (get node "node") "recur")
           (= (count (get node "args")) 2))))

  ;; --- for ---
  (expect! "for with binding"
    (let [node (parse-expr* ["for" [BRACKET-TAG "x" "items"] "x"])]
      (and (= (get node "node") "for")
           (= (count (get node "clauses")) 1)
           (= (get (nth (get node "clauses") 0) "type") "binding"))))
  (expect! "for with :when"
    (let [node (parse-expr* ["for" [BRACKET-TAG "x" "items" ":when" ["even?" "x"]]
                            "x"])]
      (and (= (count (get node "clauses")) 2)
           (= (get (nth (get node "clauses") 1) "type") "when"))))

  ;; --- match ---
  (expect! "match with patterns"
    (let [node (parse-expr* ["match" "x"
                            [BRACKET-TAG "_" "default"]
                            [BRACKET-TAG "y" ["+" "y" 1]]])]
      (and (= (get node "node") "match")
           (= (count (get node "clauses")) 2)
           (= (get (get (nth (get node "clauses") 0) "pattern") "type") "wildcard"))))
  (expect! "match record pattern"
    (let [node (parse-expr* ["match" "shape"
                            [BRACKET-TAG ["Circle" "r"] ["*" 3.14 ["*" "r" "r"]]]
                            [BRACKET-TAG ["Rect" "w" "h"] ["*" "w" "h"]]])]
      (and (= (get (get (nth (get node "clauses") 0) "pattern") "type") "record")
           (= (get (get (nth (get node "clauses") 0) "pattern") "name") "Circle"))))

  ;; --- try ---
  (expect! "try with catch"
    (let [node (parse-expr* ["try" ["foo"]
                            ["catch" "Exception" "e" ["bar" "e"]]])]
      (and (= (get node "node") "try")
           (= (count (get node "body")) 1)
           (= (count (get node "catches")) 1)
           (= (get (nth (get node "catches") 0) "name") "e")
           (= (get node "finally") false))))

  ;; --- defrecord (today: flat fields) ---
  (expect! "defrecord flat fields"
    (let [node (parse-expr* ["defrecord" "Assertion"
                            [BRACKET-TAG "tx" ":-" "Int" "op" ":-" "String"]])]
      (and (= (get node "node") "record")
           (= (get node "name") "Assertion")
           (= (count (get node "fields")) 2)
           (= (nth (get node "fields") 0)
              {"name" "tx" "ann" {"kind" "prim" "name" "Int"}})
           (nil? (get node "private")))))
  (expect! "defrecord wrapped fields still accepted"
    (let [node (parse-expr* ["defrecord" "Point"
                            [BRACKET-TAG ["x" ":-" "Float"] ["y" ":-" "Float"]]])]
      (and (= (get node "node") "record")
           (= (count (get node "fields")) 2))))

  ;; --- defunion / deferror / defenum / defscalar ---
  (expect! "defunion simple"
    (let [node (parse-expr* ["defunion" "Shape" "Circle" "Rect"])]
      (and (= (get node "node") "defunion")
           (= (get node "name") "Shape")
           (= (count (get node "members")) 2)
           (nil? (get node "type-params")))))
  (expect! "defenum"
    (let [node (parse-expr* ["defenum" "Color" "Red" "Green" "Blue"])]
      (and (= (get node "node") "defenum")
           (= (get node "name") "Color")
           (= (count (get node "values")) 3))))
  (expect! "defscalar"
    (let [node (parse-expr* ["defscalar" "Email" "String"])]
      (and (= (get node "node") "defscalar")
           (= (get node "name") "Email"))))
  (expect! "deferror"
    (let [node (parse-expr* ["deferror" "AppError" "NotFound" "Forbidden"])]
      (and (= (get node "node") "deferror")
           (= (get node "name") "AppError")
           (= (count (get node "members")) 2))))

  ;; --- method-call / kw-access / static-call / constructor ---
  (expect! "method-call"
    (let [node (parse-expr* [".push" "arr" 42])]
      (and (= (get node "node") "method-call")
           (= (get node "method") ".push")
           (= (get (get node "target") "name") "arr"))))
  (expect! "kw-access without default — false (ast-json parity)"
    (let [node (parse-expr* [":name" "m"])]
      (and (= (get node "node") "kw-access")
           (= (get node "kw") ":name")
           (= (get node "default") false))))
  (expect! "kw-access with default"
    (let [node (parse-expr* [":name" "m" "fallback"])]
      (and (= (get node "node") "kw-access")
           (not (= false (get node "default"))))))
  (expect! "(get m :k) canonicalizes to kw-access — same AST as (:k m)"
    (= (parse-expr* ["get" "m" ":k"])
       (parse-expr* [":k" "m"])))
  (expect! "(get m :k default) canonicalizes to kw-access with default"
    (= (parse-expr* ["get" "m" ":k" 0])
       (parse-expr* [":k" "m" 0])))
  (expect! "(get m k) dynamic key stays a call"
    (= (get (parse-expr* ["get" "m" "k"]) "node") "call"))
  (expect! "(get m \"k\") string key stays a call"
    (= (get (parse-expr* ["get" "m" ["#%string" "k"]]) "node") "call"))
  (expect! "static-call"
    (let [node (parse-expr* ["Math/abs" -1])]
      (and (= (get node "node") "static-call")
           (= (get node "name") "Math/abs"))))
  (expect! "constructor"
    (let [node (parse-expr* ["Date." 2024])]
      (and (= (get node "node") "new")
           (= (get node "class") "Date."))))
  (expect! "arrow-constructor stays plain ref call (->Latest)"
    (let [node (parse-expr* ["->Latest" "a"])]
      (and (= (get node "node") "call")
           (= (get (get node "fn") "name") "->Latest"))))

  ;; --- threading (surface preserved via threading node; desugared checked) ---
  (expect! "-> thread-first: threading node, desugared call chain"
    (let [node (parse-expr* ["->" "x" ["foo" 1] ["bar" 2]])]
      (and (= (get node "node") "threading")
           (= (get node "kind") "->")
           (= (count (get node "args")) 3)
           (= (nth (get node "args") 0) {"node" "ref" "name" "x"})
           (= (get (get (get node "desugared") "fn") "name") "bar")
           ;; -> inserts as FIRST arg: (bar (foo x 1) 2)
           (= (get (get (nth (get (get node "desugared") "args") 0) "fn") "name") "foo"))))
  (expect! "->> thread-last: threaded value is LAST arg"
    (let [node (parse-expr* ["->>" "x" ["foo" 1] ["bar" 2]])]
      (and (= (get node "node") "threading")
           (= (get node "kind") "->>")
           ;; ->> inserts as LAST arg: (bar 2 (foo 1 x))
           (= (get (get (nth (get (get node "desugared") "args") 1) "fn") "name") "foo"))))
  (expect! "cond-> mints fresh temps per step in the desugared chain"
    (do (mac/reset-lowering-counter!)
        (let [node (parse-expr* ["cond->" "x" ["pos?" "x"] ["inc"]])]
          (and (= (get node "node") "threading")
               (= (get node "kind") "cond->")
               (= (count (get node "args")) 3)
               (= (get (nth (get (get node "desugared") "bindings") 0) "name")
                  "cond-thread__0")))))
  (expect! "as-> keeps placeholder in args; desugars to let chain"
    (let [node (parse-expr* ["as->" 1 "n" ["+" "n" "n"]])]
      (and (= (get node "node") "threading")
           (= (get node "kind") "as->")
           (= (nth (get node "args") 1) {"node" "ref" "name" "n"})
           (= (get (get node "desugared") "node") "let"))))

  ;; --- multi-arity ---
  (expect! "multi-arity defn"
    (let [node (parse-expr* ["defn" "f"
                            [[BRACKET-TAG] ["#%string" "zero"]]
                            [[BRACKET-TAG "x"] "x"]])]
      (and (= (get node "node") "defn-multi")
           (= (get node "name") "f")
           (= (count (get node "arities")) 2)
           (= (get (nth (get node "arities") 0) "rest") false))))
  (expect! "bare-vector multi-arity defn canonicalizes to wrapped clauses"
    (= (parse-expr* ["defn" "f" [BRACKET-TAG "a"] "a"
                     [BRACKET-TAG "a" "b"] ["+" "a" "b"]])
       (parse-expr* ["defn" "f" [[BRACKET-TAG "a"] "a"]
                     [[BRACKET-TAG "a" "b"] ["+" "a" "b"]]])))
  (expect! "single-arity defn with vec body is NOT multi-arity"
    (= (get (parse-expr* ["defn" "f" [BRACKET-TAG "a"] [BRACKET-TAG 1 2]]) "node")
       "defn"))

  ;; --- target-case ---
  (expect! "target-case: cases sorted by target name; branches parse"
    (= (parse-expr* ["target-case" ":js" 2 ":clj" 1])
       {"node" "target-case"
        "cases" [{"target" "clj" "body" {"node" "literal" "kind" "number" "value" 1}}
                 {"target" "js" "body" {"node" "literal" "kind" "number" "value" 2}}]}))

  ;; --- def flags (ast-json doc/dynamic parity) ---
  (expect! "^:dynamic def sets the dynamic flag"
    (= (get (parse-expr* ["def" ["#%meta" ":dynamic" "*x*"] 1]) "dynamic") true))
  (expect! "^{:dynamic true} longhand sets the dynamic flag"
    (= (get (parse-expr* ["def" ["#%meta" [MAP-TAG ":dynamic" true] "*x*"] 1]) "dynamic") true))
  (expect! "plain def: dynamic false, doc false"
    (let [node (parse-expr* ["def" "x" 1])]
      (and (= (get node "dynamic") false) (= (get node "doc") false))))
  (expect! "def docstring recorded"
    (= (get (parse-expr* ["def" "x" ["#%string" "d"] 1]) "doc") "d"))

  ;; --- vec / map / set ---
  (expect! "vec literal"
    (let [node (parse-expr* [BRACKET-TAG 1 2 3])]
      (and (= (get node "node") "vec")
           (= (count (get node "items")) 3))))
  (expect! "map literal"
    (let [node (parse-expr* [MAP-TAG ":a" 1 ":b" 2])]
      (and (= (get node "node") "map")
           (= (count (get node "pairs")) 2))))
  (expect! "set literal"
    (let [node (parse-expr* [SET-TAG 1 2 3])]
      (and (= (get node "node") "set")
           (= (count (get node "items")) 3))))

  ;; --- quote (today: datum->json tags symbols) ---
  (expect! "quote symbol datum"
    (let [node (parse-expr* ["quote" "hello"])]
      (and (= (get node "node") "quoted")
           (= (get node "datum") {"type" "symbol" "value" "hello"}))))
  (expect! "quote list with keyword + string"
    (let [node (parse-expr* ["quote" ["a" ":k" ["#%string" "s"]]])]
      (= (get node "datum")
         [{"type" "symbol" "value" "a"}
          {"type" "keyword" "value" "k"}
          "s"])))

  ;; --- regex ---
  (expect! "regex literal"
    (let [node (parse-expr* ["#%regex" "\\d+"])]
      (and (= (get node "node") "regex")
           (= (get node "pattern") "\\d+"))))

  ;; --- when-let / if-let / condp / doseq / dotimes / set! / await / defonce ---
  (expect! "when-let lowers to (let [x v] (if x (do ...)))"
    (let [node (parse-expr* ["when-let" [BRACKET-TAG "x" "foo"] "x"])]
      (and (= (get node "node") "let")
           (= (get (nth (get node "bindings") 0) "name") "x")
           (= (get (nth (get node "body") 0) "node") "if")
           (= (get (get (nth (get node "body") 0) "cond") "name") "x"))))
  (expect! "if-let lowers to (let [x v] (if x t e))"
    (let [node (parse-expr* ["if-let" [BRACKET-TAG "x" "foo"] "x" "y"])]
      (and (= (get node "node") "let")
           (= (get (get (nth (get node "body") 0) "else") "name") "y"))))
  (expect! "when-some lowers with nil? test"
    (let [node (parse-expr* ["when-some" [BRACKET-TAG "x" "foo"] "x"])]
      (let [test (get (nth (get node "body") 0) "cond")]
        (and (= (get node "node") "let")
             (= (get (get test "fn") "name") "not")))))
  (expect! "condp"
    (let [node (parse-expr* ["condp" "=" "x" 1 ["#%string" "one"] 2 ["#%string" "two"] ["#%string" "other"]])]
      (and (= (get node "node") "condp")
           (= (count (get node "clauses")) 2)
           (not (= false (get node "default"))))))
  (expect! "doseq"
    (let [node (parse-expr* ["doseq" [BRACKET-TAG "x" "items"] ["println" "x"]])]
      (and (= (get node "node") "doseq")
           (= (count (get node "clauses")) 1))))
  ;; removed forms reject with pointed guidance
  (expect! "dotimes rejected with pointed error"
    (let [_ (reset-errors!)
          _ (parse-expr* ["dotimes" [BRACKET-TAG "i" 10] ["println" "i"]])
          errs (parse-errors)]
      (and (> (count errs) 0)
           (str/includes? (nth errs 0) "dotimes removed"))))
  (expect! "case rejected with pointed error"
    (let [_ (reset-errors!)
          _ (parse-expr* ["case" "x" 1 ["#%string" "one"]])
          errs (parse-errors)]
      (and (> (count errs) 0)
           (str/includes? (nth errs 0) "case removed"))))
  (expect! "set!"
    (let [node (parse-expr* ["set!" "x" 42])]
      (and (= (get node "node") "set!")
           (= (get (get node "target") "name") "x"))))
  (expect! "await"
    (let [node (parse-expr* ["await" ["fetch" "url"]])]
      (and (= (get node "node") "await")
           (= (get (get node "expr") "node") "call"))))
  (expect! "defonce"
    (let [node (parse-expr* ["defonce" "db" ["connect"]])]
      (and (= (get node "node") "defonce")
           (= (get node "name") "db"))))

  ;; --- letfn ---
  (expect! "letfn"
    (let [node (parse-expr* ["letfn" [BRACKET-TAG
                                     ["even?" [BRACKET-TAG "n"] ["odd?" ["dec" "n"]]]
                                     ["odd?" [BRACKET-TAG "n"] ["even?" ["dec" "n"]]]]
                            ["even?" 10]])]
      (and (= (get node "node") "letfn")
           (= (count (get node "fns")) 2))))

  ;; --- dynamic-var ---
  (expect! "dynamic-var"
    (let [node (parse-expr* "*state*")]
      (and (= (get node "node") "dynamic-var")
           (= (get node "name") "*state*"))))

  ;; --- generic call ---
  (expect! "generic call"
    (let [node (parse-expr* ["println" ["#%string" "hello"]])]
      (and (= (get node "node") "call")
           (= (get (get node "fn") "node") "ref")
           (= (get (get node "fn") "name") "println"))))

  ;; --- defn- private ---
  (expect! "defn- private"
    (let [node (parse-expr* ["defn-" "helper" [BRACKET-TAG "x"] "x"])]
      (and (= (get node "node") "defn")
           (= (get node "private") true))))

  ;; --- with form ---
  (expect! "with form"
    (let [node (parse-expr* ["with" "point"
                            [BRACKET-TAG ":x" 10]
                            [BRACKET-TAG ":y" 20]])]
      (and (= (get node "node") "with")
           (= (count (get node "updates")) 2))))

  ;; --- params / record-fields units ---
  (expect! "parse-params! flat typed"
    (let [result (parse-params! [BRACKET-TAG "x" ":-" "Int" "y" ":-" "String"])]
      (and (= (count (get result "params")) 2)
           (= (get (nth (get result "params") 0) "name") "x")
           (= (get (get (nth (get result "params") 0) "ann") "name") "Int")
           (= (get (get (nth (get result "params") 1) "ann") "name") "String"))))
  (expect! "parse-params! with rest"
    (let [result (parse-params! [BRACKET-TAG "x" "&" "rest"])]
      (and (= (count (get result "params")) 1)
           (some? (get result "rest-param"))
           (= (get (get result "rest-param") "name") "rest"))))
  (expect! "parse-params! flat typed rest (& args :- (Vec String))"
    (let [result (parse-params! [BRACKET-TAG "x" "&" "args" ":-" ["Vec" "String"]])]
      (and (= (get (get result "rest-param") "name") "args")
           (= (get (get (get result "rest-param") "ann") "kind") "app"))))
  (expect! "parse-let-bindings! plain"
    (let [bindings (parse-let-bindings! [BRACKET-TAG "x" 1 "y" 2])]
      (and (= (count bindings) 2)
           (= (get (nth bindings 0) "name") "x")
           (= (get (nth bindings 1) "name") "y"))))

  ;; --- unsafe rejection (today: zero escape hatches) ---
  (expect! "unsafe-js rejected"
    (do (reset-errors!)
        (parse-expr* ["unsafe-js" ["#%string" "1+1"]])
        (> (count (parse-errors)) 0)))

  ;; --- parse diagnostics gate the driver exit code (fuzz: `check` printed
  ;; parse errors but still exited 0/'ok'; main now fails on non-empty
  ;; parse-errors). Lock the surface main reads: a parse diagnostic and a
  ;; macro-expansion diagnostic both show up in (parse-errors), and
  ;; reset-errors! clears both. ---
  (expect! "let bare `:` recorded as parse error"
    (do (reset-errors!)
        (parse-let-bindings! [BRACKET-TAG "y" ":" "Int" 3])
        (> (count (parse-errors)) 0)))
  (expect! "parse-errors folds macro-expansion errors; reset clears both"
    (do (reset-errors!)
        (let [reg (mac/make-macro-registry)]
          (mac/register-macro! reg "zero0" "safe" [] ["+" 1 2])
          (mac/expand-fully! reg ["zero0" 9] 0 nil))
        (let [folded (> (count (parse-errors)) 0)]
          (reset-errors!)
          (and folded (= (count (parse-errors)) 0)))))

  ;; --- type parsing ---
  (expect! "parse-type primitive"
    (= (parse-type "Int") {"kind" "prim" "name" "Int"}))
  (expect! "parse-type nullable"
    (let [t (parse-type "String?")]
      (and (= (get t "kind") "union")
           (= (count (get t "members")) 2))))
  (expect! "parse-type fn"
    (let [t (parse-type [BRACKET-TAG "Int" "->" "String"])]
      (and (= (get t "kind") "fn")
           (= (count (get t "params")) 1))))
  (expect! "parse-type Vec app"
    (let [t (parse-type ["Vec" "String"])]
      (and (= (get t "kind") "app")
           (= (get t "name") "Vec"))))
  (expect! "parse-type union"
    (let [t (parse-type ["U" "Int" "String"])]
      (and (= (get t "kind") "union")
           (= (count (get t "members")) 2))))
  (expect! "parse-type clj alias Long"
    (= (parse-type "Long") {"kind" "prim" "name" "Int"}))

  ;; --- parse-program! ---
  (expect! "parse-program! meta extraction"
    (let [prog (parse-program! [["ns" "my.app"]
                               ["define-mode" "strict"]
                               ["define-target" "js"]
                               ["declare-extern" "console" "Any"]
                               ["def" "x" 42]])]
      (and (= (get prog "namespace") "my.app")
           (= (get prog "mode") "strict")
           (= (get prog "target") "js")
           (= (count (get prog "forms")) 1)
           (= (get (nth (get prog "forms") 0) "node") "def")
           (= (count (get prog "externs")) 1)
           (= (get (nth (get prog "externs") 0) "name") "console"))))
  (expect! "parse-program! require :as (fold shape)"
    (let [prog (parse-program! [["ns" "fram.fold"]
                               ["require" "fram.kernel" ":as" "k"]])]
      (= (get prog "requires")
         [{"ns" "fram.kernel" "alias" "k" "refer" false}])))
  (expect! "parse-program! ns docstring dropped"
    (let [prog (parse-program! [["ns" "fram.fold" ["#%string" "Replay the log."]]])]
      (and (= (get prog "namespace") "fram.fold")
           (= (count (get prog "forms")) 0))))
  (expect! "parse-program! ns (:require [lib :as a])"
    (let [prog (parse-program! [["ns" "my.app"
                                [":require" ["#%brackets" "clojure.string" ":as" "str"]]]])]
      (= (get prog "requires")
         [{"ns" "clojure.string" "alias" "str" "refer" false}])))
  (expect! "parse-program! require :refer"
    (let [prog (parse-program! [["require" "my.lib" ":refer" ["#%brackets" "f" "g"]]])]
      (= (get prog "requires")
         [{"ns" "my.lib" "alias" false "refer" ["f" "g"]}])))
  (expect! "parse-program! default mode strict + target clj + gen-class false"
    (let [prog (parse-program! [["ns" "x.y"]])]
      (and (= (get prog "mode") "strict")
           (= (get prog "target") "clj")
           (= (get prog "gen-class") false))))
  (expect! "parse-program! (:gen-class) sets program flag"
    (let [prog (parse-program! [["ns" "fram.main" [":gen-class"]]])]
      (= (get prog "gen-class") true)))

  ;; --- nix forms (parse.rkt L2486-3153; ast-json.rkt L466-543) ---
  (expect! "nix: (s ...) interpolated-string — literal parts are text, others expr"
    (let [node (parse-expr* ["s" ["#%string" "#!"] "pkgs.bash" ["#%string" "/bin"]])]
      (and (= (get node "node") "nix-interpolated-string")
           (= (nth (get node "parts") 0) {"type" "text" "value" "#!"})
           (= (nth (get node "parts") 1)
              {"type" "expr" "value" {"node" "ref" "name" "pkgs.bash"}})
           (= (nth (get node "parts") 2) {"type" "text" "value" "/bin"}))))
  (expect! "nix: bare symbol in (s ...) is an expr part, NOT text"
    (let [node (parse-expr* ["s" "hostName" ["#%string" ".local"]])]
      (and (= (get (nth (get node "parts") 0) "type") "expr")
           (= (get (nth (get node "parts") 1) "type") "text"))))
  (expect! "nix: (ms ...) multiline — nested (s) is interp line, literal is text"
    (let [node (parse-expr* ["ms" ["s" ["#%string" "a"] "x"] ["#%string" "lit"]])]
      (and (= (get node "node") "nix-multiline-string")
           (= (get (nth (get node "lines") 0) "type") "interp")
           (= (get (nth (get node "lines") 1) "type") "text"))))
  (expect! "nix: (p \"./x\") -> nix-path"
    (= (parse-expr* ["p" ["#%string" "./hardware.nix"]])
       {"node" "nix-path" "path" "./hardware.nix"}))
  (expect! "nix: (nix/with ns body) -> nix-with"
    (let [node (parse-expr* ["nix/with" "pkgs" [BRACKET-TAG "a"]])]
      (and (= (get node "node") "nix-with")
           (= (get node "ns-expr") {"node" "ref" "name" "pkgs"}))))
  (expect! "nix: (nix/assert c b) -> nix-assert"
    (let [node (parse-expr* ["nix/assert" "cnd" [BRACKET-TAG]])]
      (and (= (get node "node") "nix-assert")
           (= (get node "cond") {"node" "ref" "name" "cnd"}))))
  (expect! "nix: (rec-attrs k v ...) -> nix-rec-attrs, symbol keys"
    (let [node (parse-expr* ["rec-attrs" "hostName" ["#%string" "h"]])]
      (and (= (get node "node") "nix-rec-attrs")
           (= (nth (get node "pairs") 0)
              {"key" "hostName"
               "val" {"node" "literal" "kind" "string" "value" "h"}}))))
  (expect! "nix: (inherit a b) -> nix-inherit"
    (= (parse-expr* ["inherit" "a" "b"]) {"node" "nix-inherit" "names" ["a" "b"]}))
  (expect! "nix: (inherit-from (ns) a) -> nix-inherit-from"
    (let [node (parse-expr* ["inherit-from" "pkgs" "a"])]
      (and (= (get node "node") "nix-inherit-from")
           (= (get node "ns-expr") {"node" "ref" "name" "pkgs"})
           (= (get node "names") ["a"]))))
  (expect! "nix: (get-or base path default) -> nix-get-or"
    (let [node (parse-expr* ["get-or" "m" "foo" ["#%string" "d"]])]
      (and (= (get node "node") "nix-get-or") (= (get node "path") "foo"))))
  (expect! "nix: (search-path name) -> nix-search-path"
    (= (parse-expr* ["search-path" "nixpkgs"])
       {"node" "nix-search-path" "name" "nixpkgs"}))
  (expect! "nix: (nix/module [a b] body) -> nix-fn-set rest=true, at-name=false"
    (let [node (parse-expr* ["nix/module" [BRACKET-TAG "config" "lib"] [BRACKET-TAG]])]
      (and (= (get node "node") "nix-fn-set")
           (= (get node "rest") true)
           (= (get node "at-name") false)
           (= (get node "formals")
              [{"name" "config" "default" false} {"name" "lib" "default" false}]))))
  (expect! "nix: (nix/fn-set [x] body) -> nix-fn-set rest=false"
    (let [node (parse-expr* ["nix/fn-set" [BRACKET-TAG "x"] "x"])]
      (and (= (get node "rest") false)
           (= (get node "formals") [{"name" "x" "default" false}]))))
  (expect! "nix: nix/module rest-marker ... filtered from formals"
    (let [node (parse-expr* ["nix/module" [BRACKET-TAG "pkgs" "..."] [BRACKET-TAG]])]
      (= (get node "formals") [{"name" "pkgs" "default" false}])))
  (expect! "nix: (nix/overlay [final prev] body) -> curried fn (ret nil, rest false)"
    (let [node (parse-expr* ["nix/overlay" [BRACKET-TAG "final" "prev"] [BRACKET-TAG]])]
      (and (= (get node "node") "fn")
           (= (get node "rest") false)
           (nil? (get node "ret"))
           (= (mapv (fn [p :- Any] :- Any (get p "name")) (get node "params"))
              ["final" "prev"]))))
  (expect! "nix: (nix/derivation attrs) -> nix-derivation"
    (= (get (parse-expr* ["nix/derivation" [BRACKET-TAG]]) "node") "nix-derivation"))
  (expect! "nix: (nix/flake attrs) -> nix-flake"
    (= (get (parse-expr* ["nix/flake" [BRACKET-TAG]]) "node") "nix-flake"))
  (expect! "nix: (nix/with-cfg path body) -> nix-with-cfg"
    (= (get (parse-expr* ["nix/with-cfg" "config.x" [BRACKET-TAG]]) "node") "nix-with-cfg"))
  (expect! "nix: bare assert HARD-REJECTED (point at nix/assert)"
    (do (reset-errors!) (parse-expr* ["assert" "c" [BRACKET-TAG]])
        (> (count (parse-errors)) 0)))
  (expect! "nix: bare module HARD-REJECTED (point at nix/module)"
    (do (reset-errors!) (parse-expr* ["module" [BRACKET-TAG] [BRACKET-TAG]])
        (> (count (parse-errors)) 0)))
  (reset-errors!)
  (expect! "nix: parse-program! with injected (define-target nix) sets target nix"
    (= (get (parse-program! [["define-target" "nix"] ["ns" "x"]]) "target") "nix"))

  ;; --- summary ---
  (let [fails (deref FAILURES)]
    (doseq [f fails]
      (selfhost.rt/eprint (str "  FAIL: " f "\n")))
    (println (str "  PARSE: " (deref PASSES) " passed, " (count fails) " failed"))
    (count fails)))
