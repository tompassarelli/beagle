(defrecord Product [(id : Long) (name : String)])
(defrecord Customer [(id : Long) (email : String)])

(defn process-products [(products : (Vec Product))] : Long
  (count products))

;; should fail: vec contains Customer, not Product
(defn bad [] : Long
  (let [cs [(->Customer 1 "a@b.com") (->Customer 2 "c@d.com")]]
    (process-products cs)))
