#lang beagle/rkt

(defn factorial [(n : Int)] : Int
  (if (<= n 1) 1 (* n (factorial (- n 1)))))

(defn fib [(n : Int)] : Int
  (cond
    [(<= n 0) 0]
    [(= n 1) 1]
    [true (+ (fib (- n 1)) (fib (- n 2)))]))

(defn sum-to [(n : Int)] : Int
  (loop [i n acc 0]
    (if (<= i 0) acc (recur (- i 1) (+ acc i)))))

(println (factorial 10))
(println (fib 10))
(println (sum-to 100))
