#lang beagle/rkt

(deferror AppError
  (NotFound [(key : String)])
  (InvalidInput [(msg : String)]))

(defn safe-lookup [(items : (Map String Int)) (k : String)] : String
  (try
    (let [v (get items k)]
      (str "found: " v))
    (catch Exception e
      (str "error: " e))))

(def items : (Map String Int) {"a" 1 "b" 2})
(println (safe-lookup items "a"))
(println (safe-lookup items "missing"))
