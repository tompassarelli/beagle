#lang beagle/rkt

(defrecord Pair [(fst : Int) (snd : Int)])

(defn swap [(p : Pair)] : Pair
  (let [a (pair-fst p)
        b (pair-snd p)]
    (->Pair b a)))

(defn nested-let [(x : Int)] : Int
  (let [a (+ x 1)]
    (let [b (* a 2)]
      (+ a b))))

(def p (swap (->Pair 1 2)))
(println (pair-fst p))
(println (pair-snd p))
(println (nested-let 5))
