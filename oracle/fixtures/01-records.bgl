#lang beagle/rkt

(defrecord Product [(name : String) (price : Int) (stock : Int)])

(defn make-product [(name : String) (price : Int) (stock : Int)] : Product
  (->Product name price stock))

(defn product-expensive? [(p : Product)] : Bool
  (> (product-price p) 1000))

(def p : Product (make-product "Widget" 999 100))

(println (product-name p))
(println (product-expensive? p))
