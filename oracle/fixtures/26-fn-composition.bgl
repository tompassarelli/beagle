#lang beagle/rkt

(defn apply-n [(f : [Int -> Int]) (n : Int) (x : Int)] : Int
  (loop [i 0 acc x]
    (if (= i n) acc (recur (inc i) (f acc)))))

(defn pipeline [(x : Int)] : Int
  (let [step1 (+ x 10)
        step2 (* step1 2)
        step3 (- step2 5)]
    step3))

(println (apply-n inc 5 0))
(println (pipeline 3))
(println (pipeline 10))
