#lang beagle/rkt

(defn sum-pairs [(xs : (Vec Int)) (ys : (Vec Int))] : (Vec Int)
  (for [i (range (min (count xs) (count ys)))]
    (+ (nth xs i) (nth ys i))))

(defn repeat-str [(s : String) (n : Int)] : String
  (loop [i 0 acc ""]
    (if (= i n) acc (recur (inc i) (str acc s)))))

(println (sum-pairs [1 2 3] [10 20 30]))
(println (repeat-str "ab" 3))
