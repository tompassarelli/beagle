(ns g)
(defrecord Chunk [voxels :- (Arr 4 (Arr 4 (Arr 4 Int)))])
(defn cget [c :- (Ptr Chunk) x :- Int y :- Int z :- Int] :- Int
  (nth (nth (nth (:voxels (deref c)) x) y) z))
(defn cset [c :- (Ptr Chunk) x :- Int y :- Int z :- Int v :- Int] :- Nil
  (set! (nth (nth (nth (:voxels (deref c)) x) y) z) v))
