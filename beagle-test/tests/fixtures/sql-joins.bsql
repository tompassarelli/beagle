#lang beagle/sql
(ns test.sql.joins)

;; Multiple JOIN variants in a single query: inner, left, with alias.
(sql/select [c.name p.name (count o.id :as order_count)]
  (from customers :as c)
  (left-join orders :as o (= o.customer_id c.id))
  (join order_items :as oi (= oi.order_id o.id))
  (join products :as p (= oi.product_id p.id))
  (where (> p.price 10))
  (group-by c.name p.name))
