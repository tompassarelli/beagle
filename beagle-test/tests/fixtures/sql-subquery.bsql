#lang beagle/sql
(ns test.sql.subquery)

;; EXISTS subquery + IN subquery.
(sql/select [name email]
  (from customers :as c)
  (where (and (exists (sql/select [1]
                        (from orders :as o)
                        (where (= o.customer_id c.id))))
              (in c.id (sql/select [customer_id]
                         (from premium_members))))))
