#lang beagle/nix
(ns test.nix.builtins)

(module [lib pkgs]
  (let [nodes (builtins/mapAttrs
                (fn [(name : Any) (config : Any)] : Any config.system.build.toplevel)
                {:foo 1 :bar 2})
        json (builtins/toJSON {:version 1 :name "test"})]
    {:data nodes
     :meta json
     :count (builtins/length [1 2 3])
     :merged (merge {:a 1} {:b 2})
     :path (p "./hardware.nix")}))
