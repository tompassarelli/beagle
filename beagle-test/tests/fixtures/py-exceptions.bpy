#lang beagle/py

(ns py-exceptions)

(deferror DomainError
  Overflow
  Underflow
  (BadInput [(field : String) (reason : String)]))

(defn validate-input [(n : Int)] : String
  (if (< n 0) "negative" "positive"))

(defn safe-divide [(a : Int) (b : Int)] : Int
  (try
    (/ a b)
    (catch ZeroDivisionError e 0)))

(defn safe-int-parse [(s : String)] : Int
  (try
    (int s)
    (catch ValueError e -1)))

(defn always-cleanup [(filename : String)] : Nil
  (try
    (println filename)
    (catch Exception e (println "error"))))
