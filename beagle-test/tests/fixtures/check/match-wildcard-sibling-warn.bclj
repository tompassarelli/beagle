(defrecord Alpha [(id : Int) (x : String)])
(defrecord Beta [(id : Int) (y : String)])
(defrecord Gamma [(id : Int) (z : String)])
(defrecord Delta [(id : Int) (w : String)])
(claim handle [Any -> Int])
(defn handle [(e : Any)]
  (match e
    [(Alpha id x) id]
    [(Beta id y) id]
    [(Gamma id z) id]
    [_ 0]))
