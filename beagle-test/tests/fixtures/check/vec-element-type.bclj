(defrecord Product [(id : Int) (name : String)])

(claim process-products [(Vec Product) -> Int])
(defn process-products [(products : (Vec Product))]
  (count products))

;; should pass: homogeneous vec of Products
(claim good [-> Int])
(defn good []
  (let [ps [(->Product 1 "A") (->Product 2 "B")]]
    (process-products ps)))
