(defrecord Product [(id : Int) (name : String)])

(claim get-products [-> (Vec Product)])
(defn get-products []
  [(->Product 1 "A") (->Product 2 "B")])

;; should fail: product-name returns String, not Int
(claim bad-names [-> (Vec Int)])
(defn bad-names []
  (for [p (get-products)]
    (product-name p)))
