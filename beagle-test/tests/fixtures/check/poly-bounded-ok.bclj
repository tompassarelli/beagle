(defrecord Dog [(name : String) (breed : String)])
(defrecord Cat [(name : String) (indoor : Bool)])
(defunion Pet Dog Cat)

(declare-extern get-name (forall [(T <: Pet)] [T -> String]))
(claim dog-name String)
(def dog-name (get-name (->Dog "Rex" "Lab")))
(claim cat-name String)
(def cat-name (get-name (->Cat "Mimi" true)))
