(defrecord Product [(id : Int) (name : String) (price : Int)])

(claim get-product [-> Product])
(defn get-product []
  (->Product 1 "Widget" 500))

;; destructuring should propagate field types from Product
(claim use-name [-> String])
(defn use-name []
  (let [{:keys [name]} (get-product)]
    name))
