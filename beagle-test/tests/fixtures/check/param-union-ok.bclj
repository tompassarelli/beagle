(defunion (Result T E)
  (Ok [(value : T)])
  (Err [(error : E)]))

(defrecord Order [(id : Int) (name : String)])
(defrecord OrderError [(code : Int) (message : String)])

(declare-extern find-order [Int -> (Result Order OrderError)])

(claim handle [(Result Order OrderError) -> String])
(defn handle [(r : (Result Order OrderError))]
  (match r
    [(Ok order) (order-name order)]
    [(Err e) (ordererror-message e)]))
