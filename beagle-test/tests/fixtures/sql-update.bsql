#lang beagle/sql
(ns test.sql.update)

(sql/deftable products
  [(id       : Int :primary-key)
   (price    : Float)
   (stock    : Int)
   (category : String)])

;; UPDATE — multiple SET pairs, computed values, WHERE filter.
(sql/update products
  (set [price (* price 0.9)]
       [stock (+ stock 10)])
  (where (= category "clearance")))
