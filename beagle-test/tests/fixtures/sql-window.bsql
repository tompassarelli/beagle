#lang beagle/sql
(ns test.sql.window)

;; Window functions — row_number, rank, sum-over-partition.
(sql/select [department
         employee
         salary
         (rank :as salary_rank :over (partition-by department) (order-by salary :desc))
         (sum salary :as dept_total :over (partition-by department))]
  (from employees)
  (order-by department :asc salary :desc))
