#lang beagle/sql
(ns test.sql.cte)

;; CTE — WITH clause feeding a subsequent SELECT.
(sql/with
  (top_customers
    (sql/select [customer_id (sum total :as revenue)]
      (from orders)
      (group-by customer_id)
      (having (> (sum total) 1000))))
  (sql/select [c.name tc.revenue]
    (from customers :as c)
    (join top_customers :as tc (= tc.customer_id c.id))
    (order-by tc.revenue :desc)))
