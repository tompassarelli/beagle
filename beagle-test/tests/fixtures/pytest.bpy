#lang beagle/py

(ns pytest)
(define-mode strict)

(defrecord Point [(x : Int) (y : Int)])

(def origin : Point (Point 0 0))

(defn distance [(p : Point)] : Int
  (let [dx (point-x p)
        dy (point-y p)]
    (+ (* dx dx) (* dy dy))))

(defn classify [(n : Int)] : String
  (cond
    (< n 0) "negative"
    (= n 0) "zero"
    :else    "positive"))

(defn greet [(name : String)] : String
  (str "hello " name))

(defn squares [(ns : (Vec Int))] : (Vec Int)
  (for [n ns] (* n n)))

(defn factorial [(n : Int)] : Int
  (loop [i n
         acc 1]
    (if (<= i 1)
      acc
      (recur (dec i) (* acc i)))))

(defn safe-div [(a : Int) (b : Int)] : Int
  (try
    (/ a b)
    (catch Exception e 0)))

(defn print-all [(items : (Vec String))] : Nil
  (doseq [item items]
    (println item)))
