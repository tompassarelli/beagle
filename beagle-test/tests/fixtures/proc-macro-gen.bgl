#lang beagle

;; Procedural macro: generates a typed getter function from a record + field name.
(define-macro proc gen-getter
  [(rec : Symbol) (field : Symbol)] : Form
  `(defn ,(string->symbol (format "get-~a" field))
     ((obj : ,rec)) : Any
     (get obj ,(sym->kw field))))

(defrecord Point [(x : Int) (y : Int)])

(gen-getter Point x)
(gen-getter Point y)

(def p : Point (->Point 3 7))
(println (get-x p))
(println (get-y p))
