#lang beagle/py

(ns py-comprehensions)

(defn squares [(xs : (Vec Int))] : (Vec Int)
  (for [x xs] (* x x)))

(defn keep-evens [(xs : (Vec Int))] : (Vec Int)
  (for [x xs :when (= 0 (mod x 2))] x))

(defn cartesian-pairs [(xs : (Vec Int)) (ys : (Vec Int))] : (Vec (Vec Int))
  (for [x xs y ys] [x y]))

(defn count-to [(n : Int)] : (List Int)
  (list (range n)))

(defn count-from-to [(a : Int) (b : Int)] : (List Int)
  (list (range a b)))

(defn doubled-sum [(xs : (Vec Int))] : Int
  (let [doubled (for [x xs] (* x 2))]
    (sum (list doubled))))
