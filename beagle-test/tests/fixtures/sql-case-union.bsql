#lang beagle/sql
(ns test.sql.case-union)

;; CASE expression with multiple WHEN branches and ELSE.
;; UNION of two SELECTs.
(sql/union
  (sql/select [name (case (when (> price 100) "premium")
                          (when (> price 50)  "mid-range")
                          :else "budget")
                    :as tier]
    (from products)
    (where (= active #t)))
  (sql/select [name "discontinued" :as tier]
    (from products)
    (where (= active #f))))
