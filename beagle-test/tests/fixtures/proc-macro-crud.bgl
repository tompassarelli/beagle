#lang beagle

;; Procedural macro: generates a record + constructor + accessors from a spec.
;; 5 lines of macro → expands to ~15 lines of typed code.
(define-macro proc defentity
  [(name : Symbol) (fields : (Vec Syntax))] : (Vec Form)
  (let ((field-names (map car fields)))
    (append
     (list
      ;; defrecord with typed fields
      (cons 'defrecord (cons name (list (cons '#%brackets
                                              (map (lambda (f) (list (car f) ': (caddr f)))
                                                   fields))))))
     ;; generate a getter for each field
     (map (lambda (f)
            (let ((fname (car f))
                  (ftype (caddr f)))
              `(defn ,(string->symbol (format "~a-~a" name fname))
                 ((obj : ,name)) : ,ftype
                 (get obj ,(sym->kw fname)))))
          fields))))

(defentity User ((name : String) (age : Int) (active : Bool)))

(def u : User (->User "alice" 30 true))
(println (User-name u))
(println (User-age u))
(println (User-active u))
