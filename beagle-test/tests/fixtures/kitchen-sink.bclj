#lang beagle/clj

(ns kitchen-sink)
(define-mode strict)

;; records
(defrecord Point [(x : Int) (y : Int)])
(defrecord Line [(start : Point) (end : Point)])

;; union
(defunion Shape
  (Circle [(radius : Int)])
  (Square [(side : Int)]))

;; enum
(defenum Color red green blue)

;; basic defs
(def origin : Point (Point 0 0))
(def tau : Float 6.28)

;; multi-body defn
(defn distance [(p : Point)] : Int
  (let [dx (point-x p)
        dy (point-y p)]
    (+ (* dx dx) (* dy dy))))

;; cond with :else
(defn classify [(n : Int)] : String
  (cond
    (< n 0) "negative"
    (= n 0) "zero"
    :else    "positive"))

;; match on union
(defn shape-size [(s : Shape)] : Int
  (match s
    [(Circle c) (circle-radius c)]
    [(Square q) (square-side q)]))

;; when + do
(defn log-point [(p : Point)] : Nil
  (when (> (point-x p) 0)
    (do
      (println "positive x")
      (println (str "x=" (point-x p))))))

;; for comprehension
(defn squares [(ns : (Vec Int))] : (Vec Int)
  (for [n ns] (* n n)))

;; loop/recur
(defn factorial [(n : Int)] : Int
  (loop [i n
         acc 1]
    (if (<= i 1)
      acc
      (recur (- i 1) (* acc i)))))

;; try/catch
(defn safe-div [(a : Int) (b : Int)] : Int
  (try
    (/ a b)
    (catch Exception e 0)))

;; case
(defn color-name [(c : Color)] : String?
  (case c
    :red "Red"
    :green "Green"
    :blue "Blue"))

;; with (record update)
(defn move-right [(p : Point)] : Point
  (with p [:x (+ (point-x p) 1)]))

;; higher-order
(defn apply-twice [(f : [Int -> Int]) (x : Int)] : Int
  (f (f x)))

;; doseq
(defn print-all [(items : (Vec String))] : Nil
  (doseq [item items]
    (println item)))

;; if-let
(defn first-or-default [(xs : (Vec Int))] : Int
  (if-let [x (first xs)]
    x
    0))

;; letfn
(defn mutual-test [] : Bool
  (letfn [(even? [(n : Int)] : Bool
            (if (= n 0) true (odd? (- n 1))))
          (odd? [(n : Int)] : Bool
            (if (= n 0) false (even? (- n 1))))]
    (even? 10)))
