#lang beagle/nix
(ns test.nix.tilde-ms)

(nix/module [pkgs lib config ...]
  {:hello (pkgs.writeShellScriptBin "hello"
            (ms (s "#!" pkgs.bash "/bin/bash") "set -e" "" "NAME=\"${USER:-world}\"" "printf '%s\\n' ${greetings[@]}" "echo \"Hello, $NAME\""))
   :literals (ms "pair = ''';" "dollar = \"$\";")})
