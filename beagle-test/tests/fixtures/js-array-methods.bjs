#lang beagle/js

(ns js-array-methods)

(defn push-one [(xs :- (Vec Int)) (x :- Int)] :- Int
  (.push xs x))

(defn pop-last [(xs :- (Vec Int))] :- Int
  (.pop xs))

(defn first-idx [(xs :- (Vec Int)) (target :- Int)] :- Int
  (.indexOf xs target))

(defn includes? [(xs :- (Vec Int)) (target :- Int)] :- Bool
  (.includes xs target))

(defn joined [(xs :- (Vec String))] :- String
  (.join xs ", "))

(defn sliced [(xs :- (Vec Int)) (start :- Int) (end :- Int)] :- (Vec Int)
  (.slice xs start end))

(defn reversed [(xs :- (Vec Int))] :- (Vec Int)
  (.reverse xs))

(defn concatenated [(a :- (Vec Int)) (b :- (Vec Int))] :- (Vec Int)
  (.concat a b))
