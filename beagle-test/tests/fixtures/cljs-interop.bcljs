#lang beagle

(define-target cljs)
(ns test.cljs-interop)

;; JS global functions
(claim parsed Int)
(def parsed (js/parseInt "42"))

(claim float-val Float)
(def float-val (js/parseFloat "3.14"))

(claim nan-check Bool)
(def nan-check (js/isNaN 0))

(claim finite-check Bool)
(def finite-check (js/isFinite 100))

;; JS Math
(claim pi-area Float)
(def pi-area (js/Math.pow 3.14 2.0))

(claim root Float)
(def root (js/Math.sqrt 16.0))

(claim rnd Float)
(def rnd (js/Math.random))

(claim floored Float)
(def floored (js/Math.floor 3.7))

(claim ceiled Float)
(def ceiled (js/Math.ceil 3.2))

;; JS console
(claim log-it [String -> Nil])
(defn log-it [(msg : String)]
  (js/console.log msg))

;; JS URI encoding
(claim encoded String)
(def encoded (js/encodeURIComponent "hello world"))

(claim decoded String)
(def decoded (js/decodeURIComponent encoded))

;; Standard Clojure functions work in both targets
(claim greet [String -> String])
(defn greet [(name : String)]
  (str "Hello, " name "!"))

(def items (vec (map inc (range 5))))

;; try/catch uses :default in CLJS
(def safe-val
  (try
    (/ 1 0)
    (catch :default e
      (str "error: " e))))

;; defrecord works in both targets
(defrecord Point [(x : Int) (y : Int)])

(claim make-origin [-> Point])
(defn make-origin []
  (->Point 0 0))

(def origin (make-origin))

(claim ox Int)
(def ox (:x origin))
