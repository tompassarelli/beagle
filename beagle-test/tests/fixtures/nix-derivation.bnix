#lang beagle/nix
(ns test.nix.derivation)

(module [pkgs]
  (derivation {:pname "hello-rust"
               :version "0.1.0"
               :src (p "./src")
               :nativeBuildInputs [pkgs.rustc pkgs.cargo]
               :buildPhase ~"cargo build --release"
               :installPhase ~"install -Dm755 target/release/hello $out/bin/hello"}))
