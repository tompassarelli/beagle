#lang beagle/nix
(ns test.nix.derivation)

(nix/module [pkgs]
  (nix/derivation {:pname "hello-rust"
               :version "0.1.0"
               :src (p "./src")
               :nativeBuildInputs [pkgs.rustc pkgs.cargo]
               :buildPhase (s "cargo build --release")
               :installPhase (s "install -Dm755 target/release/hello $out/bin/hello")}))
