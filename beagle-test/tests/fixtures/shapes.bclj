#lang beagle

(ns shapes)

(defrecord Circle [(radius : Int)])
(defrecord Rect [(width : Int) (height : Int)])

(claim circle-area [Circle -> Int])
(defn circle-area [(c : Circle)]
  (* (circle-radius c) (circle-radius c)))

(claim rect-area [Rect -> Int])
(defn rect-area [(r : Rect)]
  (* (rect-width r) (rect-height r)))
