#lang beagle/sql
(ns test.sql.demo.update-post)

;; Insert + update against cross-file schema. Type checker validates
;; column names against .beagle-cache/sql-schema.json.

(sql/insert posts [user_id title body views]
  (values [1 "First post" "Hello" 0]))

(sql/update posts
  (set [views 100])
  (where (= id 1)))
