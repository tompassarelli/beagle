#lang beagle/py

(ns py-stdlib-modules)

(import math)
(import json)

(defn pi-times [(n : Float)] : Float
  (* math/pi n))

(defn sqrt-of [(n : Float)] : Float
  (math/sqrt n))

(defn floor-of [(n : Float)] : Int
  (math/floor n))

(defn ceil-of [(n : Float)] : Int
  (math/ceil n))

(defn to-json [(obj : Any)] : String
  (json/dumps obj))

(defn from-json [(s : String)] : Any
  (json/loads s))
