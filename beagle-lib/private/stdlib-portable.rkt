   'rand-nth   (fn-of '(Any) 'Any)
   'shuffle    (fn-of '(Any) 'Any)
   'flatten    (fn-of '(Any) 'Any)
   'frequencies (fn-of '(Any) 'Any)
   'group-by   (fn-of '(Any Any) 'Any)
   'zipmap     (fn-of '(Any Any) 'Any)
   'not-empty  (fn-of '(Any) 'Any)
   'butlast    (fn-of '(Any) 'Any)
   'nthrest    (fn-of '(Any Int) 'Any)
   'nthnext    (fn-of '(Any Int) 'Any)
   'subvec     (fn-of '(Any Int) 'Any #:rest 'Int)
   'assoc-in   (fn-of '(Any Any Any) 'Any)
   ;; --- higher-order: more -------------------------------------------------
   'map-indexed (fn-of '(Any Any) 'Any)
   'keep       (fn-of '(Any Any) 'Any)
   'keep-indexed (fn-of '(Any Any) 'Any)
   'run!       (fn-of '(Any Any) 'Nil)
