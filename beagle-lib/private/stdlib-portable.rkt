   ;; --- map / set: more operations -----------------------------------------
   'rename-keys (fn-of '(Any Any) 'Any)
   'map-keys   (fn-of '(Any Any) 'Any)
   'map-vals   (fn-of '(Any Any) 'Any)
   ;; --- regex / matching ---------------------------------------------------
   're-pattern (fn-of '(String) 'Any)
