   'dedupe     (fn-of '(Any) 'Any)
   'replace    (fn-of '(Any Any) 'Any)
   'repeatedly (fn-of '(Any) 'Any #:rest 'Any)
   ;; --- transducers --------------------------------------------------------
   'transduce  (fn-of '(Any Any Any Any) 'Any)
   'sequence   (fn-of '(Any Any) 'Any)
   'eduction   (fn-of '() 'Any #:rest 'Any)
   'completing (fn-of '(Any) 'Any #:rest 'Any)
   'halt-when  (fn-of '(Any) 'Any #:rest 'Any)
