#!/usr/bin/env bash
# beagle-op-compile: compile a beagle source file via the operative pipeline.
#
# Usage:
#   bin/beagle-op-compile [--target TARGET] <source.b*>
#
# Reads, type-checks, and emits target source to stdout. Exits non-zero
# if type errors are present (no output emitted). Target is auto-detected
# from the #lang line; --target overrides.
#
# Targets: rkt clj cljs js nix py sql

set -euo pipefail
source "$(dirname "$0")/_beagle-racket"

if [[ "${BEAGLE_EXPERIMENTAL_OPERATIVE:-}" != "1" ]]; then
    echo "beagle-op-compile: operative checker is experimental and not shipping — see ~/code/life-os/threads/20260530180100-beagle_type_system_implementation_against_v0_15_surface.md" >&2
    echo "  (set BEAGLE_EXPERIMENTAL_OPERATIVE=1 to opt in)" >&2
    exit 1
fi

target_override=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --target) target_override="$2"; shift 2 ;;
        --target=*) target_override="${1#--target=}"; shift ;;
        -h|--help)
            echo "usage: beagle-op-compile [--target TARGET] <source>" >&2
            echo "  targets: rkt clj cljs js nix py sql" >&2
            exit 0 ;;
        *) break ;;
    esac
done

if [[ $# -ne 1 ]]; then
    echo "usage: beagle-op-compile [--target TARGET] <source>" >&2
    exit 2
fi

src="$1"
if [[ ! -f "$src" ]]; then
    echo "beagle-op-compile: file not found: $src" >&2
    exit 1
fi

"$RACKET" -e "
(require beagle/private/pipeline)
(define args (current-command-line-arguments))
(define src (vector-ref args 0))
(define tgt-str (and (>= (vector-length args) 2) (vector-ref args 1)))
(define tgt (and tgt-str (not (equal? tgt-str \"\")) (string->symbol tgt-str)))
(with-handlers ([exn:fail:user?
                  (lambda (e) (eprintf \"~a~n\" (exn-message e)) (exit 1))])
  (display (compile-source src tgt)))
" -- "$src" "$target_override"
