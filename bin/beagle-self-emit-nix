#!/usr/bin/env bash
# beagle-self-emit-nix: self-hosted Nix emit pipeline.
#
# Usage:
#   bin/beagle-self-emit-nix <source.bnix>
#
# Pipeline:
#   1. Racket: parse + type-check -> JSON AST (bin/beagle-ast)
#   2. Node:   beagle-written emitter -> Nix source

set -euo pipefail

BEAGLE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$BEAGLE_ROOT/bin/_beagle-racket"

if [[ $# -ne 1 ]]; then
    echo "usage: beagle-self-emit-nix <source.bnix>" >&2
    exit 2
fi

src="$1"

if [[ ! -f "$src" ]]; then
    echo "beagle-self-emit-nix: source file not found: $src" >&2
    exit 1
fi

EMITTER="$BEAGLE_ROOT/self-host/dist/emit-nix.mjs"

if [[ ! -f "$EMITTER" ]]; then
    echo "beagle-self-emit-nix: emitter not built. Run: bin/beagle-build self-host/emit-nix.bjs" >&2
    exit 1
fi

"$BEAGLE_ROOT/bin/beagle-ast" "$src" | node "$EMITTER"
