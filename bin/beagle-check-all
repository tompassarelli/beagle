#!/usr/bin/env bash
# beagle-check-all: type-check multiple .rkt files in one process.
#
# Usage:
#   bin/beagle-check-all <file-or-dir> ...
#
# Directories are expanded to their .rkt contents. Reports all errors,
# exits 0 if all clean. Supports BEAGLE_ERROR_FORMAT=json.

set -euo pipefail
source "$(dirname "$0")/_beagle-racket"

if [[ $# -lt 1 ]]; then
    echo "usage: beagle-check-all <file-or-dir> ..." >&2
    exit 2
fi

"$RACKET" -e "(require beagle/private/check-all) (run-check-all (vector->list (current-command-line-arguments)))" -- "$@"
