#!/usr/bin/env bash
# clj-provides: list all public defs in a Clojure file (no types).
# Analog of beagle-provides for fair experiment comparison.
set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "usage: clj-provides <file.clj> ..." >&2
    exit 2
fi

for a in "$@"; do
    if [[ -d "$a" ]]; then
        files=$(find "$a" -name '*.clj' -type f)
    else
        files="$a"
    fi

    for f in $files; do
        ns=$(grep -oP '^\(ns \K\S+' "$f" 2>/dev/null | tr -d ')')
        if [[ -n "$ns" ]]; then
            echo "namespace: $ns"
            echo
        fi

        records=$(grep -oP '\(defrecord \K\S+' "$f" 2>/dev/null | sort -u)
        if [[ -n "$records" ]]; then
            echo "records:"
            echo "$records" | while read -r r; do
                fields=$(grep -oP "\(defrecord $r \K\[[^]]*\]" "$f" | head -1)
                echo "  $r $fields"
            done
            echo
        fi

        fns=$(grep -oP '\(defn \K\S+' "$f" 2>/dev/null | sort -u)
        if [[ -n "$fns" ]]; then
            echo "functions:"
            echo "$fns" | while read -r fn; do
                args=$(grep -oP "\(defn $fn \K\[[^]]*\]" "$f" | head -1)
                echo "  $fn $args"
            done
            echo
        fi

        echo
    done
done
