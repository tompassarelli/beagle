#!/usr/bin/env bb

;; Generates beagle stdlib type entries from clojure.core metadata.
;; Reads existing stdlib-types.rkt to avoid duplicating hand-tuned entries.
;; Output: Racket hash entries ready to paste into stdlib-types.rkt.

(require '[clojure.string :as str]
         '[clojure.edn :as edn])

(def existing-file (or (first *command-line-args*)
                       "private/stdlib-types.rkt"))

(def existing-names
  (->> (slurp existing-file)
       str/split-lines
       (keep (fn [line]
               (when-let [[_ nm] (re-find #"^\s+'([^\s]+)\s+" line)]
                 nm)))
       set))

(defn parse-arglist
  "Parse a Clojure arglist string like '[x y & more]' into {:fixed N :variadic? bool}"
  [s]
  (let [s (str/trim s)
        s (subs s 1 (dec (count s)))  ; strip []
        parts (str/split (str/trim s) #"\s+")
        parts (remove str/blank? parts)]
    (if (some #{"&"} parts)
      (let [fixed (count (take-while #(not= "&" %) parts))]
        {:fixed fixed :variadic? true})
      {:fixed (count parts) :variadic? false})))

(defn best-arity
  "Pick the most permissive arity from multiple arglists.
   If any is variadic, use variadic with the minimum fixed args.
   Otherwise use the maximum fixed arity."
  [arglists]
  (let [parsed (map parse-arglist arglists)
        any-variadic? (some :variadic? parsed)]
    (if any-variadic?
      (let [variadic-ones (filter :variadic? parsed)
            min-fixed (apply min (map :fixed variadic-ones))]
        {:fixed min-fixed :variadic? true})
      ;; multi-arity: use highest fixed count with variadic to cover lower arities
      (let [arities (map :fixed parsed)]
        (if (> (count (set arities)) 1)
          {:fixed (apply min arities) :variadic? true}
          {:fixed (first arities) :variadic? false})))))

(defn fn-of-str [{:keys [fixed variadic?]}]
  (let [args (str/join " " (repeat fixed "Any"))]
    (if variadic?
      (format "(fn-of '(%s) 'Any #:rest 'Any)" args)
      (format "(fn-of '(%s) 'Any)" args))))

(defn skip? [name]
  (or (contains? existing-names name)
      (str/starts-with? name "->")       ; positional factory fns
      (str/starts-with? name "map->")    ; map factory fns
      (str/starts-with? name "-")        ; internal fns
      (str/ends-with? name "'")          ; auto-promote variants (*', +', etc)
      (re-find #"^[A-Z]" name)           ; internal types
      (str/includes? name "DEPRECATED")
      (#{"agent" "agent-error" "agent-errors" "await" "await-for"
         "send" "send-off" "send-via" "set-agent-send-executor!"
         "set-agent-send-off-executor!" "release-pending-sends"
         "restart-agent" "shutdown-agents" "set-error-handler!"
         "set-error-mode!" "error-handler" "error-mode"
         "add-watch" "remove-watch"
         "pmap" "pcalls" "pvalues" "seque"
         "locking" "monitor-enter" "monitor-exit"
         "proxy-call-with-super" "proxy-super"
         "commute" "ref-set" "alter" "ensure" "ref" "dosync"
         "set-validator!" "get-validator"
         "ns-resolve" "resolve" "find-ns" "create-ns" "remove-ns"
         "the-ns" "ns-name" "ns-map" "ns-publics" "ns-imports"
         "ns-interns" "ns-refers" "ns-aliases" "ns-unmap" "ns-unalias"
         "intern" "refer" "alias" "in-ns" "require" "use" "import"
         "loaded-libs" "load" "load-file" "load-reader" "load-string"
         "compile" "gen-class" "gen-interface"
         "binding" "with-bindings" "with-bindings*" "bound-fn" "bound-fn*"
         "push-thread-bindings" "pop-thread-bindings" "get-thread-bindings"
         "thread-bound?" "bound?" "alter-var-root" "var-get" "var-set"
         "with-local-vars" "with-redefs" "with-redefs-fn"
         "supers" "bases" "class" "type"
         "eval" "macroexpand" "macroexpand-1" "special-symbol?"
         "read" "read-string" "*read-eval*" "*in*" "*out*" "*err*"
         "with-open" "with-in-str" "with-out-str"
         "print-method" "print-dup" "print-str"
         "add-classpath" "method-sig"} name)))

;; Read the dump from stdin or generate it
(def dump-str
  (let [sb (StringBuilder.)]
    (doseq [[sym v] (sort-by first (ns-publics 'clojure.core))]
      (let [m (meta v)]
        (when (and (:arglists m) (not (:macro m)))
          (.append sb (pr-str {:name (str sym)
                               :arglists (mapv str (:arglists m))})))))
    (str sb)))

;; Actually, just iterate directly
(def entries
  (->> (sort-by first (ns-publics 'clojure.core))
       (keep (fn [[sym v]]
               (let [m (meta v)
                     nm (str sym)]
                 (when (and (:arglists m)
                            (not (:macro m))
                            (not (skip? nm)))
                   (let [arity (best-arity (mapv str (:arglists m)))]
                     {:name nm :arity arity})))))
       vec))

(println (format "   ;; --- auto-generated from clojure.core metadata (%d entries) ---"
                 (count entries)))
(doseq [{:keys [name arity]} entries]
  (let [quoted (str "'" name)
        pad-width (max 16 (+ (count quoted) 1))
        padded (format (str "%-" pad-width "s") quoted)]
    (println (str "   " padded (fn-of-str arity)))))
