#!/usr/bin/env racket
#lang racket/base

;; beagle-import-nix: convert hand-written .nix to beagle/nix (.bnix).
;;
;; Strategy: pipe input through `nix-instantiate --parse` to get a
;; normalized form (Nix syntax, single-line, fully parenthesized,
;; semantically equivalent to the original). Parse that normalized form
;; into an AST. Translate to beagle/nix source. Emit.
;;
;; The normalization step buys us a much simpler parsing job —
;; `nix-instantiate --parse` handles all the messy parts (operator
;; precedence, comments, whitespace, string-vs-multiline-string,
;; etc.) before we ever see the input.
;;
;; Status: MVP. Handles attrsets, lists, function-with-formals,
;; attribute access, string literals (with interpolation), integers,
;; bools, null, identifiers, application, let, with, if-then-else,
;; inherit. Does NOT yet recognize NixOS-module shape and emit the
;; `(module ...)` macro — output is structurally equivalent raw
;; lambda + attrset. Pattern recognition is a follow-up.

(require racket/string
         racket/list
         racket/match
         racket/port
         racket/system
         racket/format
         racket/path)

;; ============================================================================
;; Driver
;; ============================================================================

(define (main argv-vec)
  (define argv (vector->list argv-vec))
  (cond
    [(or (null? argv) (member "--help" argv) (member "-h" argv))
     (display-usage)
     (exit 0)]
    [(member "--version" argv)
     (displayln "beagle-import-nix 0.1.0 (MVP)")
     (exit 0)]
    [else
     (define input-path (car argv))
     (unless (file-exists? input-path)
       (eprintf "beagle-import-nix: file not found: ~a\n" input-path)
       (exit 1))
     (define normalized (normalize-nix input-path))
     (define ast (parse-normalized normalized))
     (define ns-name (path->ns-name input-path))
     (display (emit-bnix ast ns-name))
     (newline)]))

(define (display-usage)
  (displayln "Usage: beagle-import-nix <file.nix> > file.bnix")
  (displayln "")
  (displayln "  Converts a hand-written .nix file to beagle/nix (.bnix).")
  (displayln "  Output is written to stdout.")
  (displayln "")
  (displayln "  Status: MVP. Covers common attrset/list/function/let/with shapes.")
  (displayln "  Output is semantically equivalent but may need manual cleanup to")
  (displayln "  use beagle/nix's higher-level macros (module, with-cfg, etc.)."))

(define (path->ns-name p)
  ;; Best-effort ns: derive from the file's basename, stripping .nix.
  (define name (path->string (file-name-from-path p)))
  (regexp-replace #rx"\\.nix$" name ""))

;; ============================================================================
;; Step 1: normalize via nix-instantiate --parse
;; ============================================================================

(define (normalize-nix path)
  (define-values (proc out in err)
    (subprocess #f #f (current-error-port) (find-nix-instantiate)
                "--parse" path))
  (close-output-port in)
  (define result (port->string out))
  (close-input-port out)
  (subprocess-wait proc)
  (unless (zero? (subprocess-status proc))
    (error 'beagle-import-nix
           "nix-instantiate --parse failed for ~a" path))
  result)

(define (find-nix-instantiate)
  (or (find-executable-path "nix-instantiate")
      (error 'beagle-import-nix
             "nix-instantiate not on PATH — install nix to use beagle-import-nix")))

;; ============================================================================
;; Step 2: parse normalized form into AST
;; ============================================================================
;;
;; Normalized Nix grammar (from nix-instantiate --parse output):
;;
;;   expr      = lambda | let-expr | with-expr | if-expr | apply
;;   lambda    = formals ':' expr | NAME ':' expr
;;   formals   = '{' [formal (',' formal)* [',' '...']] '}'
;;   formal    = NAME [? expr]
;;   let-expr  = 'let' bindings 'in' expr
;;   with-expr = 'with' expr ';' expr
;;   if-expr   = 'if' expr 'then' expr 'else' expr
;;   apply     = select (select)*
;;   select    = atom ('.' attr-name)*
;;   atom      = '(' expr ')' | attrset | list | string | int | bool | null | NAME
;;   attrset   = '{' bindings '}'  | 'rec' '{' bindings '}'
;;   bindings  = (binding ';')*
;;   binding   = attr-path '=' expr | 'inherit' NAME* | 'inherit' '(' expr ')' NAME*
;;   list      = '[' atom* ']'
;;   string    = '"' chars '"' | ''' chars '''
;;
;; AST node tags:
;;   ('lambda formals body)
;;   ('let bindings body)
;;   ('with scope body)
;;   ('if c t e)
;;   ('apply fn args)            — left-associative function application
;;   ('select target path)       — path is list of strings (attr names)
;;   ('attrset bindings)         — bindings is list of (binding-attrpath expr) or ('inherit ...)
;;   ('list elems)
;;   ('rec-attrset bindings)
;;   ('str-lit s)                — simple string
;;   ('str-interp parts)         — interpolated string: list of strings/exprs
;;   ('int n) ('bool b) ('null)
;;   ('id name)
;;   ('inherit names)
;;   ('inherit-from src names)

(struct tok (kind val) #:transparent)

(define (tokenize str)
  ;; Lex the normalized form. The output is single-line with spaces
  ;; between tokens — we can rely on that.
  (define len (string-length str))
  (let loop ([i 0] [acc '()])
    (cond
      [(>= i len) (reverse acc)]
      [(char-whitespace? (string-ref str i)) (loop (add1 i) acc)]
      [else
       (define ch (string-ref str i))
       (cond
         [(memv ch '(#\( #\) #\{ #\} #\[ #\] #\; #\, #\:))
          (loop (add1 i) (cons (tok 'punct (string ch)) acc))]
         [(char=? ch #\@)
          (loop (add1 i) (cons (tok 'punct "@") acc))]
         [(char=? ch #\.)
          (loop (add1 i) (cons (tok 'punct ".") acc))]
         [(char=? ch #\=)
          (cond
            [(and (< (add1 i) len) (char=? (string-ref str (add1 i)) #\=))
             (loop (+ i 2) (cons (tok 'op "==") acc))]
            [else (loop (add1 i) (cons (tok 'punct "=") acc))])]
         [(char=? ch #\?)
          ;; ? is both the has-attr operator (expr ? attr) and the
          ;; formals-default marker (name ? default). Tokenize as 'op
          ;; and let parsers check both kinds via tok-val comparison.
          (loop (add1 i) (cons (tok 'op "?") acc))]
         [(char=? ch #\+)
          (cond
            [(and (< (add1 i) len) (char=? (string-ref str (add1 i)) #\+))
             (loop (+ i 2) (cons (tok 'op "++") acc))]
            [else (loop (add1 i) (cons (tok 'op "+") acc))])]
         [(char=? ch #\!)
          (cond
            [(and (< (add1 i) len) (char=? (string-ref str (add1 i)) #\=))
             (loop (+ i 2) (cons (tok 'op "!=") acc))]
            [else (loop (add1 i) (cons (tok 'op "!") acc))])]
         [(char=? ch #\&)
          (when (or (>= (add1 i) len) (not (char=? (string-ref str (add1 i)) #\&)))
            (error 'beagle-import-nix "unexpected single & at offset ~a" i))
          (loop (+ i 2) (cons (tok 'op "&&") acc))]
         [(char=? ch #\|)
          (when (or (>= (add1 i) len) (not (char=? (string-ref str (add1 i)) #\|)))
            (error 'beagle-import-nix "unexpected single | at offset ~a" i))
          (loop (+ i 2) (cons (tok 'op "||") acc))]
         [(char=? ch #\<)
          (cond
            [(and (< (add1 i) len) (char=? (string-ref str (add1 i)) #\=))
             (loop (+ i 2) (cons (tok 'op "<=") acc))]
            [else (loop (add1 i) (cons (tok 'op "<") acc))])]
         [(char=? ch #\>)
          (cond
            [(and (< (add1 i) len) (char=? (string-ref str (add1 i)) #\=))
             (loop (+ i 2) (cons (tok 'op ">=") acc))]
            [else (loop (add1 i) (cons (tok 'op ">") acc))])]
         [(char=? ch #\*)
          (loop (add1 i) (cons (tok 'op "*") acc))]
         [(char=? ch #\/)
          ;; / is used as: path-separator, attrset-update operator (//),
          ;; or division. nix-instantiate normalizes relative paths to
          ;; absolute paths starting with /. Detect path tokens by
          ;; eating any sequence of [a-zA-Z0-9_./-] starting after the /.
          (cond
            [(and (< (add1 i) len) (char=? (string-ref str (add1 i)) #\/))
             (loop (+ i 2) (cons (tok 'op "//") acc))]
            [(and (< (add1 i) len) (path-body-char? (string-ref str (add1 i))))
             ;; Path literal: /a/b/c.nix
             (define end (find-end str i path-body-char?))
             (loop end (cons (tok 'path (substring str i end)) acc))]
            [else (loop (add1 i) (cons (tok 'op "/") acc))])]
         [(char=? ch #\-)
          (cond
            [(and (< (add1 i) len) (char=? (string-ref str (add1 i)) #\>))
             (loop (+ i 2) (cons (tok 'op "->") acc))]
            [else (loop (add1 i) (cons (tok 'op "-") acc))])]
         [(char=? ch #\")
          (define-values (parts-list next) (read-string-literal str (add1 i) #\"))
          (loop next (cons (tok 'str parts-list) acc))]
         [(char=? ch #\')
          ;; Multi-line string ''...'' — nix-instantiate --parse usually
          ;; converts these to "..." with escapes, but handle just in case.
          (define-values (parts-list next) (read-string-literal str (add1 i) #\'))
          (loop next (cons (tok 'str parts-list) acc))]
         [(or (char-numeric? ch) (and (char=? ch #\-)
                                       (< (add1 i) len)
                                       (char-numeric? (string-ref str (add1 i)))))
          (define end (find-end str i char-numeric?))
          (loop end (cons (tok 'int (substring str i end)) acc))]
         [(or (char-alphabetic? ch) (char=? ch #\_) (char=? ch #\/))
          (define end (find-end str i name-char?))
          (define name (substring str i end))
          (loop end (cons (tok 'name name) acc))]
         [else
          (error 'beagle-import-nix
                 "unexpected character '~a' at position ~a in normalized form"
                 ch i)])])))

(define (name-char? ch)
  (or (char-alphabetic? ch)
      (char-numeric? ch)
      (memv ch '(#\_ #\- #\/ #\'))))

(define (path-body-char? ch)
  ;; Characters allowed in the body of a Nix path literal after the
  ;; leading slash. Includes . since paths can have file extensions.
  (or (char-alphabetic? ch)
      (char-numeric? ch)
      (memv ch '(#\_ #\- #\. #\/))))

(define (find-end str start pred)
  (let loop ([i start])
    (cond
      [(>= i (string-length str)) i]
      [(pred (string-ref str i)) (loop (add1 i))]
      [else i])))

(define (read-string-literal str start delim)
  ;; Reads until matching delim. Returns (values parts next-index) where
  ;; parts is a list of literal-string chunks and (interp "raw-nix-substring")
  ;; entries. Escaped \${ produces a literal ${ in a string chunk; bare ${
  ;; opens an interpolation.
  (define parts-box (box '()))
  (define current (open-output-string))
  (define (flush!)
    (define s (get-output-string current))
    (when (positive? (string-length s))
      (set-box! parts-box (cons s (unbox parts-box))))
    (set! current (open-output-string)))
  (define (push-interp! s)
    (flush!)
    (set-box! parts-box (cons (list 'interp s) (unbox parts-box))))
  (let loop ([i start])
    (cond
      [(>= i (string-length str))
       (error 'beagle-import-nix "unterminated string at offset ~a" start)]
      [(char=? (string-ref str i) #\\)
       (cond
         [(>= (add1 i) (string-length str))
          (loop (add1 i))]
         [else
          (define esc (string-ref str (add1 i)))
          (case esc
            [(#\n) (write-char #\newline current) (loop (+ i 2))]
            [(#\t) (write-char #\tab current) (loop (+ i 2))]
            [(#\r) (write-char #\return current) (loop (+ i 2))]
            [(#\\) (write-char #\\ current) (loop (+ i 2))]
            [(#\") (write-char #\" current) (loop (+ i 2))]
            [(#\') (write-char #\' current) (loop (+ i 2))]
            [(#\$)
             ;; \$ → literal $. If followed by {, consume it too as
             ;; literal — preserves literal "${" sequences from source.
             (write-char #\$ current)
             (cond
               [(and (< (+ i 2) (string-length str))
                     (char=? (string-ref str (+ i 2)) #\{))
                (write-char #\{ current)
                (loop (+ i 3))]
               [else (loop (+ i 2))])]
            [else (write-char esc current) (loop (+ i 2))])])]
      [(char=? (string-ref str i) delim)
       (flush!)
       (values (reverse (unbox parts-box)) (add1 i))]
      [(and (char=? (string-ref str i) #\$)
            (< (add1 i) (string-length str))
            (char=? (string-ref str (add1 i)) #\{))
       ;; Bare ${ — opens an interpolation. Capture raw nix expr text.
       (define interp-out (open-output-string))
       (let depth-loop ([j (+ i 2)] [depth 1])
         (cond
           [(>= j (string-length str))
            (error 'beagle-import-nix "unterminated interpolation at offset ~a" i)]
           [(char=? (string-ref str j) #\{)
            (write-char #\{ interp-out)
            (depth-loop (add1 j) (add1 depth))]
           [(char=? (string-ref str j) #\})
            (define new-depth (sub1 depth))
            (cond
              [(zero? new-depth)
               (push-interp! (get-output-string interp-out))
               (loop (add1 j))]
              [else
               (write-char #\} interp-out)
               (depth-loop (add1 j) new-depth)])]
           [else
            (write-char (string-ref str j) interp-out)
            (depth-loop (add1 j) depth)]))]
      [else
       (write-char (string-ref str i) current)
       (loop (add1 i))])))


;; Parser state: mutable token cursor.
(define cursor (make-parameter #f))

(define (peek)
  (define c (cursor))
  (and (pair? c) (car c)))

(define (peek2)
  (define c (cursor))
  (and (pair? c) (pair? (cdr c)) (cadr c)))

(define (advance!)
  (define c (cursor))
  (when (null? c) (error 'beagle-import-nix "unexpected end of input"))
  (cursor (cdr c))
  (car c))

(define (expect-punct! s)
  (define t (peek))
  (unless (and t (eq? (tok-kind t) 'punct) (string=? (tok-val t) s))
    (error 'beagle-import-nix "expected '~a', got ~v" s t))
  (advance!))

(define (consume-punct? s)
  (define t (peek))
  (cond
    [(and t (eq? (tok-kind t) 'punct) (string=? (tok-val t) s))
     (advance!)
     #t]
    [else #f]))

(define (consume-name? s)
  (define t (peek))
  (cond
    [(and t (eq? (tok-kind t) 'name) (string=? (tok-val t) s))
     (advance!)
     #t]
    [else #f]))

(define (consume-op? s)
  (define t (peek))
  (cond
    [(and t (eq? (tok-kind t) 'op) (string=? (tok-val t) s))
     (advance!)
     #t]
    [else #f]))

(define (parse-normalized str)
  (parameterize ([cursor (tokenize str)])
    (define result (parse-expr))
    (unless (null? (cursor))
      (error 'beagle-import-nix
             "extra tokens after parse: ~v" (cursor)))
    result))

(define (parse-expr)
  ;; Top-level expression: lambda, let, with, if, or binary-op chain.
  ;; nix-instantiate --parse adds parens for precedence, so we can
  ;; treat all binary operators as left-associative at the same level.
  (cond
    [(consume-name? "let")
     (define bindings (parse-bindings))
     (unless (consume-name? "in")
       (error 'beagle-import-nix "expected 'in' after let bindings"))
     `(let ,bindings ,(parse-expr))]
    [(consume-name? "with")
     (define scope (parse-expr))
     (expect-punct! ";")
     `(with ,scope ,(parse-expr))]
    [(consume-name? "if")
     (define c (parse-expr))
     (unless (consume-name? "then")
       (error 'beagle-import-nix "expected 'then' in if"))
     (define t (parse-expr))
     (unless (consume-name? "else")
       (error 'beagle-import-nix "expected 'else' in if"))
     `(if ,c ,t ,(parse-expr))]
    [(lambda-ahead?)
     (parse-lambda)]
    [else
     (parse-binop)]))

(define (parse-binop)
  ;; Left-associative chain: parse-unary (OP parse-unary)*
  (let loop ([acc (parse-unary)])
    (define t (peek))
    (cond
      [(and t (eq? (tok-kind t) 'op))
       (define op (tok-val (advance!)))
       (cond
         [(string=? op "?")
          ;; Has-attr operator: expr ? attr.path → (has-attr expr [path...])
          ;; Path is dotted, parsed as sequence of attr names.
          (define path (parse-attr-path))
          (loop `(has-attr ,acc ,path))]
         [else (loop `(binop ,op ,acc ,(parse-unary)))])]
      [else acc])))

(define (parse-unary)
  ;; Prefix unary operators: ! and -. Both have higher precedence than
  ;; binary ops; nix-instantiate parens them tight when they appear.
  (define t (peek))
  (cond
    [(and t (eq? (tok-kind t) 'op)
          (or (string=? (tok-val t) "!")
              (string=? (tok-val t) "-")))
     (define op (tok-val (advance!)))
     `(unop ,op ,(parse-unary))]
    [else (parse-apply)]))

(define (lambda-ahead?)
  ;; Lookahead: detect `NAME :` or `{ formals } :` lambda shape.
  ;; nix-instantiate --parse always wraps lambdas in parens, but inside
  ;; the parens we may see `{ ... }: ...` or `name: ...`.
  (define t1 (peek))
  (define t2 (peek2))
  (cond
    [(and t1 (eq? (tok-kind t1) 'name)
          t2 (eq? (tok-kind t2) 'punct) (string=? (tok-val t2) ":"))
     #t]
    [(and t1 (eq? (tok-kind t1) 'punct) (string=? (tok-val t1) "{"))
     ;; Could be lambda or attrset. Scan to matching } and check for : after.
     (formals-then-colon?)]
    [else #f]))

(define (formals-then-colon?)
  ;; Look at tokens after current position. We're at '{'. Walk to matching
  ;; '}' and check if next token is ':' OR '@ NAME :' (for { ... } @ name: body).
  (define toks (cursor))
  (let loop ([rest (cdr toks)] [depth 1])
    (cond
      [(null? rest) #f]
      [else
       (define t (car rest))
       (cond
         [(and (eq? (tok-kind t) 'punct) (string=? (tok-val t) "{"))
          (loop (cdr rest) (add1 depth))]
         [(and (eq? (tok-kind t) 'punct) (string=? (tok-val t) "}"))
          (define new-depth (sub1 depth))
          (if (zero? new-depth)
              ;; Check : OR @ NAME : after }
              (let ([nxt (and (pair? (cdr rest)) (cadr rest))])
                (cond
                  [(and nxt (eq? (tok-kind nxt) 'punct) (string=? (tok-val nxt) ":"))
                   #t]
                  [(and nxt (eq? (tok-kind nxt) 'punct) (string=? (tok-val nxt) "@"))
                   ;; Should be @ NAME :
                   (define after-at (and (pair? (cddr rest)) (caddr rest)))
                   (define after-name (and (pair? (cdddr rest)) (cadddr rest)))
                   (and after-at (eq? (tok-kind after-at) 'name)
                        after-name (eq? (tok-kind after-name) 'punct)
                        (string=? (tok-val after-name) ":"))]
                  [else #f]))
              (loop (cdr rest) new-depth))]
         [else (loop (cdr rest) depth)])])))

(define (parse-lambda)
  (cond
    [(and (peek) (eq? (tok-kind (peek)) 'name))
     ;; NAME : body  OR  NAME @ { formals } : body  OR  { formals } @ NAME : body
     ;; (handled below for the latter; here just the bare name case)
     (define name (tok-val (advance!)))
     (cond
       [(consume-punct? "@")
        ;; name@{ formals }: body
        (expect-punct! "{")
        (define formals (parse-formals))
        (expect-punct! "}")
        (expect-punct! ":")
        `(lambda (formals-at ,(string->symbol name) ,formals before) ,(parse-expr))]
       [else
        (expect-punct! ":")
        `(lambda (single ,(string->symbol name)) ,(parse-expr))])]
    [else
     ;; { formals } : body  OR  { formals } @ name : body
     (expect-punct! "{")
     (define formals (parse-formals))
     (expect-punct! "}")
     (cond
       [(consume-punct? "@")
        (define alias-tok (advance!))
        (unless (eq? (tok-kind alias-tok) 'name)
          (error 'beagle-import-nix "@ lambda: expected name after @"))
        (expect-punct! ":")
        `(lambda (formals-at ,(string->symbol (tok-val alias-tok)) ,formals after) ,(parse-expr))]
       [else
        (expect-punct! ":")
        `(lambda (formals ,formals) ,(parse-expr))])]))

(define (parse-formals)
  ;; Comma-separated NAME [? default], optionally ending with `...`.
  (let loop ([acc '()] [ellipsis? #f])
    (cond
      [(consume-punct? ".")
       (expect-punct! ".")
       (expect-punct! ".")
       (loop acc #t)]
      [(and (peek) (eq? (tok-kind (peek)) 'name))
       (define name (tok-val (advance!)))
       (define default
         (cond
           [(consume-op? "?") (parse-expr)]
           [else #f]))
       (define new-acc (cons (list (string->symbol name) default) acc))
       (cond
         [(consume-punct? ",") (loop new-acc ellipsis?)]
         [else (list (reverse new-acc) ellipsis?)])]
      [else
       (list (reverse acc) ellipsis?)])))

(define (parse-apply)
  (define first (parse-select))
  (let loop ([acc first])
    (cond
      [(application-can-continue?)
       (loop `(apply ,acc ,(parse-select)))]
      [else acc])))

(define (application-can-continue?)
  ;; Continue applying if the next token starts an atom AND we're not
  ;; at a punctuation that would end the expression.
  (define t (peek))
  (and t
       (case (tok-kind t)
         [(name) (not (member (tok-val t)
                              '("then" "else" "in" "with"
                                "let" "if" "inherit")))]
         [(int str path) #t]
         [(punct) (member (tok-val t) '("(" "{" "["))]
         [else #f])))

(define (parse-select)
  (define base (parse-atom))
  (let loop ([target base] [path '()])
    (cond
      [(consume-punct? ".")
       (define seg (parse-attr-name))
       (loop target (cons seg path))]
      [(consume-name? "or")
       ;; Default-value-on-attr-access: target.a.b or default →
       ;; (select-or target [path...] default)
       (define default-expr (parse-atom))
       (define new-target
         (if (null? path)
             `(binop "or" ,target ,default-expr)
             `(select-or ,target ,(reverse path) ,default-expr)))
       (loop new-target '())]
      [else
       (if (null? path)
           target
           `(select ,target ,(reverse path)))])))

(define (parse-attr-name)
  ;; Attr names can be plain identifiers, quoted strings, integers
  ;; (services.foo.9090 etc), or ${...}.
  (define t (advance!))
  (case (tok-kind t)
    [(name) (tok-val t)]
    [(str)  (list 'str (tok-val t))]
    [(int)  (tok-val t)]
    [else (error 'beagle-import-nix "expected attr name, got ~v" t)]))

(define (parse-atom)
  (define t (peek))
  (unless t (error 'beagle-import-nix "unexpected end of input in atom"))
  (case (tok-kind t)
    [(punct)
     (cond
       [(string=? (tok-val t) "(")
        (advance!)
        (define e (parse-expr))
        (expect-punct! ")")
        e]
       [(string=? (tok-val t) "{")
        (parse-attrset)]
       [(string=? (tok-val t) "[")
        (parse-list)]
       [else (error 'beagle-import-nix "unexpected punct '~a'" (tok-val t))])]
    [(name)
     (cond
       [(or (string=? (tok-val t) "true") (string=? (tok-val t) "false"))
        (advance!)
        `(bool ,(string=? (tok-val t) "true"))]
       [(string=? (tok-val t) "null")
        (advance!)
        '(null)]
       [(string=? (tok-val t) "rec")
        (advance!)
        (define inner (parse-atom))
        (match inner
          [(list 'attrset bindings) (list 'rec-attrset bindings)]
          [_ (error 'beagle-import-nix "rec must be followed by attrset")])]
       [else
        (advance!)
        `(id ,(string->symbol (tok-val t)))])]
    [(int)
     (advance!)
     `(int ,(string->number (tok-val t)))]
    [(path)
     (advance!)
     `(path ,(tok-val t))]
    [(str)
     (advance!)
     (parse-string-literal (tok-val t))]
    [else (error 'beagle-import-nix "unexpected token in atom: ~v" t)]))

(define (parse-attrset)
  (expect-punct! "{")
  (define bindings (parse-bindings))
  (expect-punct! "}")
  `(attrset ,bindings))

(define (parse-bindings)
  (let loop ([acc '()])
    (cond
      [(or (let ([t (peek)])
             (and t (eq? (tok-kind t) 'punct)
                  (member (tok-val t) '("}" "in"))))
           (let ([t (peek)])
             (and t (eq? (tok-kind t) 'name) (string=? (tok-val t) "in"))))
       (reverse acc)]
      [(consume-name? "inherit")
       (cond
         [(consume-punct? "(")
          (define src (parse-expr))
          (expect-punct! ")")
          (define names (parse-inherit-names))
          (expect-punct! ";")
          (loop (cons `(inherit-from ,src ,names) acc))]
         [else
          (define names (parse-inherit-names))
          (expect-punct! ";")
          (loop (cons `(inherit ,names) acc))])]
      [else
       (define path (parse-attr-path))
       (expect-punct! "=")
       (define val (parse-expr))
       (expect-punct! ";")
       (loop (cons `(bind ,path ,val) acc))])))

(define (parse-inherit-names)
  (let loop ([acc '()])
    (define t (peek))
    (cond
      [(and t (eq? (tok-kind t) 'name)
            (not (member (tok-val t) '("inherit"))))
       (advance!)
       (loop (cons (string->symbol (tok-val t)) acc))]
      [(and t (eq? (tok-kind t) 'str))
       (advance!)
       (loop (cons (tok-val t) acc))]
      [else (reverse acc)])))

(define (parse-attr-path)
  (let loop ([acc (list (parse-attr-name))])
    (cond
      [(consume-punct? ".") (loop (cons (parse-attr-name) acc))]
      [else (reverse acc)])))

(define (parse-list)
  (expect-punct! "[")
  (let loop ([acc '()])
    (cond
      [(consume-punct? "]") `(list ,(reverse acc))]
      [else (loop (cons (parse-atom) acc))])))

(define (parse-string-literal parts-list)
  ;; parts-list comes from read-string-literal: a list of literal-string
  ;; chunks and (interp "raw-nix") entries. Literal "${" sequences from
  ;; \${ in source are baked into the literal chunks (NOT in interp
  ;; entries) — so we can trust the structure.
  (cond
    [(and (= (length parts-list) 1) (string? (car parts-list)))
     `(str-lit ,(car parts-list))]
    [(null? parts-list)
     `(str-lit "")]
    [else
     `(str-interp ,parts-list)]))

(define (split-on-interp s)
  ;; Returns alternating string-lit and expr-substr chunks. expr-substr
  ;; is wrapped as (interp "literal nix substring").
  (let loop ([i 0] [acc '()])
    (cond
      [(>= i (string-length s))
       (reverse acc)]
      [else
       (define dollar (regexp-match-positions #rx"\\$\\{" s i))
       (cond
         [(not dollar)
          (reverse (cons (substring s i) acc))]
         [else
          (define start (car (car dollar)))
          (define before (substring s i start))
          (define-values (expr-str next)
            (read-interp-expr s (+ start 2)))
          (define new-acc
            (cons `(interp ,expr-str) (if (zero? (string-length before))
                                          acc
                                          (cons before acc))))
          (loop next new-acc)])])))

(define (read-interp-expr s start)
  ;; Read until matching close-brace, respecting nesting.
  (let loop ([i start] [depth 1] [out (open-output-string)])
    (cond
      [(>= i (string-length s))
       (error 'beagle-import-nix "unterminated interpolation")]
      [(char=? (string-ref s i) #\{)
       (write-char #\{ out)
       (loop (add1 i) (add1 depth) out)]
      [(char=? (string-ref s i) #\})
       (define new-depth (sub1 depth))
       (cond
         [(zero? new-depth)
          (values (get-output-string out) (add1 i))]
         [else
          (write-char #\} out)
          (loop (add1 i) new-depth out)])]
      [else
       (write-char (string-ref s i) out)
       (loop (add1 i) depth out)])))

;; ============================================================================
;; Step 3: emit beagle/nix
;; ============================================================================

(define (emit-bnix ast ns-name)
  (string-append
    "#lang beagle/nix\n"
    "(ns " (sanitize-ns ns-name) ")\n"
    "\n"
    (emit-expr ast 0)))

(define (sanitize-ns s)
  (regexp-replace* #rx"[^a-zA-Z0-9._-]" s "-"))

(define (indent n) (make-string (* n 2) #\space))

(define (emit-expr ast depth)
  (match ast
    [(list 'lambda kind body)
     (emit-lambda kind body depth)]
    [(list 'let bindings body)
     (emit-let bindings body depth)]
    [(list 'with scope body)
     (format "(with ~a\n~a~a)"
             (emit-expr scope depth)
             (indent (add1 depth))
             (emit-expr body (add1 depth)))]
    [(list 'if c t e)
     (format "(if ~a ~a ~a)"
             (emit-expr c depth)
             (emit-expr t depth)
             (emit-expr e depth))]
    [(list 'apply fn arg)
     (define args (collect-apply-args ast))
     (format "(~a ~a)"
             (emit-expr (car args) depth)
             (string-join (map (λ (a) (emit-expr a depth)) (cdr args)) " "))]
    [(list 'binop op lhs rhs)
     (emit-binop op lhs rhs depth)]
    [(list 'unop "!" arg)
     (format "(not ~a)" (emit-expr arg depth))]
    [(list 'unop "-" arg)
     (format "(- ~a)" (emit-expr arg depth))]
    [(list 'has-attr target path)
     ;; (has? target [path...]) — beagle uses has? for attr-presence
     (format "(has? ~a ~a)"
             (emit-expr target depth)
             (string-join
               (map (λ (s) (if (string? s) (format ":~a" s) (format "~v" (cadr s)))) path)
               " "))]
    [(list 'select target path)
     (emit-select target path depth)]
    [(list 'select-or target path default)
     ;; beagle/nix's (get-or base attr-symbol default) handles single-
     ;; attribute access with default. For multi-segment paths
     ;; (a.b.c or default), nest: chain the inner accesses statically
     ;; and apply get-or to only the OUTERMOST segment, because that's
     ;; where the default kicks in semantically (Nix's `a.b.c or X`
     ;; means "try the full path; if any segment missing, X").
     ;;
     ;; In practice, multi-segment-with-or is rare; single-segment
     ;; dominates. For multi-segment we still produce semantically
     ;; correct beagle by emitting nested get-or on the final segment
     ;; with intermediate plain attr access.
     (cond
       [(= (length path) 1)
        (define attr-str
          (let ([s (car path)])
            (cond [(string? s) s]
                  [else (cadr s)])))
        (format "(get-or ~a ~a ~a)"
                (emit-expr target depth) attr-str (emit-expr default depth))]
       [else
        ;; Multi-segment: target.a.b.c or default → access target.a.b
        ;; statically, then get-or on .c with default.
        (define prefix (drop-right path 1))
        (define last-seg (last path))
        (define prefix-target `(select ,target ,prefix))
        (define last-attr-str
          (cond [(string? last-seg) last-seg]
                [else (cadr last-seg)]))
        (format "(get-or ~a ~a ~a)"
                (emit-expr prefix-target depth)
                last-attr-str
                (emit-expr default depth))])]
    [(list 'attrset bindings)
     (emit-attrset bindings depth)]
    [(list 'rec-attrset bindings)
     (string-append "; rec attrset not yet supported, emitting plain attrset\n"
                    (emit-attrset bindings depth))]
    [(list 'list elems)
     (format "[~a]"
             (string-join (map (λ (e) (emit-expr e depth)) elems) " "))]
    [(list 'str-lit s)
     ;; Escape literal ${ → $${ so beagle's emit-nix emits \${ in the
     ;; output Nix (preserves the literal-not-interpolation property).
     (format "~v" (escape-literal-dollars s))]
    [(list 'path p)
     ;; Nix path literal. beagle/nix's (p "...") form emits as a Nix
     ;; path. nix-instantiate normalizes relative paths to absolute,
     ;; so we just preserve the absolute path as-is.
     (format "(p ~v)" p)]
    [(list 'str-interp parts)
     (emit-str-interp parts depth)]
    [(list 'int n)
     (number->string n)]
    [(list 'bool b)
     (if b "true" "false")]
    [(list 'null)
     "nil"]
    [(list 'id name)
     (symbol->string name)]
    [_ (format "; unhandled: ~v" ast)]))

(define (collect-apply-args ast)
  ;; (apply (apply (apply f a) b) c) → (f a b c)
  (let loop ([e ast] [args '()])
    (match e
      [(list 'apply fn arg) (loop fn (cons arg args))]
      [_ (cons e args)])))

(define (emit-binop op lhs rhs depth)
  ;; Map Nix binary operators to beagle/nix call forms. String concat
  ;; (+) uses (s ...); arithmetic + uses (+ ...); attrset merge (//)
  ;; uses (// ...) or a stdlib helper.
  (case op
    [("+")
     ;; Flatten nested + chains: (binop + (binop + a b) c) → (s a b c).
     ;; Then MERGE consecutive string-literal args into one literal
     ;; (with ${ escaped) so beagle's emit doesn't produce
     ;; "${THEMES[@]}" — i.e. consecutive Nix strings concat'd at the
     ;; source become a single literal that's safely escaped.
     (define raw-args (flatten-plus-chain `(binop ,op ,lhs ,rhs)))
     (define merged (merge-consecutive-string-lits raw-args))
     (format "(s ~a)"
             (string-join (map (λ (a) (emit-expr a depth)) merged) " "))]
    [else
     (define lhs-str (emit-expr lhs depth))
     (define rhs-str (emit-expr rhs depth))
     (case op
       [("-")  (format "(- ~a ~a)" lhs-str rhs-str)]
       [("*")  (format "(* ~a ~a)" lhs-str rhs-str)]
       [("/")  (format "(/ ~a ~a)" lhs-str rhs-str)]
       [("++") (format "(++ ~a ~a)" lhs-str rhs-str)]
       [("//") (format "(// ~a ~a)" lhs-str rhs-str)]
       [("==") (format "(== ~a ~a)" lhs-str rhs-str)]
       [("!=") (format "(!= ~a ~a)" lhs-str rhs-str)]
       [("<")  (format "(< ~a ~a)" lhs-str rhs-str)]
       [(">")  (format "(> ~a ~a)" lhs-str rhs-str)]
       [("<=") (format "(<= ~a ~a)" lhs-str rhs-str)]
       [(">=") (format "(>= ~a ~a)" lhs-str rhs-str)]
       [("&&") (format "(and ~a ~a)" lhs-str rhs-str)]
       [("||") (format "(or ~a ~a)" lhs-str rhs-str)]
       [("->") (format "(implies ~a ~a)" lhs-str rhs-str)]
       [("!")  (format "(not ~a)" lhs-str)]
       [else   (format "; unsupported op ~a\n  (~a ~a ~a)" op op lhs-str rhs-str)])]))

(define (flatten-plus-chain ast)
  ;; Walk a (binop "+" lhs rhs) tree left-associatively, flattening
  ;; into a list of operand exprs. (binop "+" (binop "+" a b) c) → (a b c).
  (match ast
    [(list 'binop "+" lhs rhs)
     (append (flatten-plus-chain lhs) (flatten-plus-chain rhs))]
    [_ (list ast)]))

(define (merge-consecutive-string-lits args)
  ;; Walk a list of args. Consecutive (str-lit s) entries get merged
  ;; into a single (str-lit "concat"). The merged string has any
  ;; literal ${ escaped so beagle's emit-nix produces \${ in output
  ;; rather than leaving an unintended Nix interpolation.
  (let loop ([rest args] [acc '()] [pending #f])
    (cond
      [(null? rest)
       (reverse (if pending (cons `(str-lit ,pending) acc) acc))]
      [else
       (define a (car rest))
       (cond
         [(and (pair? a) (eq? (car a) 'str-lit) (string? (cadr a)))
          (loop (cdr rest) acc
                (if pending
                    (string-append pending (cadr a))
                    (cadr a)))]
         [else
          (define new-acc (if pending (cons `(str-lit ,pending) acc) acc))
          (loop (cdr rest) (cons a new-acc) #f)])])))

(define (emit-lambda kind body depth)
  (match kind
    [(list 'single name)
     ;; Single-arg bare lambda: x: body → (fn [x] body) which beagle emits
     ;; as `x: body`. (fn-set ...) would emit `{ x }: body` which is the
     ;; FORMALS shape — semantically different.
     (format "(fn [~a] ~a)" name (emit-expr body depth))]
    [(list 'formals (list args ellipsis?))
     (define names (map (λ (p) (symbol->string (car p))) args))
     ;; Use (fn-set ...) for round-trip fidelity: ellipsis is preserved
     ;; only when present in the original. (module [args]) always
     ;; implies ellipsis which over-translates.
     (define args-str
       (cond [ellipsis? (string-append (string-join names " ") " ...")]
             [else (string-join names " ")]))
     (format "(fn-set (~a)\n~a~a)"
             args-str
             (indent (add1 depth))
             (emit-expr body (add1 depth)))]
    [(list 'formals-at alias (list args ellipsis?) _position)
     ;; { args, ... }@alias: body  →  module-with-alias.
     ;; beagle has no direct equivalent of @-alias; emit as a let-bound
     ;; alias = (module-args-as-attrset). Functionally equivalent.
     (define names (map (λ (p) (symbol->string (car p))) args))
     (format "(module [~a]\n~a;; @-alias `~a` flattened — original referenced the full attrset~n~a(let [~a {~a}]~n~a~a))"
             (string-join names " ")
             (indent (add1 depth))
             alias
             (indent (add1 depth))
             alias
             (string-join (map (λ (n) (format ":~a ~a" n n)) names) " ")
             (indent (+ depth 2))
             (emit-expr body (+ depth 2)))]))

(define (emit-let bindings body depth)
  ;; Expand inherit/inherit-from into explicit name=value bindings,
  ;; same as emit-attrset does.
  (define expanded
    (apply append
           (map (λ (b)
                  (match b
                    [(list 'inherit names)
                     (map (λ (n) (list 'bind (list (symbol->string n)) `(id ,n))) names)]
                    [(list 'inherit-from src names)
                     (map (λ (n)
                            (list 'bind (list (symbol->string n))
                                  `(select ,src (,(symbol->string n)))))
                          names)]
                    [_ (list b)]))
                bindings)))
  (format "(let [~a]\n~a~a)"
          (string-join
            (map (λ (b)
                   (match b
                     [(list 'bind (list path) val)
                      (define name-str
                        (cond
                          [(string? path) path]
                          [(pair? path) (cadr path)] ; (str s) → s
                          [else (format "~v" path)]))
                     (format "~a ~a" name-str (emit-expr val depth))]
                     [_ (format "; unsupported let binding: ~v" b)]))
                 expanded)
            "\n        ")
          (indent (add1 depth))
          (emit-expr body (add1 depth))))

(define (emit-select target path depth)
  ;; Static dotted access: target.a.b.c → target.a.b.c
  ;; Dynamic segments (from ${expr} in source) need (get target key-expr).
  ;; Non-identifier targets (e.g. parenthesized applications) need
  ;; (.attr target) method-call shape because beagle's dotted syntax
  ;; only works on identifier prefixes.
  (define base-str (emit-expr target depth))
  (define target-is-id?
    (and (pair? target)
         (or (eq? (car target) 'id)
             (eq? (car target) 'select))))
  (let loop ([acc-expr-str base-str] [segs path] [first-step? #t])
    (cond
      [(null? segs) acc-expr-str]
      [else
       (define seg (car segs))
       (cond
         [(and (pair? seg) (eq? (car seg) 'str) (pair? (cadr seg))
               (= (length (cadr seg)) 1) (pair? (caadr seg))
               (eq? (car (caadr seg)) 'interp))
          ;; Single-interp string key
          (define key-expr (emit-interp-expr (cadr (caadr seg))))
          (loop (format "(get ~a ~a)" acc-expr-str key-expr)
                (cdr segs) #f)]
         [else
          ;; Collect consecutive static segments and emit as dotted.
          (define-values (static-run rest)
            (let inner ([s (cons seg (cdr segs))] [out '()])
              (cond
                [(null? s) (values (reverse out) '())]
                [(static-seg? (car s))
                 (inner (cdr s) (cons (car s) out))]
                [else (values (reverse out) s)])))
          (cond
            [(null? static-run) (loop acc-expr-str (cdr segs) #f)]
            [else
             (define dotted
               (string-join
                 (map (λ (s) (if (string? s) s (format "~v" (cadr s)))) static-run)
                 "."))
             (define new-acc
               (cond
                 [(and first-step? (not target-is-id?))
                  ;; (complex-expr).a.b.c → method-call shape so
                  ;; beagle/nix can emit it. First static seg becomes
                  ;; (.a complex-expr); remaining segs append dotted.
                  (define first-seg (car static-run))
                  (define rest-segs (cdr static-run))
                  (define first-str
                    (cond [(string? first-seg) first-seg]
                          [else (format "~v" (cadr first-seg))]))
                  (define base-call (format "(.~a ~a)" first-str acc-expr-str))
                  (cond
                    [(null? rest-segs) base-call]
                    [else
                     (format "~a.~a" base-call
                             (string-join
                               (map (λ (s) (if (string? s) s (format "~v" (cadr s)))) rest-segs)
                               "."))])]
                 [else (format "~a.~a" acc-expr-str dotted)]))
             (loop new-acc rest #f)])])])))

(define (static-seg? seg)
  (or (string? seg)
      (and (pair? seg) (eq? (car seg) 'str) (string? (cadr seg)))))

(define (emit-attrset bindings depth)
  (cond
    [(null? bindings) "{}"]
    [else
     ;; beagle/nix supports (inherit ...) and (inherit-from ...) as
     ;; singleton items inside a {...} attrset; emit them directly
     ;; for round-trip fidelity rather than expanding into explicit
     ;; key/value bindings.
     (string-append
       "{"
       (string-join
         (map (λ (b) (emit-binding b (add1 depth))) bindings)
         (string-append "\n" (indent (add1 depth))))
       "}")]))

(define (emit-binding b depth)
  (match b
    [(list 'bind path val)
     (define key (emit-binding-key path))
     (format "~a ~a" key (emit-expr val depth))]
    [(list 'inherit names)
     (format "(inherit ~a)"
             (string-join (map symbol->string names) " "))]
    [(list 'inherit-from src names)
     (format "(inherit-from ~a ~a)"
             (emit-expr src depth)
             (string-join (map symbol->string names) " "))]))

(define (emit-binding-key path)
  ;; Emit an attrset key. Handle the canonical idioms:
  ;;   - single bare name → :name
  ;;   - dotted path → :a.b.c
  ;;   - string key with single (interp "ident") → bare ident
  ;;     (matches idiomatic Nix attrset key shape; normalizes without
  ;;     paren-wrapping)
  ;;   - other quoted string → "string-content"
  (cond
    [(= (length path) 1)
     (match (car path)
       [(? string? s) (format ":~a" s)]
       [(list 'str parts-list)
        (cond
          [(simple-ident-interp-parts? parts-list)
           (extract-ident-interp-parts parts-list)]
          [else
           (format "~v" (parts-list->raw-string parts-list))])])]
    [else
     ;; Dotted path: emit as :a.b.c form
     (string-append ":"
                    (string-join
                      (map (λ (s)
                             (cond
                               [(string? s) s]
                               [else (format "~v" (parts-list->raw-string (cadr s)))]))
                           path)
                      "."))]))

(define (simple-ident-interp-parts? parts-list)
  ;; Single (interp "ident") with a bare-identifier expression.
  (and (= (length parts-list) 1)
       (let ([p (car parts-list)])
         (and (pair? p) (eq? (car p) 'interp)
              (regexp-match-exact? #rx"[a-zA-Z_][a-zA-Z0-9_-]*" (cadr p))))))

(define (extract-ident-interp-parts parts-list)
  (cadr (car parts-list)))

(define (parts-list->raw-string parts-list)
  ;; Concatenate parts back into a single string with ${...} interp
  ;; markers. Used for cases where we have no better representation.
  (apply string-append
         (map (λ (p) (if (string? p) p (format "${~a}" (cadr p))))
              parts-list)))

(define (emit-str-interp parts depth)
  ;; parts: list of strings and (interp "raw-nix") entries.
  ;;
  ;; Emit as beagle's (s ...) form. For each interp:
  ;;   - Simple dotted identifier (e.g. "pkgs.foo", "config.bar.baz"):
  ;;     emit as bare symbol. Beagle's emit-nix renders as ${pkgs.foo}.
  ;;   - Complex expression (function calls, operators, nested):
  ;;     emit the string with literal ${...} markers via an opaque
  ;;     beagle string-with-interp-escape. Beagle's string handling
  ;;     preserves the ${...} verbatim in the output Nix.
  (cond
    [(and (= (length parts) 1) (string? (car parts)))
     (format "~v" (escape-literal-dollars (car parts)))]
    [else
     (define s-args
       (map (λ (p)
              (match p
                [(? string? s)
                 (format "~v" (escape-literal-dollars s))]
                [(list 'interp nix-expr)
                 (emit-interp-expr nix-expr)]))
            parts))
     (format "(s ~a)" (string-join s-args " "))]))

(define (escape-literal-dollars s)
  ;; In a beagle string, "$${...}" is the Nix-style way to mark a literal
  ;; "${..." (beagle's emit-nix turns "$$" into "$\$" which Nix parses
  ;; as literal "$"). Source strings here have already been processed
  ;; through read-string-literal which folded \${ into literal ${ in
  ;; string chunks. We need to re-escape those so beagle emits them as
  ;; literal in the .nix output.
  (regexp-replace* #rx"\\$\\{" s "$${"))

(define (emit-interp-expr nix-expr)
  ;; nix-expr is a raw substring of normalized Nix from inside a ${...}.
  ;; Strategy:
  ;;   - simple identifier or dotted-id: emit as bare symbol
  ;;   - anything else: recursively tokenize and parse as a beagle/nix
  ;;     expression. If parse succeeds, emit. If it fails, fall back to
  ;;     opaque ${...} preservation via $$ escape.
  (define trimmed (string-trim nix-expr))
  (cond
    [(regexp-match-exact? #rx"[a-zA-Z_][a-zA-Z0-9_-]*(\\.[a-zA-Z_][a-zA-Z0-9_'-]*)*" trimmed)
     trimmed]
    [else
     ;; Try recursive parse using my own tokenizer/parser on the
     ;; substring. The interp text is already in normalized form so
     ;; my parser handles the same grammar.
     (define parsed
       (with-handlers ([exn:fail? (lambda (_) #f)])
         (parameterize ([cursor (tokenize trimmed)])
           (parse-expr))))
     (cond
       [parsed (emit-expr parsed 0)]
       [else
        ;; Fallback: opaque preservation
        (format "~v" (format "$${~a}" trimmed))])]))

;; ============================================================================
;; Entry point
;; ============================================================================

(main (current-command-line-arguments))
