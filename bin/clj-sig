#!/usr/bin/env bash
# clj-sig: show a Clojure function's signature (arg list, no types).
# Analog of beagle-sig for fair experiment comparison.
set -euo pipefail

if [[ $# -lt 2 ]]; then
    echo "usage: clj-sig <fn-name> <file-or-dir> ..." >&2
    exit 2
fi

name="$1"; shift

for a in "$@"; do
    if [[ -d "$a" ]]; then
        files=$(find "$a" -name '*.clj' -type f)
    else
        files="$a"
    fi

    for f in $files; do
        # Match defn with optional metadata prefix
        grep -n "(defn $name " "$f" 2>/dev/null | while IFS=: read -r lineno content; do
            args=$(echo "$content" | grep -oP '\(defn '"$name"' \K\[[^]]*\]')
            if [[ -n "$args" ]]; then
                echo "$name $args  ($f:$lineno)"
            fi
        done
    done
done
