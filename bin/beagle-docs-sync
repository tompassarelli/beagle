#!/usr/bin/env bash
set -euo pipefail

# Propagate mechanical facts from the codebase into documentation.
# Run after any change that affects test count, stdlib size, experiment
# count, or version. Safe to run repeatedly (idempotent).

BEAGLE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$BEAGLE_DIR"

DRY_RUN=false
VERBOSE=false
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --verbose) VERBOSE=true ;;
    --help|-h)
      echo "Usage: beagle-docs-sync [--dry-run] [--verbose]"
      echo "Propagate codebase facts (test count, stdlib size, etc.) into docs."
      exit 0 ;;
  esac
done

CHANGES=0

update_in_file() {
  local file="$1" old_pat="$2" new_text="$3" label="$4"
  if [ ! -f "$file" ]; then return; fi
  if grep -qE "$old_pat" "$file" 2>/dev/null; then
    local current
    current=$(grep -oE "$old_pat" "$file" | head -1)
    if [ "$current" != "$new_text" ]; then
      if $DRY_RUN; then
        echo "  WOULD: $file: $label: $current -> $new_text"
      else
        sed -i "s|${current}|${new_text}|g" "$file"
        echo "  UPDATE: $file: $label: $current -> $new_text"
      fi
      CHANGES=$((CHANGES + 1))
    elif $VERBOSE; then
      echo "  OK: $file: $label ($current)"
    fi
  elif $VERBOSE; then
    echo "  SKIP: $file: pattern not found for $label"
  fi
}

# --- Regenerate cheatsheets from Scribble ------------------------------------

echo "Regenerating cheatsheets from Scribble..."
if [ -x "$BEAGLE_DIR/bin/beagle-gen-cheatsheet" ]; then
  if $DRY_RUN; then
    "$BEAGLE_DIR/bin/beagle-gen-cheatsheet" --dry-run
  else
    "$BEAGLE_DIR/bin/beagle-gen-cheatsheet"
  fi
else
  echo "  SKIP: bin/beagle-gen-cheatsheet not found"
fi

echo ""

# --- Collect facts -----------------------------------------------------------

echo "Collecting facts..."

# Test count: raco test reports actual test-case count
TEST_COUNT=$(raco test beagle-test/tests/ 2>&1 | grep -oP '\d+(?= tests passed)' || echo "0")
echo "  tests: $TEST_COUNT"

# Stdlib function count (sum across portable + clj + cljs hash definitions only)
STDLIB_COUNT=$(python3 -c "
import re
total = 0
for path, marker in [('beagle-lib/private/stdlib-portable.rkt', 'STDLIB-PORTABLE'),
                     ('beagle-lib/private/stdlib-clj.rkt', 'STDLIB-CLJ'),
                     ('beagle-lib/private/stdlib-cljs.rkt', 'STDLIB-CLJS')]:
    with open(path) as f:
        content = f.read()
    start = content.find('(define ' + marker)
    if start < 0: continue
    # find matching close — count parens from the (hash
    depth = 0
    section = ''
    for c in content[start:]:
        if c == '(': depth += 1
        elif c == ')': depth -= 1
        section += c
        if depth == 0: break
    keys = re.findall(r\"^   '([a-zA-Z./*<>=!?+-][a-zA-Z0-9./*<>=!?+-]*)\", section, re.MULTILINE)
    total += len(keys)
print(total)
" 2>/dev/null || echo "0")
echo "  stdlib: $STDLIB_COUNT"

# Devlog count
DEVLOG_COUNT=$(ls docs/devlog/[0-9]*.md 2>/dev/null | wc -l)
echo "  devlog entries: $DEVLOG_COUNT"

# Canonical types: Int Float Bool String Nil Any Keyword Symbol
# Deprecated aliases that should not appear in docs as Beagle types:
DEPRECATED_TYPES="Long|Double|Boolean|Integer"

# Check for stale type references in docs
# Exclude lines that explain the alias resolution (e.g. "Long → Int", "resolve to Int")
STALE_FILES=""
for f in docs/cheatsheet.md docs/cheatsheet-consumer.md \
         README.md CLAUDE.md AGENTS.md; do
  if [ -f "$f" ]; then
    if grep -Pn "(?<![/.])\b($DEPRECATED_TYPES)\b(?!/)" "$f" \
       | grep -v 'Long/\|Double/\|Boolean/\|Integer/' \
       | grep -v "resolve to\|sugar\|JVM names\|CLJ-ALIASES\|accepted as\|compatibility\|don't appear\|Don't add\|removed by" \
       | grep -qv '^\s*#'; then
      STALE_FILES="$STALE_FILES $f"
    fi
  fi
done
if [ -n "$STALE_FILES" ]; then
  echo "  WARNING: stale type names (Long/Double/Boolean) in:$STALE_FILES"
  echo "  Canonical types are: Int Float Bool String Nil Any Keyword Symbol Number"
else
  echo "  type names: consistent"
fi

# --- Update files ------------------------------------------------------------

echo ""
echo "Propagating..."

# Test count: "N tests" pattern
for f in CLAUDE.md AGENTS.md README.md docs/todo.md; do
  update_in_file "$f" "[0-9]+ tests" "$TEST_COUNT tests" "test count"
  update_in_file "$f" "[0-9]+-test" "$TEST_COUNT-test" "test count (hyphenated)"
done

# Stdlib count: various patterns across docs
for f in CLAUDE.md README.md docs/cheatsheet.md; do
  update_in_file "$f" "~[0-9]+ Clojure functions" "~$STDLIB_COUNT Clojure functions" "stdlib count"
  update_in_file "$f" "~[0-9]+ functions\)" "~$STDLIB_COUNT functions)" "stdlib count (parens)"
  update_in_file "$f" "~[0-9]+ entries total" "~$STDLIB_COUNT entries total" "stdlib entries total"
done

# Devlog count (pattern must not match "352 entries" in stdlib table)
update_in_file "README.md" "journal \\([0-9]+ entries\\)" "journal ($DEVLOG_COUNT entries)" "devlog count"

# Stdlib count in AGENTS.md file map
update_in_file "AGENTS.md" "~[0-9]+ pre-typed" "~$STDLIB_COUNT pre-typed" "stdlib count"

echo ""
if [ $CHANGES -eq 0 ]; then
  echo "All docs up to date."
else
  if $DRY_RUN; then
    echo "$CHANGES update(s) would be applied. Run without --dry-run to apply."
  else
    echo "$CHANGES update(s) applied."
  fi
fi
