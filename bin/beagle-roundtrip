#!/usr/bin/env bash
# beagle-roundtrip: the facts source-of-truth gate.
#
#   bin/beagle-roundtrip <file-or-dir> ...      # datum<->facts gate + text-is-a-view
#   bin/beagle-roundtrip --emit-edn <file>      # reader-level facts as EDN (for Fram)
#   bin/beagle-roundtrip --verify <edn> <src>   # verify EDN reconstructs <src>
#
# Proves a beagle program round-trips through its CNF fact graph losslessly:
# the graph is a source of truth; text is a regenerable view.
set -o pipefail
source "$(dirname "$0")/_beagle-racket"
exec "$RACKET" "$(dirname "$0")/../beagle-lib/private/facts-roundtrip.rkt" "$@"
