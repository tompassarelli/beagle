#!/usr/bin/env bash
# beagle-build-all: compile multiple .rkt files to Clojure in one process.
#
# Usage:
#   bin/beagle-build-all <file-or-dir> ... [--out <dir>] [--warn]
#
# Directories are expanded to their .rkt contents. Without --out, output
# paths derive from each file's (ns ...) declaration. With --out, .clj
# files land in the given directory with the same basename.
#
# --warn: emit Clojure despite type errors (diagnostics printed as warnings).
#         Parse errors and unresolvable bindings still fail.

set -euo pipefail
source "$(dirname "$0")/_beagle-racket"

if [[ $# -lt 1 ]]; then
    echo "usage: beagle-build-all <file-or-dir> ... [--out <dir>]" >&2
    exit 2
fi

"$RACKET" -e "(require beagle/private/build-all) (run-build-all (vector->list (current-command-line-arguments)))" -- "$@"
