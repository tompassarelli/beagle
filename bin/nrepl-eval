#!/usr/bin/env python3
"""Send a Clojure form to a running nREPL server. Speaks bencode."""
import socket, sys

def bencode(obj):
    if isinstance(obj, int):
        return f"i{obj}e".encode()
    if isinstance(obj, str):
        b = obj.encode()
        return f"{len(b)}:".encode() + b
    if isinstance(obj, bytes):
        return f"{len(obj)}:".encode() + obj
    if isinstance(obj, dict):
        parts = b"d"
        for k, v in sorted(obj.items()):
            parts += bencode(k) + bencode(v)
        return parts + b"e"
    if isinstance(obj, list):
        return b"l" + b"".join(bencode(x) for x in obj) + b"e"
    raise TypeError(f"Cannot bencode {type(obj)}")

def bdecode_one(data, idx=0):
    if data[idx:idx+1] == b"i":
        end = data.index(b"e", idx)
        return int(data[idx+1:end]), end + 1
    if data[idx:idx+1] == b"l":
        idx += 1
        lst = []
        while data[idx:idx+1] != b"e":
            val, idx = bdecode_one(data, idx)
            lst.append(val)
        return lst, idx + 1
    if data[idx:idx+1] == b"d":
        idx += 1
        d = {}
        while data[idx:idx+1] != b"e":
            key, idx = bdecode_one(data, idx)
            val, idx = bdecode_one(data, idx)
            d[key if isinstance(key, str) else key.decode()] = val
            if isinstance(d[list(d.keys())[-1]], bytes):
                d[list(d.keys())[-1]] = d[list(d.keys())[-1]].decode(errors="replace")
        return d, idx + 1
    colon = data.index(b":", idx)
    length = int(data[idx:colon])
    start = colon + 1
    raw = data[start:start+length]
    try:
        return raw.decode(), start + length
    except UnicodeDecodeError:
        return raw, start + length

def nrepl_eval(port, code, timeout=10):
    sock = socket.create_connection(("127.0.0.1", port), timeout=timeout)
    msg = bencode({"op": "eval", "code": code})
    sock.sendall(msg)
    buf = b""
    responses = []
    try:
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            buf += chunk
            while buf:
                try:
                    resp, end = bdecode_one(buf)
                    responses.append(resp)
                    buf = buf[end:]
                    if any(r.get("status") for r in responses):
                        sock.close()
                        return responses
                except (ValueError, IndexError):
                    break
    except socket.timeout:
        pass
    sock.close()
    return responses

if __name__ == "__main__":
    port = int(sys.argv[1]) if len(sys.argv) > 1 else 7888
    code = sys.argv[2] if len(sys.argv) > 2 else sys.stdin.read()
    responses = nrepl_eval(port, code)
    for r in responses:
        if "err" in r:
            print(r["err"], end="", file=sys.stderr)
        if "out" in r:
            print(r["out"], end="")
        if "value" in r:
            print(r["value"])
        if "ex" in r:
            print(f"Exception: {r['ex']}", file=sys.stderr)
